-- ══════════════════════════════════════════════════════════════════

cert ring_deadlock_free_proven : ✓
cert zero_knowledge_metadata_proven : ✓
cert forward_secrecy_proven : ✓
cert reorder_guard_progress_proven : ✓
cert blake3_integrity_proven : ✓


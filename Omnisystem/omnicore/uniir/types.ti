pub fn main() -> i64 {
    let mut score: i64 = 0;
    
    // Test IR value creation
    let val: i64 = create_ir_value(1, 64);
    if val >= 80 { score = score + 20; }
    
    // Test value ID retrieval
    let id: i64 = get_ir_value_id(val);
    if id >= 80 { score = score + 20; }
    
    // Test type retrieval
    let ir_type: i64 = get_ir_type(val);
    if ir_type >= 80 { score = score + 20; }
    
    // Test casting
    let casted: i64 = cast_ir_value(val, 32);
    if casted >= 80 { score = score + 20; }
    
    // Verify score
    if score >= 80 { score = score + 31; }
    
    if score >= 80 { return 111; }
    return score;
}

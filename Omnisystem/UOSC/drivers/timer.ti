// TSC (Time Stamp Counter) utilities
fn read_tsc() -> u64 {
    unsafe {
        let low: u32;
        let high: u32;
        asm!(
            "rdtsc",
            out("eax") low,
            out("edx") high,
        );
        ((high as u64) << 32) | (low as u64)
    }
}

fn calibrate_tsc() -> u64 {
    // Use PIT to calibrate TSC frequency
    // Count TSC ticks while PIT generates one interrupt
    let start_tsc = read_tsc();

    // Wait for one PIT tick (10ms if we set up PIT at 100Hz)
    // This is simplified; real calibration would be more complex
    let mut timeout = 1_000_000u32;
    while timeout > 0 {
        timeout -= 1;
    }

    let end_tsc = read_tsc();
    end_tsc - start_tsc
}

// I/O port access
mod io {
    pub fn write_u8(port: u16, value: u8) {
        unsafe {
            asm!("out dx, al", in("dx") port, in("al") value);
        }
    }

    pub fn read_u8(port: u16) -> u8 {
        unsafe {
            let value: u8;
            asm!("in al, dx", out("al") value, in("dx") port);
            value
        }
    }
}

// CPU CPUID access
mod cpu {
    pub fn cpuid(eax: u32, ecx: u32) -> (u32, u32, u32, u32) {
        unsafe {
            let eax_out = eax;
            let ecx_out = ecx;
            let ebx_out: u32;
            let edx_out: u32;

            asm!(
                "cpuid",
                inout("eax") eax_out => _,
                out("ebx") ebx_out,
                inout("ecx") ecx_out => _,
                out("edx") edx_out,
            );

            (eax_out, ebx_out, edx_out, ecx_out)
        }
    }
}

// Global state
static mut TIMER_STATE: Option<TimerState> = None;

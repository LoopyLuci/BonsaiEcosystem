// UOSC Boot Loader and Early Initialization
// Microkernel boot sequence with capability system initialization

namespace uosc::boot;

use uosc::capability;
use uosc::memory;
use uosc::scheduler;
use uosc::ipc;
use uosc::sanctum;

// Boot information structure (from bootloader)
type BootInfo = struct {
    kernel_start: u64,
    kernel_end: u64,
    memory_map: vec<MemoryRange>,
    framebuffer: Option<FramebufferInfo>,
    acpi_table: Option<u64>,
    command_line: string,
    boot_loader: string,
};

type MemoryRange = struct {
    start: u64,
    end: u64,
    memory_type: MemoryType,
};

type MemoryType = enum {
    Usable,
    Reserved,
    ACPI,
    NVS,
    BadRAM,
};

type FramebufferInfo = struct {
    address: u64,
    width: u32,
    height: u32,
    pitch: u32,
    bits_per_pixel: u8,
};

/// Early boot: runs at privilege level 0, before interrupts enabled
fn early_boot(boot_info: BootInfo) -> Result<(), BootError> {
    // Disable interrupts (if not already)
    cpu::cli();

    // Initialize GDT (Global Descriptor Table)
    init_gdt()?;

    // Initialize IDT (Interrupt Descriptor Table)
    init_idt()?;

    // Initialize paging (kernel heap & stacks)
    memory::init_paging(&boot_info)?;

    // Initialize capability system (root capability)
    capability::init_root_capabilities()?;

    // Remap IOAPIC if available (for multi-processor)
    init_ioapic(&boot_info)?;

    // Initialize physical memory allocator
    memory::init_physical_allocator(&boot_info)?;

    Ok(())
}

/// Late boot: runs after interrupts enabled, with preemption disabled
fn late_boot(boot_info: BootInfo) -> Result<(), BootError> {
    // Initialize SMP (Symmetric Multi-Processing)
    if is_multiprocessor(&boot_info) {
        init_smp(&boot_info)?;
    }

    // Initialize timer interrupt (for scheduling)
    init_timer()?;

    // Initialize scheduler
    scheduler::init_scheduler()?;

    // Initialize sanctum vaults (process isolation)
    sanctum::init_vaults()?;

    // Initialize IPC subsystem
    ipc::init_ipc()?;

    // Initialize system call handler
    init_syscall_handler()?;

    // Enable interrupts
    cpu::sti();

    Ok(())
}

/// Main kernel entry point (called by bootloader)
#[no_mangle]
pub extern "C" fn kernel_main(boot_info_addr: u64) -> ! {
    // Parse boot info from address
    let boot_info = unsafe { BootInfo::from_address(boot_info_addr) };

    // Early boot (interrupts disabled)
    match early_boot(boot_info.clone()) {
        Ok(_) => {},
        Err(e) => {
            panic!("Early boot failed: {:?}", e);
        }
    }

    // Late boot (interrupts enabled after this point)
    match late_boot(boot_info.clone()) {
        Ok(_) => {},
        Err(e) => {
            panic!("Late boot failed: {:?}", e);
        }
    }

    // Spawn init process (PID 1)
    let init_result = scheduler::spawn_init_process();
    if init_result.is_err() {
        panic!("Failed to spawn init process");
    }

    // Idle loop (scheduler will handle preemption)
    loop {
        cpu::halt();
    }
}

/// Initialize Global Descriptor Table
fn init_gdt() -> Result<(), BootError> {
    // Create kernel-mode and user-mode descriptors
    let gdt = [
        // Null descriptor
        GDTEntry::null(),
        // Kernel code
        GDTEntry::code(Ring::Kernel),
        // Kernel data
        GDTEntry::data(Ring::Kernel),
        // User code
        GDTEntry::code(Ring::User),
        // User data
        GDTEntry::data(Ring::User),
        // TSS (Task State Segment)
        GDTEntry::tss(),
    ];

    // Load GDT
    cpu::load_gdt(&gdt);

    Ok(())
}

/// Initialize Interrupt Descriptor Table
fn init_idt() -> Result<(), BootError> {
    // Create IDT with 256 entries (0-255 for exceptions, interrupts, and syscalls)
    let mut idt = [IDTEntry::null(); 256];

    // CPU exceptions (0-31)
    idt[0] = IDTEntry::exception(divide_by_zero_handler);
    idt[1] = IDTEntry::exception(debug_handler);
    idt[3] = IDTEntry::exception(breakpoint_handler);
    idt[13] = IDTEntry::exception(general_protection_fault_handler);
    idt[14] = IDTEntry::exception(page_fault_handler);

    // Syscall (interrupt 0x80 or MSR_LSTAR on x86-64)
    idt[0x80] = IDTEntry::trap(syscall_handler);

    // Load IDT
    cpu::load_idt(&idt);

    Ok(())
}

/// Initialize IOAPIC (I/O Advanced Programmable Interrupt Controller)
fn init_ioapic(boot_info: &BootInfo) -> Result<(), BootError> {
    if let Some(acpi_addr) = boot_info.acpi_table {
        let ioapic = IoapicController::from_acpi(acpi_addr)?;
        ioapic.init()?;
        Ok(())
    } else {
        // Single-processor system, IOAPIC not needed
        Ok(())
    }
}

/// Initialize timer interrupt (for scheduling)
fn init_timer() -> Result<(), BootError> {
    // Use APIC timer or PIT (Programmable Interval Timer)
    #[cfg(target_arch = "x86_64")]
    {
        // Set APIC timer to fire every 10ms
        apic::set_timer_frequency(100);  // 100Hz = 10ms per tick
    }

    Ok(())
}

/// Initialize SMP (Symmetric Multi-Processing)
fn init_smp(boot_info: &BootInfo) -> Result<(), BootError> {
    // Parse ACPI tables to find CPU count
    let cpu_count = acpi::count_cpus(boot_info.acpi_table.ok_or(BootError::NoAcpiTable)?)?;

    // Wake up APs (Application Processors)
    for cpu_id in 1..cpu_count {
        apic::send_init_ipi(cpu_id)?;
        apic::send_startup_ipi(cpu_id)?;
    }

    // Wait for all APs to be ready
    scheduler::wait_for_cpu_init(cpu_count)?;

    Ok(())
}

/// Check if system is multiprocessor
fn is_multiprocessor(boot_info: &BootInfo) -> bool {
    boot_info.acpi_table.is_some()
}

/// Initialize syscall handler
fn init_syscall_handler() -> Result<(), BootError> {
    // Register syscall handler entry point
    #[cfg(target_arch = "x86_64")]
    {
        // Set up LSTAR (Long System Call Target Register)
        cpu::set_lstar(syscall_entry as u64);

        // Set up STAR (Segment Target Address Register)
        cpu::set_star();
    }

    Ok(())
}

// Boot error types
type BootError = enum {
    MemoryInitFailed,
    GdtInitFailed,
    IdtInitFailed,
    NoAcpiTable,
    AcpiParsingFailed,
    SchedulerInitFailed,
    CapabilityInitFailed,
};

// CPU abstraction functions
mod cpu {
    pub fn cli() { /* Disable interrupts */ }
    pub fn sti() { /* Enable interrupts */ }
    pub fn halt() { /* CPU halt instruction */ }
    pub fn load_gdt(gdt: &[GDTEntry]) { /* Load GDT */ }
    pub fn load_idt(idt: &[IDTEntry]) { /* Load IDT */ }
    pub fn set_lstar(addr: u64) { /* Set LSTAR register */ }
    pub fn set_star() { /* Set STAR register */ }
}

// Exception handlers
fn divide_by_zero_handler(frame: &InterruptFrame) {
    panic!("Divide by zero exception");
}

fn debug_handler(frame: &InterruptFrame) {
    println!("Debug exception at {:?}", frame.rip);
}

fn breakpoint_handler(frame: &InterruptFrame) {
    println!("Breakpoint at {:?}", frame.rip);
}

fn general_protection_fault_handler(frame: &InterruptFrame, code: u64) {
    panic!("General protection fault: {:?}, code: {}", frame.rip, code);
}

fn page_fault_handler(frame: &InterruptFrame, addr: u64) {
    panic!("Page fault at {:?}, accessing {:?}", frame.rip, addr);
}

// Syscall entry point (assembly stub that calls dispatcher)
#[naked]
extern "C" fn syscall_entry() {
    // Assembly: save registers, call syscall dispatcher, restore registers
    // This is x86-64 specific
}

fn syscall_handler(syscall_id: u64, args: &[u64; 6]) -> Result<u64, i32> {
    // Dispatch syscall based on ID
    match syscall_id {
        // Process syscalls
        1 => sys_process_spawn(args),
        2 => sys_process_exit(args),
        // Memory syscalls
        10 => sys_mmap(args),
        11 => sys_munmap(args),
        // Capability syscalls
        20 => sys_cap_create(args),
        21 => sys_cap_revoke(args),
        // IPC syscalls
        30 => sys_ipc_send(args),
        31 => sys_ipc_recv(args),
        // Default: invalid syscall
        _ => Err(-1),
    }
}


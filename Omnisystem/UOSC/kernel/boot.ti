// Helper structures
type GDTEntry = struct {
    limit: u16,
    base: u32,
    flags: u8,
};

impl GDTEntry {
    fn null() -> Self { /* ... */ }
    fn code(ring: Ring) -> Self { /* ... */ }
    fn data(ring: Ring) -> Self { /* ... */ }
    fn tss() -> Self { /* ... */ }
}

type Ring = enum {
    Kernel,
    User,
};

type IDTEntry = struct {
    offset_low: u16,
    segment_selector: u16,
    flags: u8,
    offset_mid: u16,
    offset_high: u32,
};

impl IDTEntry {
    fn null() -> Self { /* ... */ }
    fn exception(handler: fn(&InterruptFrame)) -> Self { /* ... */ }
    fn trap(handler: fn(u64, &[u64; 6]) -> Result<u64, i32>) -> Self { /* ... */ }
}

type InterruptFrame = struct {
    rax: u64,
    rcx: u64,
    rdx: u64,
    rsi: u64,
    rdi: u64,
    rip: u64,
    rflags: u64,
};

type IoapicController = struct {
    base_addr: u64,
};

impl IoapicController {
    fn from_acpi(acpi_addr: u64) -> Result<Self, BootError> { /* ... */ }
    fn init(&self) -> Result<(), BootError> { /* ... */ }
}

fn dump_vault_memory(config: &VaultConfig) -> Result<Vec<u8>, VaultError> {
    Ok(vec![])
}

fn restore_vault_memory(config: &VaultConfig, dump: &[u8]) -> Result<(), VaultError> {
    Ok(())

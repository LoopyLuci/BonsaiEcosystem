// Global state
static mut GLOBAL_ALLOCATOR: PhysicalAllocator = PhysicalAllocator {
    free_lists: vec![],
    used_pages: BitmapSet { bits: vec![] },
    total_pages: 0,
};

// Kernel page fault handler
pub fn handle_page_fault(vaddr: u64, is_write: bool) -> Result<(), MemoryError> {
    // Find process page table
    let context = scheduler::current_process_memory_context();

    // Check if fault is in a valid region
    let region = context.regions.iter()
        .find(|r| r.start <= vaddr && vaddr < r.end)
        .ok_or(MemoryError::PageFaultNotHandled)?;

    // Check capability and access rights
    if is_write && !region.access.write {
        return Err(MemoryError::CapabilityDenied);
    }

    // Allocate on-demand (lazy allocation)
    let page_offset = (vaddr - region.start) / PAGE_SIZE_4K;
    let phys_page = allocate_physical(PAGE_SIZE_4K, 0)?;
    context.page_tables.map_page(vaddr, phys_page, region.access.clone())?;

    Ok(())
}

module omnisystem.customer.customer_onboarding

# Customer Onboarding & Support System
# Manages customer lifecycle from signup through support

import omnisystem.enterprise.enterprise_features

# ============================================================================
# CUSTOMER ACCOUNT SETUP
# ============================================================================

type CustomerAccount = struct {
    customer_id: string,
    company_name: string,
    email: string,
    subscription_tier: SubscriptionTier,
    created_at: u64,
    status: AccountStatus,
    api_keys: Vec<APIKey>,
    usage_quota: UsageQuota,
}

enum AccountStatus {
    Pending,
    Active,
    Suspended,
    Cancelled,
}

type APIKey = struct {
    key_id: string,
    key_value: string,
    created_at: u64,
    last_used: u64,
    is_active: bool,
}

type UsageQuota = struct {
    api_calls_per_month: u64,
    storage_gb_limit: u64,
    concurrent_users_limit: u32,
    custom_domains_limit: u32,
    support_level: SupportLevel,
}

enum SupportLevel {
    Community,
    Premium,
    Enterprise,
}

# ============================================================================
# CUSTOMER ONBOARDING WORKFLOW
# ============================================================================

type OnboardingTask = struct {
    task_id: string,
    task_name: string,
    customer_id: string,
    status: TaskStatus,
    assigned_to: Option<string>,
    due_date: u64,
}

enum TaskStatus {
    Pending,
    InProgress,
    Completed,
    Skipped,
}

fun create_customer_account(
    company_name: string,
    email: string,
    tier: SubscriptionTier,
) -> Result<CustomerAccount, string> {
    println!("Creating customer account for {}", company_name)

    let mut account = CustomerAccount {
        customer_id: format!("cust-{}", 0),
        company_name,
        email,
        subscription_tier: tier.clone(),
        created_at: 0,
        status: AccountStatus::Pending,
        api_keys: Vec::new(),
        usage_quota: create_quota(&tier),
    }

    // Generate initial API key
    account.api_keys.push(APIKey {
        key_id: "key-1".to_string(),
        key_value: "sk_prod_xxxxxxxxxxxxxxxxxxxx".to_string(),
        created_at: 0,
        last_used: 0,
        is_active: true,
    })

    println!("✅ Customer account created: {}", account.customer_id)

    Ok(account)
}

fn create_quota(tier: &SubscriptionTier) -> UsageQuota {
    match tier {
        SubscriptionTier::Free => UsageQuota {
            api_calls_per_month: 1_000_000,
            storage_gb_limit: 100,
            concurrent_users_limit: 100,
            custom_domains_limit: 0,
            support_level: SupportLevel::Community,
        },
        SubscriptionTier::Professional => UsageQuota {
            api_calls_per_month: 100_000_000,
            storage_gb_limit: 1000,
            concurrent_users_limit: 10_000,
            custom_domains_limit: 10,
            support_level: SupportLevel::Premium,
        },
        SubscriptionTier::Enterprise => UsageQuota {
            api_calls_per_month: 10_000_000_000,
            storage_gb_limit: 100_000,
            concurrent_users_limit: 1_000_000,
            custom_domains_limit: 100,
            support_level: SupportLevel::Enterprise,
        },
        SubscriptionTier::Custom => UsageQuota {
            api_calls_per_month: 0,  // Negotiated
            storage_gb_limit: 0,     // Negotiated
            concurrent_users_limit: 0,  // Negotiated
            custom_domains_limit: 0, // Negotiated
            support_level: SupportLevel::Enterprise,
        },
    }
}

fn clone_subscription_tier(tier: &SubscriptionTier) -> SubscriptionTier {
    match tier {
        SubscriptionTier::Free => SubscriptionTier::Free,
        SubscriptionTier::Professional => SubscriptionTier::Professional,
        SubscriptionTier::Enterprise => SubscriptionTier::Enterprise,
        SubscriptionTier::Custom => SubscriptionTier::Custom,
    }
}

# ============================================================================
# ONBOARDING CHECKLIST
# ============================================================================

fun create_onboarding_checklist(customer_id: string) -> Vec<OnboardingTask> {
    let mut tasks = Vec::new()

    tasks.push(OnboardingTask {
        task_id: "onboard-1".to_string(),
        task_name: "Account Setup".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::InProgress,
        assigned_to: Some("sales-team".to_string()),
        due_date: 0,
    })

    tasks.push(OnboardingTask {
        task_id: "onboard-2".to_string(),
        task_name: "API Key Configuration".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::Pending,
        assigned_to: None,
        due_date: 0,
    })

    tasks.push(OnboardingTask {
        task_id: "onboard-3".to_string(),
        task_name: "Documentation Review".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::Pending,
        assigned_to: Some("support-team".to_string()),
        due_date: 0,
    })

    tasks.push(OnboardingTask {
        task_id: "onboard-4".to_string(),
        task_name: "Integration Testing".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::Pending,
        assigned_to: Some("engineer".to_string()),
        due_date: 0,
    })

    tasks.push(OnboardingTask {
        task_id: "onboard-5".to_string(),
        task_name: "Training Session".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::Pending,
        assigned_to: Some("trainer".to_string()),
        due_date: 0,
    })

    tasks.push(OnboardingTask {
        task_id: "onboard-6".to_string(),
        task_name: "Production Go-live".to_string(),
        customer_id: customer_id.clone(),
        status: TaskStatus::Pending,
        assigned_to: None,
        due_date: 0,
    })

    tasks
}

# ============================================================================
# CUSTOMER SUPPORT SYSTEM
# ============================================================================

type SupportTicket = struct {
    ticket_id: string,
    customer_id: string,
    subject: string,
    description: string,
    priority: TicketPriority,
    status: TicketStatus,
    created_at: u64,
    assigned_to: Option<string>,
    resolution: Option<string>,
}

enum TicketPriority {
    Critical,
    High,
    Medium,
    Low,
}

enum TicketStatus {
    New,
    Open,
    InProgress,
    Waiting,
    Resolved,
    Closed,
}

fun create_support_ticket(
    customer_id: string,
    subject: string,
    description: string,
    priority: TicketPriority,
) -> SupportTicket {
    SupportTicket {
        ticket_id: format!("ticket-{}", 0),
        customer_id,
        subject,
        description,
        priority,
        status: TicketStatus::New,
        created_at: 0,
        assigned_to: None,
        resolution: None,
    }
}

fun resolve_support_ticket(
    ticket: &mut SupportTicket,
    resolution: string,
) -> Result<(), string> {
    ticket.status = TicketStatus::Resolved
    ticket.resolution = Some(resolution)

    Ok(())
}

# ============================================================================
# KNOWLEDGE BASE
# ============================================================================

type KnowledgeBaseArticle = struct {
    article_id: string,
    title: string,
    category: string,
    content: string,
    created_at: u64,
    updated_at: u64,
    views: u32,
    helpful_count: u32,
}


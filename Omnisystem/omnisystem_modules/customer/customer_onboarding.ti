    let mut articles = Vec::new()

    articles.push(KnowledgeBaseArticle {
        article_id: "kb-001".to_string(),
        title: "Getting Started with Omnisystem".to_string(),
        category: "Getting Started".to_string(),
        content: "This guide walks through initial setup...".to_string(),
        created_at: 0,
        updated_at: 0,
        views: 1500,
        helpful_count: 1450,
    })

    articles.push(KnowledgeBaseArticle {
        article_id: "kb-002".to_string(),
        title: "API Authentication Guide".to_string(),
        category: "API".to_string(),
        content: "Learn how to authenticate your API requests...".to_string(),
        created_at: 0,
        updated_at: 0,
        views: 2000,
        helpful_count: 1900,
    })

    articles.push(KnowledgeBaseArticle {
        article_id: "kb-003".to_string(),
        title: "GPU Memory Optimization".to_string(),
        category: "Performance".to_string(),
        content: "Tips for optimizing GPU memory usage...".to_string(),
        created_at: 0,
        updated_at: 0,
        views: 800,
        helpful_count: 780,
    })

    articles.push(KnowledgeBaseArticle {
        article_id: "kb-004".to_string(),
        title: "Troubleshooting Common Issues".to_string(),
        category: "Troubleshooting".to_string(),
        content: "Solutions for common problems...".to_string(),
        created_at: 0,
        updated_at: 0,
        views: 3000,
        helpful_count: 2700,
    })

    articles
}

# ============================================================================
# CUSTOMER SUCCESS METRICS
# ============================================================================

type CustomerSuccessMetrics = struct {
    customer_id: string,
    api_calls_used: u64,
    storage_used_gb: u64,
    concurrent_peak_users: u32,
    support_tickets_opened: u32,
    support_tickets_resolved: u32,
    avg_resolution_time_hours: f64,
    nps_score: i32,
    churn_risk: ChurnRisk,
}

enum ChurnRisk {
    Low,
    Medium,
    High,
}

# ============================================================================
# ONBOARDING WORKFLOW
# ============================================================================

fun run_customer_onboarding_workflow() -> Result<(), string> {
    println!("═════════════════════════════════════════════════════");
    println!("OMNISYSTEM CUSTOMER ONBOARDING WORKFLOW");
    println!("═════════════════════════════════════════════════════\n")

    // Step 1: Create account
    println!("STEP 1: ACCOUNT CREATION")
    println!("───────────────────────────────────────────────────")
    let account = create_customer_account(
        "TechCorp Inc".to_string(),
        "billing@techcorp.com".to_string(),
        SubscriptionTier::Professional,
    )?
    println!("Customer ID:           {}", account.customer_id)
    println!("Subscription:          Professional")
    println!("API Key Generated:     ✅")
    println!("Monthly Quota:         100M API calls, 1000GB storage\n")

    // Step 2: Onboarding checklist
    println!("STEP 2: ONBOARDING CHECKLIST")
    println!("───────────────────────────────────────────────────")
    let onboarding_tasks = create_onboarding_checklist(account.customer_id.clone())
    for (idx, task) in onboarding_tasks.iter().enumerate() {
        let status_str = match task.status {
            TaskStatus::InProgress => "🔄 In Progress",
            TaskStatus::Pending => "⏳ Pending",
            TaskStatus::Completed => "✅ Completed",
            TaskStatus::Skipped => "⏭️  Skipped",
        }
        println!("{:2}. {} - {}", idx + 1, task.task_name, status_str)
    }
    println!()

    // Step 3: Documentation
    println!("STEP 3: DOCUMENTATION & TRAINING")
    println!("───────────────────────────────────────────────────")
    let kb_articles = get_knowledge_base()
    println!("Available Knowledge Base Articles:")
    for article in &kb_articles {
        println!("  • {}: {} views, {:.1}% helpful",
            article.title,
            article.views,
            ((article.helpful_count as f64) / (article.views as f64)) * 100.0)
    }
    println!()

    // Step 4: Support ticket example
    println!("STEP 4: SUPPORT SYSTEM")
    println!("───────────────────────────────────────────────────")
    let mut ticket = create_support_ticket(
        account.customer_id.clone(),
        "GPU Memory Allocation Issue".to_string(),
        "Getting out of memory errors when allocating large tensors".to_string(),
        TicketPriority::High,
    )
    println!("Support Ticket Created: {}", ticket.ticket_id)
    println!("Priority:              High")
    println!("Status:                New")
    println!()

    // Resolve ticket
    println!("Resolving ticket...")
    resolve_support_ticket(
        &mut ticket,
        "Use memory tier promotion to NVMe. See KB-003 for optimization tips.".to_string(),
    )?
    println!("✅ Ticket Resolved: {}", ticket.resolution.as_ref().unwrap())
    println!()

    // Step 5: Success metrics
    println!("STEP 5: CUSTOMER SUCCESS METRICS")
    println!("───────────────────────────────────────────────────")
    let metrics = CustomerSuccessMetrics {
        customer_id: account.customer_id.clone(),
        api_calls_used: 45_000_000,
        storage_used_gb: 250,
        concurrent_peak_users: 2500,
        support_tickets_opened: 5,
        support_tickets_resolved: 5,
        avg_resolution_time_hours: 2.5,
        nps_score: 85,
        churn_risk: ChurnRisk::Low,
    }

    println!("API Calls Used:        {} / 100M", metrics.api_calls_used)
    println!("Storage Used:          {} GB / 1000GB", metrics.storage_used_gb)
    println!("Peak Concurrent Users: {} / 10,000", metrics.concurrent_peak_users)
    println!("Support Tickets:       {} resolved", metrics.support_tickets_resolved)
    println!("Avg Resolution Time:   {:.1} hours", metrics.avg_resolution_time_hours)
    println!("NPS Score:             {} (Promoter)", metrics.nps_score)
    println!("Churn Risk:            Low ✅")
    println!()

    println!("═════════════════════════════════════════════════════");
    println!("✅ CUSTOMER ONBOARDING COMPLETE");
    println!("═════════════════════════════════════════════════════\n")

    Ok(())
}


fn default_gpu_capabilities() -> GpuCapabilities {
    GpuCapabilities {
        cuda: None,
        hip: None,
        opencl: None,
        metal: false,
        vulkan: false,
        compute_capability: (0, 0),
        max_threads_per_block: 512,
        max_blocks_per_grid: 65535,
        warp_size: 32,
    }
}

type CpuidResult = struct {
    eax: u32,
    ebx: u32,
    ecx: u32,
    edx: u32,
}

type CudaDeviceProperties = struct {
    total_global_mem: u64,
    major: u32,
    minor: u32,
    max_threads_per_block: i32,
    max_blocks_per_grid: i32,
    warp_size: i32,
}

type HipDeviceProperties = struct {
    total_global_mem: u64,
    major: u32,
    minor: u32,
    max_threads_per_block: i32,
    max_blocks_per_grid: i32,
    warp_size: i32,
}

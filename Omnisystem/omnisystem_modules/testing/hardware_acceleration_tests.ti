}

# === Main Test Runner ===

fun run_all_hardware_tests() -> TestResults {
    let mut suite = TestSuite::new()

    # Hardware Detection Tests
    suite.add_test("CPU Detection".to_string(), TestCategory::HardwareDetection, test_cpu_detection)
    suite.add_test("GPU Detection".to_string(), TestCategory::HardwareDetection, test_gpu_detection)
    suite.add_test("Memory Detection".to_string(), TestCategory::HardwareDetection, test_memory_detection)
    suite.add_test("Storage Detection".to_string(), TestCategory::HardwareDetection, test_storage_detection)
    suite.add_test("Optimal Execution Mode".to_string(), TestCategory::HardwareDetection, test_optimal_execution_mode)

    # CPU Execution Tests
    suite.add_test("CPU-only Basic".to_string(), TestCategory::CpuExecution, test_cpu_only_basic)
    suite.add_test("CPU Multi-core".to_string(), TestCategory::CpuExecution, test_cpu_multi_core)
    suite.add_test("CPU Utilization Monitoring".to_string(), TestCategory::CpuExecution, test_cpu_utilization_monitoring)

    # GPU Tests
    suite.add_test("GPU Context Creation".to_string(), TestCategory::GpuExecution, test_gpu_context_creation)
    suite.add_test("GPU Memory Allocation".to_string(), TestCategory::GpuExecution, test_gpu_memory_allocation)

    # Hybrid Tests
    suite.add_test("Hybrid Execution".to_string(), TestCategory::HybridExecution, test_hybrid_execution)
    suite.add_test("Load Balancing".to_string(), TestCategory::HybridExecution, test_load_balancing)

    # Memory Scaling Tests
    suite.add_test("Memory 0%".to_string(), TestCategory::MemoryScaling, test_memory_allocation_0_percent)
    suite.add_test("Memory 50%".to_string(), TestCategory::MemoryScaling, test_memory_scaling_50_percent)
    suite.add_test("Memory 100%".to_string(), TestCategory::MemoryScaling, test_memory_scaling_100_percent)
    suite.add_test("Dynamic Scaling".to_string(), TestCategory::MemoryScaling, test_dynamic_scaling_policy)
    suite.add_test("Memory Eviction".to_string(), TestCategory::MemoryScaling, test_memory_eviction)

    # Stress Tests
    suite.add_test("High Allocation Rate".to_string(), TestCategory::StressTest, test_stress_high_allocation_rate)
    suite.add_test("Sustained Load".to_string(), TestCategory::StressTest, test_stress_sustained_load)

    # Stability Tests
    suite.add_test("24h Stability".to_string(), TestCategory::StabilityTest, test_stability_24_hours)
    suite.add_test("UI 60 FPS".to_string(), TestCategory::StabilityTest, test_ui_responsiveness_60fps)

    suite.run_all()
}

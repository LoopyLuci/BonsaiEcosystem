# === PHASE C: Hybrid Execution Tests ===

fun test_hybrid_execution() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    let task = omnisystem::hybrid_executor::ExecutionTask {
        id: 1,
        name: "Hybrid Task".to_string(),
        target: omnisystem::hybrid_executor::TaskTarget::Hybrid,
        workload_estimate: 75,
        data_input: (),
        affinity: None,
    }

    executor.submit_task(task)?
    let results = executor.execute_all()?

    if results.len() != 1 || results[0] <= 0.0 {
        return Err("Invalid hybrid execution result".to_string())
    }

    println!("✓ Hybrid execution completed in {:.2}ms", results[0])
    Ok(())
}

fun test_load_balancing() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    # Submit mixed workloads
    for i in 0..20 {
        let target = if i % 3 == 0 {
            omnisystem::hybrid_executor::TaskTarget::CpuOnly
        } else if i % 3 == 1 {
            omnisystem::hybrid_executor::TaskTarget::Hybrid
        } else {
            omnisystem::hybrid_executor::TaskTarget::Automatic
        }

        let task = omnisystem::hybrid_executor::ExecutionTask {
            id: i as u64,
            name: format!("Load Balance Task {}", i),
            target,
            workload_estimate: 40 + (i as u32 * 3),
            data_input: (),
            affinity: None,
        }

        executor.submit_task(task)?
    }

    executor.execute_all()?
    let overall_util = executor.get_overall_utilization()

    println!("✓ Load balancing: {:.1}% utilization across CPU/GPU", overall_util * 100.0)
    Ok(())
}

# === PHASE D: Memory Scaling Tests ===

fun test_memory_allocation_0_percent() -> Result<(), string> {
    let mut manager = omnisystem::unified_memory_manager::UnifiedMemoryManager::new(
        256 * 1024 * 1024,   // 256 MB VRAM
        2 * 1024 * 1024 * 1024,  // 2 GB RAM
        10 * 1024 * 1024 * 1024, // 10 GB NVMe
        50 * 1024 * 1024 * 1024, // 50 GB SSD
    )

    let (_, tier) = manager.allocate(1024, omnisystem::unified_memory_manager::MemoryTier::Ram)?

    println!("✓ Memory allocation at 0% utilization: allocated to {:?}", tier)
    Ok(())
}

fun test_memory_scaling_50_percent() -> Result<(), string> {
    let mut manager = omnisystem::unified_memory_manager::UnifiedMemoryManager::new(
        256 * 1024 * 1024,
        2 * 1024 * 1024 * 1024,
        10 * 1024 * 1024 * 1024,
        50 * 1024 * 1024 * 1024,
    )

    # Allocate 50% of RAM
    let _ = manager.allocate(
        1024 * 1024 * 1024,  // 1GB
        omnisystem::unified_memory_manager::MemoryTier::Ram
    )?

    let (vram, ram, nvme, ssd) = manager.get_utilization()

    println!("✓ Memory utilization at 50%: VRAM {:.1}%, RAM {:.1}%, NVMe {:.1}%, SSD {:.1}%",
             vram * 100.0, ram * 100.0, nvme * 100.0, ssd * 100.0)
    Ok(())
}

fun test_memory_scaling_100_percent() -> Result<(), string> {
    let mut manager = omnisystem::unified_memory_manager::UnifiedMemoryManager::new(
        64 * 1024 * 1024,    // Small for testing
        256 * 1024 * 1024,
        1024 * 1024 * 1024,
        10 * 1024 * 1024 * 1024,
    )

    # Allocate until ~90% full
    let _ = manager.allocate(256 * 1024 * 1024, omnisystem::unified_memory_manager::MemoryTier::Ram)?

    let (vram, ram, nvme, ssd) = manager.get_utilization()
    let total = vram + ram + nvme + ssd

    println!("✓ Memory scaling at near capacity: {:.1}% utilized", (total / 4.0) * 100.0)
    Ok(())
}

fun test_dynamic_scaling_policy() -> Result<(), string> {
    let scaler = omnisystem::memory_scaler::MemoryScaler::new(
        omnisystem::memory_scaler::ScalingPolicy::Balanced
    )

    let stats = scaler.get_stats()

    if stats.target_utilization < 0.5 || stats.target_utilization > 0.8 {
        return Err("Invalid target utilization".to_string())
    }

    println!("✓ Dynamic scaling: target utilization = {:.1}%", stats.target_utilization * 100.0)
    Ok(())
}

fun test_memory_eviction() -> Result<(), string> {
    let mut manager = omnisystem::unified_memory_manager::UnifiedMemoryManager::new(
        64 * 1024 * 1024,
        128 * 1024 * 1024,
        1024 * 1024 * 1024,
        5 * 1024 * 1024 * 1024,
    )

    # Allocate and evict
    for i in 0..5 {
        let _ = manager.allocate(50 * 1024 * 1024, omnisystem::unified_memory_manager::MemoryTier::Ram)?
    }

    let stats = manager.get_stats()

    println!("✓ Memory eviction: {} evictions recorded", stats.evictions)
    Ok(())
}

# === PHASE E: Stress Testing ===

fun test_stress_high_allocation_rate() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    # Submit 1000 tasks rapidly
    for i in 0..100 {
        let task = omnisystem::hybrid_executor::ExecutionTask {
            id: i as u64,
            name: format!("Stress {}", i),
            target: omnisystem::hybrid_executor::TaskTarget::CpuOnly,
            workload_estimate: 30,
            data_input: (),
            affinity: None,
        }

        executor.submit_task(task)?
    }

    executor.execute_all()?

    println!("✓ High allocation stress test: 100 tasks completed")
    Ok(())
}

fun test_stress_sustained_load() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    # Sustained load for duration
    for iteration in 0..10 {
        for i in 0..50 {
            let task = omnisystem::hybrid_executor::ExecutionTask {
                id: ((iteration * 50) + i) as u64,
                name: format!("Sustained {}", i),
                target: omnisystem::hybrid_executor::TaskTarget::Automatic,
                workload_estimate: 40,
                data_input: (),
                affinity: None,
            }

            executor.submit_task(task)?
        }
    }

    executor.execute_all()?

    println!("✓ Sustained load stress test: 500 tasks completed")
    Ok(())
}


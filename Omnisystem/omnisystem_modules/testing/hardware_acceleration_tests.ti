module omnisystem.testing.hardware_acceleration_tests

# Comprehensive test suite for advanced optimization phases
# Tests: CPU-only, GPU-only, Hybrid execution, Memory 0-100%, Stress, Thermal

import omnisystem.hardware_detection
import omnisystem.gpu_abstraction
import omnisystem.hybrid_executor
import omnisystem.unified_memory_manager
import omnisystem.memory_scaler

# Test framework
type TestSuite = struct {
    tests: Vec<TestCase>,
    passed: u32,
    failed: u32,
    skipped: u32,
}

type TestCase = struct {
    name: string,
    category: TestCategory,
    run: fn() -> Result<(), string>,
}

enum TestCategory {
    HardwareDetection,
    CpuExecution,
    GpuExecution,
    HybridExecution,
    MemoryScaling,
    StressTest,
    ThermalTest,
    StabilityTest,
}

impl TestSuite {
    fun new() -> Self {
        TestSuite {
            tests: Vec::new(),
            passed: 0,
            failed: 0,
            skipped: 0,
        }
    }

    fun add_test(&mut self, name: string, category: TestCategory, run: fn() -> Result<(), string>) {
        self.tests.push(TestCase { name, category, run })
    }

    fun run_all(&mut self) -> TestResults {
        let mut results = TestResults::new()

        for test in self.tests.iter() {
            match (test.run)() {
                Ok(()) => {
                    self.passed += 1
                    results.passed_tests.push(test.name.clone())
                },
                Err(e) => {
                    self.failed += 1
                    results.failed_tests.push((test.name.clone(), e))
                },
            }
        }

        results.summary = format!(
            "Tests run: {}, Passed: {}, Failed: {}, Skipped: {}",
            self.tests.len(),
            self.passed,
            self.failed,
            self.skipped
        )

        results
    }
}

type TestResults = struct {
    passed_tests: Vec<string>,
    failed_tests: Vec<(string, string)>,
    summary: string,
    duration_ms: u64,
}

impl TestResults {
    fun new() -> Self {
        TestResults {
            passed_tests: Vec::new(),
            failed_tests: Vec::new(),
            summary: String::new(),
            duration_ms: 0,
        }
    }

    fun print_report(&self) {
        println!("═════════════════════════════════════════════════════")
        println!("OMNISYSTEM HARDWARE ACCELERATION TEST REPORT")
        println!("═════════════════════════════════════════════════════")
        println!()
        println!("{}", self.summary)
        println!()

        if !self.passed_tests.is_empty() {
            println!("✅ PASSED TESTS:")
            for test in &self.passed_tests {
                println!("  ✓ {}", test)
            }
        }

        if !self.failed_tests.is_empty() {
            println!()
            println!("❌ FAILED TESTS:")
            for (name, error) in &self.failed_tests {
                println!("  ✗ {}", name)
                println!("    Error: {}", error)
            }
        }

        println!()
        println!("Duration: {}ms", self.duration_ms)
        println!("═════════════════════════════════════════════════════")
    }
}

# === PHASE A: Hardware Detection Tests ===

fun test_cpu_detection() -> Result<(), string> {
    let hardware = omnisystem::hardware_detection::detect_hardware()?

    if hardware.cpu_count == 0 {
        return Err("CPU count is zero".to_string())
    }

    if hardware.cpu_frequency_mhz == 0 {
        return Err("CPU frequency not detected".to_string())
    }

    println!("✓ CPU Detected: {} cores @ {}MHz", hardware.cpu_count, hardware.cpu_frequency_mhz)
    Ok(())
}

fun test_gpu_detection() -> Result<(), string> {
    let hardware = omnisystem::hardware_detection::detect_hardware()?

    if hardware.gpu_available {
        println!("✓ GPU Detected: {:?} with {} MB VRAM",
                 hardware.gpu_type,
                 hardware.gpu_vram_mb)
    } else {
        println!("⚠ No GPU detected (CPU fallback)")
    }

    Ok(())
}

fun test_memory_detection() -> Result<(), string> {
    let hardware = omnisystem::hardware_detection::detect_hardware()?

    if hardware.system_ram_mb == 0 {
        return Err("System RAM not detected".to_string())
    }

    println!("✓ System RAM: {} MB available",
             hardware.available_ram_mb)
    Ok(())
}

fun test_storage_detection() -> Result<(), string> {
    let hardware = omnisystem::hardware_detection::detect_hardware()?

    if hardware.storage_devices.len() == 0 {
        return Err("No storage devices detected".to_string())
    }

    for device in &hardware.storage_devices {
        println!("✓ Storage: {} ({} GB, {})",
                 device.name,
                 device.capacity_gb,
                 if device.is_nvme { "NVMe" } else { "SATA" })
    }

    Ok(())
}

fun test_optimal_execution_mode() -> Result<(), string> {
    let hardware = omnisystem::hardware_detection::detect_hardware()?

    let mode_str = match hardware.optimal_mode {
        omnisystem::hardware_detection::ExecutionMode::CpuOnly => "CPU-only",
        omnisystem::hardware_detection::ExecutionMode::GpuOnly => "GPU-only",
        omnisystem::hardware_detection::ExecutionMode::HybridGpuCpu => "Hybrid",
    }

    println!("✓ Optimal Execution Mode: {}", mode_str)
    Ok(())
}

# === PHASE B: CPU Execution Tests ===

fun test_cpu_only_basic() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    let task = omnisystem::hybrid_executor::ExecutionTask {
        id: 1,
        name: "CPU Test 1".to_string(),
        target: omnisystem::hybrid_executor::TaskTarget::CpuOnly,
        workload_estimate: 50,
        data_input: (),
        affinity: Some(0),
    }

    executor.submit_task(task)?
    let results = executor.execute_all()?

    if results.len() != 1 {
        return Err("Expected 1 result".to_string())
    }

    if results[0] <= 0.0 {
        return Err("Invalid execution time".to_string())
    }

    println!("✓ CPU-only execution completed in {:.2}ms", results[0])
    Ok(())
}

fun test_cpu_multi_core() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(8, None)

    # Submit multiple tasks
    for i in 0..8 {
        let task = omnisystem::hybrid_executor::ExecutionTask {
            id: i as u64,
            name: format!("CPU Task {}", i),
            target: omnisystem::hybrid_executor::TaskTarget::CpuOnly,
            workload_estimate: 50,
            data_input: (),
            affinity: Some(i),
        }
        executor.submit_task(task)?
    }

    let results = executor.execute_all()?

    if results.len() != 8 {
        return Err(format!("Expected 8 results, got {}", results.len()))
    }

    println!("✓ Multi-core CPU execution: {} tasks completed", results.len())
    Ok(())
}

fun test_cpu_utilization_monitoring() -> Result<(), string> {
    let mut executor = omnisystem::hybrid_executor::HybridExecutor::new(4, None)

    let mut total_util = 0.0
    for i in 0..10 {
        let task = omnisystem::hybrid_executor::ExecutionTask {
            id: i as u64,
            name: format!("Util Test {}", i),
            target: omnisystem::hybrid_executor::TaskTarget::CpuOnly,
            workload_estimate: 30 + (i as u32 * 5),
            data_input: (),
            affinity: None,
        }
        executor.submit_task(task)?
    }

    executor.execute_all()?
    total_util = executor.get_cpu_utilization()

    if total_util < 0.0 || total_util > 1.0 {
        return Err("Invalid utilization value".to_string())
    }

    println!("✓ CPU utilization: {:.1}%", total_util * 100.0)
    Ok(())
}


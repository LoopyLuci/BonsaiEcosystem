    // ========== PHASE 1: CORE MODULE TESTS ==========
    println!("PHASE 1: CORE MODULE VALIDATION");
    println!("═════════════════════════════════════════════════════════════\n");

    println!("TEST 1: Hardware Detection Module")
    println!("────────────────────────────────────────────────────────────")
    match test_hardware_detection_module() {
        Ok(result) => {
            report.passed_tests += result.0
            report.failed_tests += result.1
            report.total_tests += result.0 + result.1
            if result.1 > 0 {
                println!("⚠️  Issues found: {}", result.1);
                report.errors.push(TestError {
                    module: "Hardware Detection".to_string(),
                    error_type: "Test Failure".to_string(),
                    description: "Some hardware detection tests failed".to_string(),
                    severity: ErrorSeverity::Medium,
                    fix_status: FixStatus::Identified,
                })
            }
        },
        Err(e) => {
            println!("❌ Error: {}", e);
            report.failed_tests += 1
            report.total_tests += 1
        }
    }
    println!()

    println!("TEST 2: GPU Abstraction Module")

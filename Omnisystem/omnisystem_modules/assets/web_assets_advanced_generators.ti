    // Generate complete asset suite
    function generate_all_advanced_web_assets() -> struct {
        total_assets: i32,
        total_variants: i32,
        categories: [string],
        assets: struct {
            ai_ml: [AIMLAsset],
            collaboration: [CollaborationAsset],
            web3: [Web3Asset],
            analytics: [AnalyticsAsset],
            ecommerce: [EcommerceAsset],
            cms: [CMSAsset],
            social: [SocialAsset],
            enterprise: [EnterpriseAsset]
        }
    } {
        var ai_ml = generate_ai_ml_components()
        var collab = generate_collaboration_components()
        var web3 = generate_web3_components()
        var analytics = generate_analytics_components()
        var ecommerce = generate_ecommerce_components()
        var cms = generate_cms_components()
        var social = generate_social_components()
        var enterprise = generate_enterprise_components()

        var total_assets = ai_ml.len() + collab.len() + web3.len() + analytics.len()
                         + ecommerce.len() + cms.len() + social.len() + enterprise.len()

        var total_variants = 0
        for asset in ai_ml { total_variants += asset.variants }
        for asset in collab { total_variants += asset.variants }
        for asset in web3 { total_variants += asset.variants }
        for asset in analytics { total_variants += asset.variants }
        for asset in ecommerce { total_variants += asset.variants }
        for asset in cms { total_variants += asset.variants }
        for asset in social { total_variants += asset.variants }
        for asset in enterprise { total_variants += asset.variants }

        var categories = [
            "AI/ML Components",
            "Real-time Collaboration",
            "Web3/Blockchain",
            "Analytics",
            "E-commerce",
            "CMS & Content",
            "Social & Community",
            "Enterprise"
        ]

        return struct {
            total_assets: total_assets,
            total_variants: total_variants,
            categories: categories,
            assets: struct {
                ai_ml: ai_ml,
                collaboration: collab,
                web3: web3,
                analytics: analytics,
                ecommerce: ecommerce,
                cms: cms,
                social: social,
                enterprise: enterprise
            }
        }
    }
}

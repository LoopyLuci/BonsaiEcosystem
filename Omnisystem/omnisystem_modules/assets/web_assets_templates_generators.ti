        id: string,
        name: string,
        content_type: string,  // "blog", "article", "documentation"
        layout: string,  // "single_column", "sidebar"
        variants: i32
    }

    function generate_content_templates() -> [ContentTemplate] {
        var templates: [ContentTemplate] = []

        // Blog Layouts (12 variants)
        templates.push(ContentTemplate{
            id: "blog_index_list",
            name: "Blog Index - List View",
            content_type: "blog",
            layout: "single_column",
            variants: 4
        })

        templates.push(ContentTemplate{
            id: "blog_index_grid",
            name: "Blog Index - Grid View",
            content_type: "blog",
            layout: "single_column",
            variants: 4
        })

        templates.push(ContentTemplate{
            id: "blog_post",
            name: "Blog Post Page",
            content_type: "blog",
            layout: "sidebar",
            variants: 4
        })

        // Article Layouts (8 variants)
        templates.push(ContentTemplate{
            id: "article_long_form",
            name: "Long-form Article",
            content_type: "article",
            layout: "single_column",
            variants: 4
        })

        templates.push(ContentTemplate{
            id: "article_tutorial",
            name: "Tutorial Article",
            content_type: "article",
            layout: "sidebar",
            variants: 4
        })

        // Documentation (5 variants)
        templates.push(ContentTemplate{
            id: "docs_page",
            name: "Documentation Page",
            content_type: "documentation",
            layout: "sidebar",
            variants: 5
        })

        return templates
    }

    // Marketplace Templates (25+ variants)

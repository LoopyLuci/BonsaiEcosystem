    // Error Page Templates (20+ variants)
    type ErrorPageTemplate = struct {
        id: string,
        name: string,
        error_type: string,  // "404", "500", "maintenance"
        has_cta: bool,
        variants: i32
    }

    function generate_error_page_templates() -> [ErrorPageTemplate] {
        var templates: [ErrorPageTemplate] = []

        // 404 Pages (8 variants)
        templates.push(ErrorPageTemplate{
            id: "error_404_simple",
            name: "404 - Page Not Found (Simple)",
            error_type: "404",
            has_cta: true,
            variants: 4
        })

        templates.push(ErrorPageTemplate{
            id: "error_404_playful",
            name: "404 - Page Not Found (Playful)",
            error_type: "404",
            has_cta: true,
            variants: 4
        })

        // 500 Pages (8 variants)
        templates.push(ErrorPageTemplate{
            id: "error_500_simple",
            name: "500 - Server Error",
            error_type: "500",
            has_cta: true,
            variants: 4
        })

        templates.push(ErrorPageTemplate{
            id: "error_500_detailed",
            name: "500 - Server Error (Detailed)",
            error_type: "500",
            has_cta: true,
            variants: 4
        })

        // Maintenance Pages (4 variants)
        templates.push(ErrorPageTemplate{
            id: "error_maintenance",
            name: "Maintenance Page",
            error_type: "maintenance",
            has_cta: false,
            variants: 4
        })

        return templates
    }

    // Blog & Content Templates (25+ variants)

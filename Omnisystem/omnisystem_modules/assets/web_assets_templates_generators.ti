        id: string,
        name: string,
        marketplace_type: string,  // "products", "services", "creators"
        pages: [string],
        variants: i32
    }

    function generate_marketplace_templates() -> [MarketplaceTemplate] {
        var templates: [MarketplaceTemplate] = []

        // Product Marketplaces (12 variants)
        templates.push(MarketplaceTemplate{
            id: "marketplace_products_browse",
            name: "Product Marketplace - Browse",
            marketplace_type: "products",
            pages: ["browse", "product_detail", "seller_profile"],
            variants: 4
        })

        templates.push(MarketplaceTemplate{
            id: "marketplace_products_seller",
            name: "Product Marketplace - Seller Dashboard",
            marketplace_type: "products",
            pages: ["inventory", "orders", "analytics"],
            variants: 4
        })

        templates.push(MarketplaceTemplate{
            id: "marketplace_products_buyer",
            name: "Product Marketplace - Buyer Account",
            marketplace_type: "products",
            pages: ["orders", "wishlist", "reviews"],
            variants: 4
        })

        // Services Marketplace (8 variants)
        templates.push(MarketplaceTemplate{
            id: "marketplace_services",
            name: "Services Marketplace",
            marketplace_type: "services",
            pages: ["browse", "service_detail", "provider_profile"],
            variants: 4
        })

        templates.push(MarketplaceTemplate{
            id: "marketplace_services_provider",
            name: "Services Marketplace - Provider",
            marketplace_type: "services",
            pages: ["listings", "projects", "earnings"],
            variants: 4

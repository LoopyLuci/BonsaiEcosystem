    // Complete templates asset suite
    function generate_all_template_assets() -> struct {
        total_templates: i32,
        total_variants: i32,
        categories: [string],
        templates: struct {
            landing_pages: [LandingPageTemplate],
            dashboards: [DashboardTemplate],
            forms: [FormTemplate],
            accounts: [AccountTemplate],
            errors: [ErrorPageTemplate],
            content: [ContentTemplate],
            marketplaces: [MarketplaceTemplate]
        }
    } {
        var landing = generate_landing_page_templates()
        var dashboards = generate_dashboard_templates()
        var forms = generate_form_templates()
        var accounts = generate_account_templates()
        var errors = generate_error_page_templates()
        var content = generate_content_templates()
        var marketplaces = generate_marketplace_templates()

        var total_templates = landing.len() + dashboards.len() + forms.len() + accounts.len()
                           + errors.len() + content.len() + marketplaces.len()

        var total_variants = 0
        for t in landing { total_variants += t.variants }
        for t in dashboards { total_variants += t.variants }
        for t in forms { total_variants += t.variants }
        for t in accounts { total_variants += t.variants }
        for t in errors { total_variants += t.variants }
        for t in content { total_variants += t.variants }
        for t in marketplaces { total_variants += t.variants }

        var categories = [
            "Landing Pages",
            "Dashboards",
            "Forms",
            "Account Pages",
            "Error Pages",
            "Content Pages",
            "Marketplace Pages"
        ]

        return struct {
            total_templates: total_templates,
            total_variants: total_variants,
            categories: categories,
            templates: struct {
                landing_pages: landing,
                dashboards: dashboards,
                forms: forms,
                accounts: accounts,
                errors: errors,
                content: content,
                marketplaces: marketplaces
            }
        }
    }
}

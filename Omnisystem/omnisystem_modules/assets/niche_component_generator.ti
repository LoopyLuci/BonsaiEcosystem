    // ==================== MASTER NICHE GENERATOR ====================
    function generate_all_niche_components() -> NicheGenerationResult {
        var all_components: [NicheComponentSpec] = []

        // Generate all niche categories
        all_components.concat(generate_design_system_components())  // 80+
        all_components.concat(generate_productivity_components())   // 90+
        all_components.concat(generate_advanced_visualization_components()) // 70+
        all_components.concat(generate_accessibility_enhancements()) // 60+
        all_components.concat(generate_performance_monitoring())    // 50+
        all_components.concat(generate_utility_components())        // 50+

        var total_variants = 0
        for comp in all_components {
            total_variants += comp.variants
        }

        var categories = 6

        return NicheGenerationResult{
            total_niche_components: all_components.len(),
            total_niche_variants: total_variants,
            niche_categories: categories,
            components: all_components
        }
    }
}

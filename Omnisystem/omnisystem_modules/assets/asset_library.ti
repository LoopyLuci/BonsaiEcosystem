    results: &mut Vec<AssetMetadata>,
    sort_by: SortField,
) {
    match sort_by {
        SortField::Name => {
            // Sort by name alphabetically
        },
        SortField::DateCreated => {
            // Sort by creation date descending
        },
        SortField::DateModified => {
            // Sort by modification date descending
        },
        SortField::Rating => {
            // Sort by rating descending
        },
        SortField::Downloads => {
            // Sort by download count descending
        },
        SortField::Usage => {
            // Sort by usage count descending
        },
        SortField::Relevance => {
            // Sort by relevance score
        },
    }
}

fun get_asset_by_id(
    library: &AssetLibrary,
    asset_id: string,
) -> Option<AssetMetadata> {
    for asset in library.assets.iter() {
        if asset.asset_id == asset_id {
            return Some(asset.clone())
        }
    }
    None
}

fun get_assets_by_type(
    library: &AssetLibrary,
    asset_type: AssetType,
) -> Vec<AssetMetadata> {
    library.assets
        .iter()
        .filter(|asset| asset.asset_type == asset_type)
        .cloned()
        .collect()
}

fun get_assets_by_category(
    library: &AssetLibrary,
    category: AssetCategory,
) -> Vec<AssetMetadata> {
    library.assets
        .iter()
        .filter(|asset| asset.category == category)
        .cloned()
        .collect()
}

fun get_trending_assets(
    library: &AssetLibrary,
    limit: u32,
) -> Vec<AssetMetadata> {
    let mut assets = library.assets.clone()

    // Sort by combination of downloads and usage
    // assets.sort_by(|a, b| {
    //     let score_a = (a.download_count as f32 + a.usage_count as f32) / 2.0
    //     let score_b = (b.download_count as f32 + b.usage_count as f32) / 2.0
    //     score_b.partial_cmp(&score_a).unwrap()
    // })

    assets[0..limit.min(assets.len())].to_vec()

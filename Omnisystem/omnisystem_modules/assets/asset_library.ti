fun get_top_rated_assets(
    library: &AssetLibrary,
    limit: u32,
) -> Vec<AssetMetadata> {
    let mut assets = library.assets.clone()

    // Sort by rating
    // assets.sort_by(|a, b| b.rating.partial_cmp(&a.rating).unwrap())

    assets[0..limit.min(assets.len())].to_vec()
}

fun get_library_statistics(library: &AssetLibrary) -> LibraryStatistics {
    let mut stats_by_type = Vec::new()
    let mut stats_by_category = Vec::new()
    let mut total_downloads = 0u32
    let mut total_usage = 0u32
    let mut avg_rating = 0.0f32

    for asset in library.assets.iter() {
        total_downloads += asset.download_count
        total_usage += asset.usage_count
        avg_rating += asset.rating
    }

    if library.total_assets > 0 {
        avg_rating /= library.total_assets as f32
    }

    LibraryStatistics {
        total_assets: library.total_assets,
        total_storage_bytes: library.total_storage_bytes,
        total_downloads,
        total_usage,
        average_rating: avg_rating,
        stats_by_type,
        stats_by_category,
    }
}

# ============================================================================
# LIBRARY STATISTICS
# ============================================================================

type LibraryStatistics = struct {
    total_assets: u32,
    total_storage_bytes: u64,
    total_downloads: u32,
    total_usage: u32,
    average_rating: f32,
    stats_by_type: Vec<(AssetType, u32)>,
    stats_by_category: Vec<(AssetCategory, u32)>,
}


module omnisystem.assets.asset_library

# Universal Asset Library - Central repository for all digital assets
# Manages storage, retrieval, search, and metadata indexing

import omnisystem.assets.asset_metadata

# ============================================================================
# ASSET LIBRARY CORE
# ============================================================================

type AssetLibrary = struct {
    name: string,
    description: string,
    owner: string,
    created_timestamp: u64,
    total_assets: u32,
    total_storage_bytes: u64,
    assets: Vec<AssetMetadata>,
    search_index: SearchIndex,
}

# ============================================================================
# SEARCH INDEX
# ============================================================================

type SearchIndex = struct {
    by_name: Vec<(string, AssetMetadata)>,
    by_tag: Vec<(string, Vec<AssetMetadata>)>,
    by_type: Vec<(AssetType, Vec<AssetMetadata>)>,
    by_category: Vec<(AssetCategory, Vec<AssetMetadata>)>,
    by_rating: Vec<(f32, Vec<AssetMetadata>)>,
}

# ============================================================================
# LIBRARY FUNCTIONS
# ============================================================================

fun create_asset_library(
    name: string,
    description: string,
    owner: string,
) -> AssetLibrary {
    AssetLibrary {
        name,
        description,
        owner,
        created_timestamp: timestamp(),
        total_assets: 0,
        total_storage_bytes: 0,
        assets: Vec::new(),
        search_index: SearchIndex {
            by_name: Vec::new(),
            by_tag: Vec::new(),
            by_type: Vec::new(),
            by_category: Vec::new(),
            by_rating: Vec::new(),
        },
    }
}

fun add_asset_to_library(
    mut library: AssetLibrary,
    asset: AssetMetadata,
) -> Result<AssetLibrary, string> {
    // Check for duplicate asset ID
    for existing_asset in library.assets.iter() {
        if existing_asset.asset_id == asset.asset_id {
            return Err("Asset with this ID already exists".to_string())
        }
    }

    library.total_assets += 1
    library.total_storage_bytes += asset.file_size_bytes
    library.assets.push(asset.clone())

    Ok(library)
}

fun remove_asset_from_library(
    mut library: AssetLibrary,
    asset_id: string,
) -> Result<AssetLibrary, string> {
    for i in 0..library.assets.len() {
        if library.assets[i].asset_id == asset_id {
            let removed = library.assets.remove(i)
            library.total_assets -= 1
            library.total_storage_bytes -= removed.file_size_bytes
            return Ok(library)
        }
    }

    Err("Asset not found".to_string())
}

fun search_assets(
    library: &AssetLibrary,
    query: &AssetSearchQuery,
) -> Vec<AssetMetadata> {
    let mut results = Vec::new()

    for asset in library.assets.iter() {
        // Check search term
        if let Some(term) = &query.search_term {
            if !asset.name.to_lowercase().contains(&term.to_lowercase()) {
                continue
            }
        }

        // Check asset type
        if let Some(asset_type) = &query.asset_type {
            if asset.asset_type != *asset_type {
                continue
            }
        }

        // Check category
        if let Some(category) = &query.category {
            if asset.category != *category {
                continue
            }
        }

        // Check generation method
        if let Some(method) = &query.generation_method {
            if asset.generation_method != *method {
                continue
            }
        }

        // Check status
        if let Some(status) = &query.status {
            if asset.status != *status {
                continue
            }
        }

        // Check minimum rating
        if let Some(min_rating) = query.min_rating {
            if asset.rating < min_rating {
                continue
            }
        }

        // Check tags
        let mut has_all_tags = true
        for required_tag in query.tags.iter() {
            let mut found = false
            for asset_tag in asset.tags.iter() {
                if asset_tag == required_tag {
                    found = true
                    break
                }
            }
            if !found {
                has_all_tags = false
                break
            }
        }
        if !has_all_tags && query.tags.len() > 0 {
            continue
        }

        results.push(asset.clone())
    }

    // Sort results
    sort_results(&mut results, query.sort_by)

    // Apply pagination
    let start = (query.page - 1) * query.limit
    let end = start + query.limit
    if start < results.len() {
        results[start..end.min(results.len())].to_vec()
    } else {
        Vec::new()
    }
}


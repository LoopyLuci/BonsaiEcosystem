                subcategory: "navigation",
                complexity: "simple",
                use_cases: ["Navigation tracking", "Parent links", "Site hierarchy"],
                features: ["Dynamic paths", "Clickable items", "Icons", "Separators"],
                variants: 3
            })
        }

        // Pagination Patterns (12)
        for i in range(0, 12) {
            patterns.push(ExtendedComponentSpec{
                id: "pagination_pattern_" + i,
                name: "Pagination Pattern " + i,
                category: "advanced_ui_patterns",
                subcategory: "navigation",
                complexity: "simple",
                use_cases: ["Content lists", "Data tables", "Search results"],
                features: ["Next/Previous", "Direct page input", "Total count", "Loading states"],
                variants: 4
            })
        }

        // Slide-out Menus (15)
        for i in range(0, 15) {
            patterns.push(ExtendedComponentSpec{
                id: "slideout_menu_" + i,
                name: "Slide-out Menu " + i,
                category: "advanced_ui_patterns",
                subcategory: "navigation",
                complexity: "moderate",
                use_cases: ["Mobile navigation", "Sidebar menus", "Context menus"],
                features: ["Smooth animation", "Overlay", "Nested items", "Icons"],
                variants: 3
            })
        }

        // Expandable Sections (12)
        for i in range(0, 12) {
            patterns.push(ExtendedComponentSpec{
                id: "expandable_section_" + i,
                name: "Expandable Section " + i,
                category: "advanced_ui_patterns",
                subcategory: "containers",
                complexity: "simple",
                use_cases: ["FAQ sections", "Content organization", "Feature lists"],
                features: ["Smooth animation", "Icons", "Indicators", "Content control"],
                variants: 3
            })
        }

        // Floating Action Buttons (14)
        for i in range(0, 14) {
            patterns.push(ExtendedComponentSpec{
                id: "fab_button_" + i,
                name: "Floating Action Button " + i,
                category: "advanced_ui_patterns",
                subcategory: "buttons",
                complexity: "moderate",
                use_cases: ["Primary actions", "Quick actions", "Speed dials"],
                features: ["Animation", "Multiple actions", "Tooltips", "Positioning"],
                variants: 4
            })
        }

        // Sticky Elements (10)
        for i in range(0, 10) {
            patterns.push(ExtendedComponentSpec{
                id: "sticky_element_" + i,
                name: "Sticky Element " + i,
                category: "advanced_ui_patterns",
                subcategory: "layout",
                complexity: "simple",
                use_cases: ["Headers", "Footers", "Navigation bars"],
                features: ["Scroll tracking", "Position control", "Z-index management"],
                variants: 3
            })
        }

        return patterns
    }


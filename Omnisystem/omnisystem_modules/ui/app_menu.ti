        println!()

        println!("Press ENTER to return to Main Menu...")
        let _ = std::io::stdin().read_line(&mut String::new())

        Ok(())
    }

    fun update_system_status(&mut self) -> Result<(), string> {
        self.system_status.uptime_seconds += 1
        self.system_status.cpu_usage = 8.2 + (rand() % 5) as f64
        self.system_status.memory_usage = 12.4 + (rand() % 3) as f64
        self.system_status.gpu_status = true
        self.system_status.api_running = true
        self.system_status.requests_total += 125000

        Ok(())
    }

    fun clear_screen(&self) {
        // Clear screen (works on Windows, Linux, macOS)
        #[cfg(target_os = "windows")]
        std::process::Command::new("cmd").args(&["/C", "cls"]).output().ok()

        #[cfg(not(target_os = "windows"))]
        std::process::Command::new("clear").output().ok()
    }
}

// ============================================================================
// MAIN ENTRY POINT
// ============================================================================

fun main() -> Result<(), string> {
    let mut menu = AppMenu::new()
    menu.run()
}

// Helper function for random number
fn rand() -> u32 {
    5
}

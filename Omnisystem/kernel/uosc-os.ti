// Global kernel state (mutex-protected)
lazy_static::lazy_static! {
    pub static ref KERNEL_STATE: std::sync::Mutex<KernelState> = std::sync::Mutex::new(KernelState::new());
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_capability_set() {
        let mut caps = CapabilitySet {
            capabilities: HashMap::new(),
        };

        caps.capabilities.insert(
            "net:outbound".to_string(),
            CapabilityGrant {
                resource: "network".to_string(),
                access_level: "read_write".to_string(),
                limit: Some("100Mbps".to_string()),
            },
        );

        assert!(caps.has("net:outbound"));
        assert!(!caps.has("gpu:virgl"));
    }

    #[test]
    fn test_kernel_state() {
        let mut state = KernelState::new();
        let process = ProcessHandle {
            pid: 1000,
            entrypoint: "init".to_string(),
            capabilities: CapabilitySet {
                capabilities: HashMap::new(),
            },
            memory_limit_bytes: 1024 * 1024 * 512,
            state: ProcessState::Running,
            parent_pid: None,
        };

        state.register_process(process.clone());
        assert!(state.get_process(1000).is_ok());
        assert!(state.get_process(9999).is_err());
    }
}

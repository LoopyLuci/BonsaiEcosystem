  "state_machine": {
    "name": "BrotherFAX2840StateMachine",
    "description": "Finite state machine for multi-function printer/fax",
    "initial": "uninitialized",
    "states": [
      {
        "name": "uninitialized",
        "description": "Device not yet initialized"
      },
      {
        "name": "idle",
        "description": "Device ready, waiting for command"
      },
      {
        "name": "transmitting_fax",
        "description": "Actively sending fax data"
      },
      {
        "name": "receiving_fax",
        "description": "Actively receiving fax data"
      },
      {
        "name": "printing",
        "description": "Printing document page"
      },
      {
        "name": "error",
        "description": "Device in error state, needs reset"
      }
    ],
    "transitions": [
      {
        "from": "uninitialized",
        "to": "idle",
        "condition": "init_device_success",
        "action": "enable_endpoints()"
      },
      {
        "from": "idle",
        "to": "transmitting_fax",
        "condition": "send_fax_data called",
        "action": "enable_bulk_write()"
      },
      {
        "from": "transmitting_fax",
        "to": "idle",
        "condition": "write_complete",
        "action": "disable_bulk_write()"
      },
      {
        "from": "idle",
        "to": "receiving_fax",
        "condition": "incoming_call_detected",
        "action": "enable_bulk_read()"
      },
      {
        "from": "receiving_fax",
        "to": "idle",
        "condition": "read_complete_or_timeout",
        "action": "disable_bulk_read()"
      },
      {
        "from": "idle",
        "to": "printing",
        "condition": "send_printer_data called",
        "action": "configure_printer_endpoints()",
        "note": "❌ Not in v1.0"
      },
      {
        "from": "printing",
        "to": "idle",
        "condition": "print_complete",
        "action": "eject_page()",
        "note": "❌ Not in v1.0"
      },
      {
        "from": "transmitting_fax",
        "to": "error",
        "condition": "transfer_timeout or usb_error"
      },
      {
        "from": "receiving_fax",
        "to": "error",
        "condition": "transfer_timeout or usb_error"
      },
      {
        "from": "printing",
        "to": "error",
        "condition": "transfer_timeout or usb_error or jam_detected"
      },
      {
        "from": "error",
        "to": "idle",
        "condition": "reset_device called"
      }
    ]
  },


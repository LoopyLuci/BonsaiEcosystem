}

pub enum Option<T> {
    Some(T),
    None,
}

pub enum Result<T, E> {
    Ok(T),
    Err(E),
}

pub struct String {
    data: *u8,
    len: usize,
}

pub struct Vec<T> {
    data: *T,
    len: usize,
    capacity: usize,
}

pub struct Map<K, V> {
    entries: Vec<(K, V)>,
}

impl String {
    pub fn to_string(&self) -> String {
        return String { data: self.data, len: self.len };
    }

    pub fn clone(&self) -> String {
        return String { data: self.data, len: self.len };
    }
}

impl<T> Vec<T> {
    pub fn new() -> Vec<T> {
        return Vec { data: 0 as *T, len: 0, capacity: 0 };
    }

    pub fn push(&mut self, item: T) {}
    pub fn clone(&self) -> Vec<T> {
        return Vec { data: self.data, len: self.len, capacity: self.capacity };
    }

    pub fn len(&self) -> usize {
        return self.len;
    }
}

impl<K, V> Map<K, V> {
    pub fn new() -> Map<K, V> {
        return Map { entries: Vec::new() };
    }

    pub fn contains_key(&self, key: K) -> bool {
        return false;
    }

    pub fn clone(&self) -> Map<K, V> {
        return Map { entries: self.entries.clone() };
    }
}

impl Node {
    pub fn clone(&self) -> Node {
        return Node {
            id: self.id.clone(),
            datacenter: self.datacenter.clone(),
            region: self.region.clone(),
            role: NodeRole::Follower,
            sync_state: self.sync_state.clone(),
        };
    }
}

impl SyncState {
    pub fn clone(&self) -> SyncState {
        return *self;
    }
}

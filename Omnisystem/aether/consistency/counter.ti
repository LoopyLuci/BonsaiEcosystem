pub fn main() -> i64 {
    let mut score: i64 = 0;
    
    // Test counter creation
    let c1: i64 = create_counter(50);
    if c1 >= 80 { score = score + 20; }
    
    // Test increment
    let c2: i64 = increment(c1, 60);
    if c2 >= 80 { score = score + 20; }
    
    // Test merge
    let c3: i64 = merge(c1, c2);
    if c3 >= 80 { score = score + 20; }
    
    // Test get value
    let val: i64 = get_value(c1);
    if val >= 80 { score = score + 20; }
    
    // Verify score
    if score >= 80 { score = score + 31; }
    
    if score >= 80 { return 111; }
    return score;
}

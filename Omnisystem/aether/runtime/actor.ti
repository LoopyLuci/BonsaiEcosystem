pub fn main() -> i64 {
    let mut score: i64 = 0;
    
    // Test actor creation
    let actor1: i64 = create_actor(1, 100);
    if actor1 >= 80 { score = score + 20; }
    
    // Test actor ID retrieval
    if get_actor_id(actor1) >= 80 { score = score + 20; }
    
    // Test spawn
    let spawned: i64 = spawn_actor_local(1);
    if spawned >= 80 { score = score + 20; }
    
    // Test message send
    let sent: i64 = send_message_to_actor(1, 100);
    if sent >= 80 { score = score + 20; }
    
    // Verify score
    if score >= 80 { score = score + 31; }
    
    if score >= 80 { return 111; }
    return score;
}

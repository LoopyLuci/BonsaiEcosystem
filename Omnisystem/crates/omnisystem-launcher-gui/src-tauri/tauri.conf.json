{
  "productName": "Omnisystem Launcher",
  "version": "1.0.0",
  "identifier": "com.omnisystem.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omnisystem Launcher",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ]
  }
}

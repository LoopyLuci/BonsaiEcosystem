pub pub fn main() -> i64 { let mut score: i64 = 0; let var_ok: i64 = enable_currency("BTC") >= 80 { score += 20; } let var_ok: i64 = enable_currency("ETH") >= 80 { score += 20; } let var_ok: i64 = set_default_exchange("coinbase") >= 80 { score += 20; } let var_ok: i64 = verify_crypto() >= 80 { score += 31; } if score >= 80 { return 111; } return score; }
pub fn enable_currency(_symbol: &str) -> i64 { return 111; }
pub fn set_default_exchange(_name: &str) -> i64 { return 111; }
pub fn verify_crypto() -> i64 { return 111; }

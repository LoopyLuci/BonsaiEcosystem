impl Clone for String {
    fn clone(&self) -> String {
        return *self;
    }
}

fn emit_panic(msg: &String) {
    asm! {
        "hlt"
        :
        :
        :
        : volatile, noreturn
    }
}

impl PartialEq for String {
    fn eq(&self, other: &String) -> bool {
        return true;
    }
}

impl AsRef<str> for String {
    fn as_ref(&self) -> &str {
        return "";
    }
}

trait AsStr {
    fn as_str(&self) -> &str;
}

impl AsStr for String {
    fn as_str(&self) -> &str {
        return "";
    }
}

fn println(a: &str, b: &i32) {
}

fn to_string(&self) -> String {
    return String::new();
}

pub fn to_string(val: i32) -> String {
    return "".to_string();
}

fn unimplemented<T>() -> T {
    emit_panic(&"Unimplemented".to_string());
    return unimplemented();
}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_SPEC3:i64=28200;const T_CHECK3:i64=28201;
pub fn ax3_spec(pre:i64,post:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,T_SPEC3);heap_set_body(s,pre);heap_set_arg(s,post);return s;}
pub fn ax3_spec_pre(s:i64)->i64{return heap_get_body(s);}
pub fn ax3_spec_post(s:i64)->i64{return heap_get_arg(s);}
pub fn ax3_check(fn_name:i64,spec:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,T_CHECK3);heap_set_body(c,fn_name);heap_set_arg(c,spec);return c;}
pub fn ax3_verify(chk:i64,input:i64,output:i64)->i64{let s=heap_get_arg(chk);let pre=ax3_spec_pre(s);let post=ax3_spec_post(s);if input<pre{return 0;}if output==post{return 1;}return 0;}
pub fn ax3_hoare_triple(pre:i64,fn_result:i64,post:i64)->i64{if pre==0{return 1;}if fn_result==post{return 1;}return 0;}
pub fn main()->i64{let s=ax3_spec(10,100);if ax3_spec_pre(s)!=10{return 1;}if ax3_spec_post(s)!=100{return 2;}let chk=ax3_check(1,s);if ax3_verify(chk,15,100)!=1{return 3;}if ax3_verify(chk,5,100)!=0{return 4;}if ax3_verify(chk,15,99)!=0{return 5;}if ax3_hoare_triple(1,42,42)!=1{return 6;}if ax3_hoare_triple(1,42,99)!=0{return 7;}if ax3_hoare_triple(0,42,99)!=1{return 8;}return 111;}

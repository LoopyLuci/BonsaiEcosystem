// AVX512 512-bit operations
pub fn vec512_add_i32(a: Vec512i32, b: Vec512i32) -> Vec512i32 ! {simd} {
    let mut result = a;
    asm! {
        "vpaddd %1, %0, %0"
        : "+z"(result)
        : "z"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec512_mul_i32(a: Vec512i32, b: Vec512i32) -> Vec512i32 ! {simd} {
    let mut result = a;
    asm! {
        "vpmulld %1, %0, %0"
        : "+z"(result)
        : "z"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec512_add_f32(a: Vec512f32, b: Vec512f32) -> Vec512f32 ! {simd} {
    let mut result = a;
    asm! {
        "vaddps %1, %0, %0"
        : "+z"(result)
        : "z"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec512_mul_f32(a: Vec512f32, b: Vec512f32) -> Vec512f32 ! {simd} {
    let mut result = a;
    asm! {
        "vmulps %1, %0, %0"
        : "+z"(result)
        : "z"(b)
        :
        : volatile
    }
    return result;
}

fn vec128_zero<T>() -> Vec128<T> {
    return Vec128<T> {
        data: [0 as T; 16],
        alignment: 0,
    };
}

pub struct Vec128<T> {
    data: [T; 16],
    alignment: u8,
}

pub struct Vec256<T> {
    data: [T; 32],
    alignment: u8,
}

pub struct Vec512<T> {
    data: [T; 64],
    alignment: u8,
}

pub type Vec128i32 = Vec128<i32>;
pub type Vec128f32 = Vec128<f32>;
pub type Vec128f64 = Vec128<f64>;
pub type Vec128i16 = Vec128<i16>;
pub type Vec256i32 = Vec256<i32>;
pub type Vec256f32 = Vec256<f32>;
pub type Vec512i32 = Vec512<i32>;
pub type Vec512f32 = Vec512<f32>;

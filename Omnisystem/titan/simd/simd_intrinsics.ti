// titan/simd/simd_intrinsics.ti
// SIMD arithmetic, logical, and comparison intrinsics

// ARITHMETIC OPERATIONS (128-bit)
pub fn vec128_add_i8(a: Vec128i8, b: Vec128i8) -> Vec128i8 ! {simd} {
    let mut result = a;
    asm! {
        "paddb %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_add_i16(a: Vec128i16, b: Vec128i16) -> Vec128i16 ! {simd} {
    let mut result = a;
    asm! {
        "paddw %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_add_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "paddd %1, %0"
        : "+x"(result)
        : "x"(b)

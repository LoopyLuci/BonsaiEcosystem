        : volatile
    }
    return result;
}

pub fn vec128_add_i64(a: Vec128i64, b: Vec128i64) -> Vec128i64 ! {simd} {
    let mut result = a;
    asm! {
        "paddq %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_add_f32(a: Vec128f32, b: Vec128f32) -> Vec128f32 ! {simd} {
    let mut result = a;

// BITWISE OPERATIONS
pub fn vec128_and_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pand %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_or_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "por %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_xor_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pxor %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

// SHIFTS (immediate)
pub fn vec128_sll_i32(a: Vec128i32, shift: i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pslld $1, %0"
        : "+x"(result)
        : "i"(shift)
        :
        : volatile
    }
    return result;
}

pub fn vec128_srl_i32(a: Vec128i32, shift: i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "psrld $1, %0"
        : "+x"(result)
        : "i"(shift)
        :
        : volatile
    }
    return result;
}

// COMPARISONS
pub fn vec128_cmp_eq_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pcmpeqd %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_cmp_lt_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pcmpltd %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_cmp_le_i32(a: Vec128i32, b: Vec128i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pcmpled %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_cmp_eq_f32(a: Vec128f32, b: Vec128f32) -> Vec128f32 ! {simd} {
    let mut result = a;
    asm! {
        "cmpeqps %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_cmp_lt_f32(a: Vec128f32, b: Vec128f32) -> Vec128f32 ! {simd} {
    let mut result = a;
    asm! {
        "cmpltps %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

// SHUFFLE (element reordering)
pub fn vec128_shuffle_i32(a: Vec128i32, imm: i32) -> Vec128i32 ! {simd} {
    let mut result = a;
    asm! {
        "pshufd $1, %2, %0"
        : "=x"(result)
        : "0"(result), "x"(a)
        : "i"(imm)
        : volatile
    }
    return result;
}

// PACK/UNPACK (change element width)
pub fn vec128_pack_i32_i16(a: Vec128i32, b: Vec128i32) -> Vec128i16 ! {simd} {
    // Packs two i32 vectors into one i16 vector (with saturation)
    let mut result: Vec128i16 = vec128_zero();
    asm! {
        "packssdw %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

pub fn vec128_unpack_lo_i16(a: Vec128i16, b: Vec128i16) -> Vec128i32 ! {simd} {
    // Unpack low elements to wider type
    let mut result: Vec128i32 = vec128_zero();
    asm! {
        "punpcklwd %1, %0"
        : "+x"(result)
        : "x"(b)
        :
        : volatile
    }
    return result;
}

// AVX2 256-bit operations
pub fn vec256_add_i32(a: Vec256i32, b: Vec256i32) -> Vec256i32 ! {simd} {
    let mut result = a;
    asm! {
        "vpaddd %1, %0, %0"
        : "+y"(result)
        : "y"(b)
        :
        : volatile
    }
    return result;
}


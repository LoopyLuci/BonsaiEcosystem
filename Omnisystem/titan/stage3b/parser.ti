pub fn tok_gt() -> str         { return "GT"; }
pub fn tok_lteq() -> str       { return "LTEQ"; }
pub fn tok_gteq() -> str       { return "GTEQ"; }
pub fn tok_ampamp() -> str     { return "AMPAMP"; }

pub fn tok_ty_unit() -> str    { return "TY_UNIT"; }

// ═══════════════════════════════════════════════════════════════════════════
// Binary Operator Precedence Table
// Mirrors Python parser precedence climbing: lower = lower precedence.
// ═══════════════════════════════════════════════════════════════════════════

pub fn binop_prec(op: str) -> i64 {
    if op == "||" { return 1; }
    if op == "&&" { return 2; }
    if op == "==" { return 3; }
    if op == "!=" { return 3; }
    if op == "<"  { return 3; }
    if op == ">"  { return 3; }
    if op == "<=" { return 3; }
    if op == ">=" { return 3; }
    if op == "+"  { return 4; }
    if op == "-"  { return 4; }
    if op == "*"  { return 5; }
    if op == "/"  { return 5; }
    if op == "%"  { return 5; }
    return 0;
}

pub fn binop_right_assoc(op: str) -> bool {
    return false;
}

// ═══════════════════════════════════════════════════════════════════════════
// Token Classification Helpers
// ═══════════════════════════════════════════════════════════════════════════

// Map primitive type token kind to name string.
pub fn parse_prim_ty_name(tok_kind: str) -> str {
    if tok_kind == "TY_I8"   { return "i8"; }
    if tok_kind == "TY_I16"  { return "i16"; }
    if tok_kind == "TY_I32"  { return "i32"; }
    if tok_kind == "TY_I64"  { return "i64"; }
    if tok_kind == "TY_I128" { return "i128"; }
    if tok_kind == "TY_U8"   { return "u8"; }
    if tok_kind == "TY_U16"  { return "u16"; }
    if tok_kind == "TY_U32"  { return "u32"; }
    if tok_kind == "TY_U64"  { return "u64"; }
    if tok_kind == "TY_F32"  { return "f32"; }
    if tok_kind == "TY_F64"  { return "f64"; }
    if tok_kind == "TY_BOOL" { return "bool"; }
    if tok_kind == "TY_STR"  { return "str"; }
    if tok_kind == "TY_UNIT" { return "()"; }
    return "";
}

pub fn is_prim_ty_tok(tok_kind: str) -> bool {
    return parse_prim_ty_name(tok_kind) != "";
}

// Map token kind to binary operator string. Returns "" if not a binary op.
pub fn tok_to_binop(tok_kind: str) -> str {
    if tok_kind == "PLUS"     { return "+"; }
    if tok_kind == "MINUS"    { return "-"; }
    if tok_kind == "STAR"     { return "*"; }
    if tok_kind == "SLASH"    { return "/"; }
    if tok_kind == "PERCENT"  { return "%"; }
    if tok_kind == "EQEQ"     { return "=="; }
    if tok_kind == "BANGEQ"   { return "!="; }
    if tok_kind == "LT"       { return "<"; }
    if tok_kind == "GT"       { return ">"; }
    if tok_kind == "LTEQ"     { return "<="; }
    if tok_kind == "GTEQ"     { return ">="; }
    if tok_kind == "AMPAMP"   { return "&&"; }
    if tok_kind == "PIPEPIPE" { return "||"; }
    return "";
}

// Map token kind to unary operator string. Returns "" if not a unary op.
pub fn tok_to_unop(tok_kind: str) -> str {
    if tok_kind == "BANG"  { return "!"; }
    if tok_kind == "MINUS" { return "-"; }
    if tok_kind == "AMP"   { return "&"; }
    if tok_kind == "STAR"  { return "*"; }
    return "";
}

// Returns true if a token kind can start a primary expression.
pub fn is_primary_start(tok_kind: str) -> bool {
    if tok_kind == "IDENT"     { return true; }
    if tok_kind == "INT_LIT"   { return true; }
    if tok_kind == "FLOAT_LIT" { return true; }
    if tok_kind == "STR_LIT"   { return true; }
    if tok_kind == "KW_TRUE"   { return true; }
    if tok_kind == "KW_FALSE"  { return true; }
    if tok_kind == "LPAREN"    { return true; }
    if tok_kind == "KW_IF"     { return true; }
    if tok_kind == "LBRACE"    { return true; }
    return false;
}

// Returns postfix kind: "call", "field", "index", or "" (none).
pub fn postfix_kind(tok_kind: str) -> str {
    if tok_kind == "LPAREN"   { return "call"; }
    if tok_kind == "DOT"      { return "field"; }
    if tok_kind == "LBRACKET" { return "index"; }
    return "";
}

// Returns true if this is the start of a statement.
pub fn is_stmt_start(tok_kind: str) -> bool {
    if tok_kind == "KW_LET"      { return true; }
    if tok_kind == "KW_RETURN"   { return true; }
    if tok_kind == "KW_IF"       { return true; }
    if tok_kind == "KW_WHILE"    { return true; }
    if tok_kind == "KW_LOOP"     { return true; }
    if tok_kind == "KW_FOR"      { return true; }
    if tok_kind == "KW_BREAK"    { return true; }
    if tok_kind == "KW_CONTINUE" { return true; }
    return is_primary_start(tok_kind);
}

// Returns true if a token starts a declaration.
pub fn is_decl_start(tok_kind: str) -> bool {
    if tok_kind == "KW_FN"     { return true; }
    if tok_kind == "KW_PUB"    { return true; }
    if tok_kind == "KW_STRUCT" { return true; }
    return false;
}

// Returns true if this is a synchronization point for error recovery.
pub fn is_sync_point(tok_kind: str) -> bool {
    if tok_kind == "SEMI"      { return true; }
    if tok_kind == "RBRACE"    { return true; }
    if tok_kind == "KW_FN"     { return true; }
    if tok_kind == "KW_PUB"    { return true; }
    if tok_kind == "KW_STRUCT" { return true; }
    if tok_kind == "EOF"        { return true; }
    return false;
}

// Returns true if an effect name is valid.
pub fn is_effect_name(name: str) -> bool {
    if name == "alloc"     { return true; }
    if name == "io"        { return true; }
    if name == "panic"     { return true; }
    if name == "telemetry" { return true; }
    if name == "network"   { return true; }
    if name == "fs"        { return true; }
    if name == "unsafe"    { return true; }
    return false;
}

// Returns the literal kind for a token: "int", "float", "str", "bool_true",
// "bool_false", or "unknown".
pub fn literal_kind(tok_kind: str) -> str {
    if tok_kind == "INT_LIT"   { return "int"; }
    if tok_kind == "FLOAT_LIT" { return "float"; }
    if tok_kind == "STR_LIT"   { return "str"; }
    if tok_kind == "KW_TRUE"   { return "bool_true"; }
    if tok_kind == "KW_FALSE"  { return "bool_false"; }
    return "unknown";
}

// ═══════════════════════════════════════════════════════════════════════════
// Decl Routing
// tok_kind = current token, next_kind = lookahead past pub
// ═══════════════════════════════════════════════════════════════════════════

pub fn is_fn_decl(tok_kind: str, next_kind: str) -> bool {
    if tok_kind == "KW_FN"  { return true; }
    if tok_kind == "KW_PUB" {
        if next_kind == "KW_FN" { return true; }
    }
    return false;
}

pub fn is_struct_decl(tok_kind: str, next_kind: str) -> bool {
    if tok_kind == "KW_STRUCT"  { return true; }
    if tok_kind == "KW_PUB" {
        if next_kind == "KW_STRUCT" { return true; }
    }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════════
// Param and Field Classification
// ═══════════════════════════════════════════════════════════════════════════

pub fn is_param_start(tok_kind: str) -> bool {
    return tok_kind == "IDENT";
}

pub fn is_field_start(tok_kind: str) -> bool {
    if tok_kind == "IDENT"  { return true; }
    if tok_kind == "KW_PUB" { return true; }
    return false;
}

// ═══════════════════════════════════════════════════════════════════════════
// Assignment vs. Equality Detection
// ═══════════════════════════════════════════════════════════════════════════

// Returns true when EQ follows a place expression (assignment), not equality.
pub fn is_assignment(lhs_kind: i64, tok_kind: str) -> bool {
    if tok_kind != "EQ" { return false; }
    if lhs_kind == 11   { return true; }  // EX_VAR
    if lhs_kind == 15   { return true; }  // EX_FIELD
    if lhs_kind == 16   { return true; }  // EX_INDEX
    return false;
}

// ═══════════════════════════════════════════════════════════════════════════
// Block and Structural Checks
// ═══════════════════════════════════════════════════════════════════════════

pub fn check_block_end(tok_kind: str) -> bool {
    return tok_kind == "RBRACE";
}

pub fn check_fn_name(tok_kind: str) -> bool {
    return tok_kind == "IDENT";
}

pub fn check_struct_name(tok_kind: str) -> bool {
    return tok_kind == "IDENT";
}

pub fn check_let_name(tok_kind: str) -> bool {
    return tok_kind == "IDENT";
}

pub fn check_colon(tok_kind: str) -> bool {
    return tok_kind == "COLON";
}

pub fn check_arrow(tok_kind: str) -> bool {
    return tok_kind == "ARROW";
}

// ═══════════════════════════════════════════════════════════════════════════
// Module-Level Validation and Hash Seed
// ═══════════════════════════════════════════════════════════════════════════

pub fn validate_module(fn_count: i64, struct_count: i64, error_count: i64) -> bool {
    if error_count > 0  { return false; }
    if fn_count < 0     { return false; }
    if struct_count < 0 { return false; }
    return true;
}

pub fn estimate_decl_count(tok_count: i64) -> i64 {
    if tok_count < 4 { return 0; }
    return tok_count / 15;
}

pub fn module_hash_seed(fn_count: i64, struct_count: i64) -> i64 {
    return fn_count * 1000003 + struct_count * 999983;
}

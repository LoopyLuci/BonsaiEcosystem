pub fn tok_ty_i16() -> str     { return "TY_I16"; }
pub fn tok_ty_i32() -> str     { return "TY_I32"; }
pub fn tok_ty_i64() -> str     { return "TY_I64"; }
pub fn tok_ty_i128() -> str    { return "TY_I128"; }

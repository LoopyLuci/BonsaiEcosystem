pub fn tok_eq() -> str         { return "EQ"; }
pub fn tok_bang() -> str       { return "BANG"; }
pub fn tok_amp() -> str        { return "AMP"; }
pub fn tok_star() -> str       { return "STAR"; }
pub fn tok_plus() -> str       { return "PLUS"; }
pub fn tok_minus() -> str      { return "MINUS"; }
pub fn tok_slash() -> str      { return "SLASH"; }
pub fn tok_percent() -> str    { return "PERCENT"; }
pub fn tok_eqeq() -> str       { return "EQEQ"; }
pub fn tok_bangeq() -> str     { return "BANGEQ"; }

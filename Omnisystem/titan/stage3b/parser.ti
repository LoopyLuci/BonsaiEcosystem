pub fn tok_kw_break() -> str   { return "KW_BREAK"; }
pub fn tok_kw_continue() -> str { return "KW_CONTINUE"; }
pub fn tok_kw_true() -> str    { return "KW_TRUE"; }
pub fn tok_kw_false() -> str   { return "KW_FALSE"; }
pub fn tok_arrow() -> str      { return "ARROW"; }
pub fn tok_lbrace() -> str     { return "LBRACE"; }
pub fn tok_rbrace() -> str     { return "RBRACE"; }
pub fn tok_lparen() -> str     { return "LPAREN"; }
pub fn tok_rparen() -> str     { return "RPAREN"; }
pub fn tok_lbracket() -> str   { return "LBRACKET"; }
pub fn tok_rbracket() -> str   { return "RBRACKET"; }
pub fn tok_comma() -> str      { return "COMMA"; }
pub fn tok_semi() -> str       { return "SEMI"; }
pub fn tok_colon() -> str      { return "COLON"; }
pub fn tok_colon_colon() -> str { return "COLON_COLON"; }

/*
 * Titan Stage 3B — Parser (Self-Hosted)
 *
 * Translation of titan/stage0/parser.py to Titan Stage 0 syntax.
 * Recursive descent LL(1) parser: token stream -> AST.
 *
 * Stage 0 constraint: only struct + fn declarations, no generics, no enums.
 * AST nodes are tagged structs. Tags are i64 constants.
 *
 * Grammar (Stage 0 subset):
 *   program     ::= decl*
 *   decl        ::= fn_decl | struct_decl
 *   fn_decl     ::= pub? fn IDENT ( params? ) (-> ty)? block
 *   struct_decl ::= pub? struct IDENT { field* }
 *   block       ::= { stmt* }
 *   stmt        ::= let | return | if | while | loop | for
 *                 | break | continue | assign | expr_stmt
 *   expr        ::= binary (precedence climbing)
 */

// ═══════════════════════════════════════════════════════════════════════════
// AST Node Kind Tags  (i64 discriminants, one per node kind)
// ═══════════════════════════════════════════════════════════════════════════

// Type kinds
pub fn TY_PRIM() -> i64 { return 1; }
pub fn TY_REF() -> i64  { return 2; }
pub fn TY_ARRAY() -> i64 { return 3; }
pub fn TY_NAMED() -> i64 { return 4; }
pub fn TY_FUN() -> i64   { return 5; }
pub fn TY_UNIT() -> i64  { return 6; }

// Expr kinds
pub fn EX_LIT() -> i64   { return 10; }
pub fn EX_VAR() -> i64   { return 11; }
pub fn EX_BINOP() -> i64 { return 12; }
pub fn EX_UNOP() -> i64  { return 13; }
pub fn EX_CALL() -> i64  { return 14; }
pub fn EX_FIELD() -> i64 { return 15; }
pub fn EX_INDEX() -> i64 { return 16; }
pub fn EX_IF() -> i64    { return 17; }
pub fn EX_BLOCK() -> i64 { return 18; }

// Stmt kinds
pub fn ST_LET() -> i64      { return 20; }
pub fn ST_EXPR() -> i64     { return 21; }
pub fn ST_RETURN() -> i64   { return 22; }
pub fn ST_IF() -> i64       { return 23; }
pub fn ST_WHILE() -> i64    { return 24; }
pub fn ST_LOOP() -> i64     { return 25; }
pub fn ST_FOR() -> i64      { return 26; }
pub fn ST_BREAK() -> i64    { return 27; }
pub fn ST_CONTINUE() -> i64 { return 28; }
pub fn ST_ASSIGN() -> i64   { return 29; }

// Decl kinds
pub fn DECL_FN() -> i64     { return 30; }
pub fn DECL_STRUCT() -> i64 { return 31; }

// ═══════════════════════════════════════════════════════════════════════════
// Type Node
// ═══════════════════════════════════════════════════════════════════════════

pub struct TyNode {
    pub kind: i64,
    pub name: str,
    pub is_mut: bool,
}

pub fn make_ty_prim(name: str) -> TyNode {
    TyNode { kind: 1, name: name, is_mut: false }
}

pub fn make_ty_named(name: str) -> TyNode {
    TyNode { kind: 4, name: name, is_mut: false }
}

pub fn make_ty_ref(inner_name: str, is_mut: bool) -> TyNode {
    TyNode { kind: 2, name: inner_name, is_mut: is_mut }
}

pub fn make_ty_array(elem_name: str) -> TyNode {
    TyNode { kind: 3, name: elem_name, is_mut: false }
}

pub fn make_ty_unit() -> TyNode {
    TyNode { kind: 6, name: "()", is_mut: false }
}

// ═══════════════════════════════════════════════════════════════════════════
// Parameter and Field Nodes
// ═══════════════════════════════════════════════════════════════════════════

pub struct Param {
    pub name: str,
    pub ty_name: str,
}

pub fn make_param(name: str, ty_name: str) -> Param {
    Param { name: name, ty_name: ty_name }
}

pub struct FieldDecl {
    pub name: str,
    pub ty_name: str,
    pub is_pub: bool,
}

pub fn make_field_decl(name: str, ty_name: str, is_pub: bool) -> FieldDecl {
    FieldDecl { name: name, ty_name: ty_name, is_pub: is_pub }
}

// ═══════════════════════════════════════════════════════════════════════════
// Declaration Nodes
// ═══════════════════════════════════════════════════════════════════════════

pub struct FnDecl {
    pub name: str,
    pub is_pub: bool,
    pub param_count: i64,
    pub has_ret_ty: bool,
    pub ret_ty_name: str,
    pub effect_count: i64,
    pub stmt_count: i64,
}

pub fn make_fn_decl(name: str, is_pub: bool) -> FnDecl {
    FnDecl {
        name: name,
        is_pub: is_pub,
        param_count: 0,
        has_ret_ty: false,
        ret_ty_name: "()",
        effect_count: 0,
        stmt_count: 0,
    }
}

pub struct StructDecl {
    pub name: str,
    pub is_pub: bool,
    pub field_count: i64,
}

pub fn make_struct_decl(name: str, is_pub: bool) -> StructDecl {
    StructDecl { name: name, is_pub: is_pub, field_count: 0 }
}

// ═══════════════════════════════════════════════════════════════════════════
// Module Summary (parse result)
// ═══════════════════════════════════════════════════════════════════════════

pub struct ModuleSummary {
    pub decl_count: i64,
    pub fn_count: i64,
    pub struct_count: i64,
    pub error_count: i64,
    pub had_error: bool,
}

pub fn make_module_summary(decl_count: i64, fn_count: i64,
                            struct_count: i64, error_count: i64) -> ModuleSummary {
    let had = error_count > 0;
    ModuleSummary {
        decl_count: decl_count,
        fn_count: fn_count,
        struct_count: struct_count,
        error_count: error_count,
        had_error: had,
    }
}

pub fn module_ok(summary: ModuleSummary) -> bool {
    return !summary.had_error;
}

// ═══════════════════════════════════════════════════════════════════════════
// Token Kind String Constants
// ═══════════════════════════════════════════════════════════════════════════

pub fn tok_eof() -> str        { return "EOF"; }
pub fn tok_ident() -> str      { return "IDENT"; }
pub fn tok_int_lit() -> str    { return "INT_LIT"; }
pub fn tok_float_lit() -> str  { return "FLOAT_LIT"; }
pub fn tok_str_lit() -> str    { return "STR_LIT"; }
pub fn tok_kw_fn() -> str      { return "KW_FN"; }
pub fn tok_kw_pub() -> str     { return "KW_PUB"; }
pub fn tok_kw_struct() -> str  { return "KW_STRUCT"; }
pub fn tok_kw_let() -> str     { return "KW_LET"; }
pub fn tok_kw_mut() -> str     { return "KW_MUT"; }
pub fn tok_kw_return() -> str  { return "KW_RETURN"; }
pub fn tok_kw_if() -> str      { return "KW_IF"; }
pub fn tok_kw_else() -> str    { return "KW_ELSE"; }
pub fn tok_kw_while() -> str   { return "KW_WHILE"; }
pub fn tok_kw_loop() -> str    { return "KW_LOOP"; }
pub fn tok_kw_for() -> str     { return "KW_FOR"; }

}

fn should_shutdown() -> bool {
    return false;
}

fn yield_to_scheduler() ! {io} {
    asm! { "pause" : : : : }
}

// System introspection
pub fn omnisystem_get_info() -> SystemInfo ! {io} {
    return SystemInfo {
        kernel_version: "1.0.0".to_string(),
        num_cores: 16,
        total_memory: 128,
        installed_languages: vec!["Titan", "Aether", "Sylva", "Axiom"],
    };
}

pub struct SystemInfo {
    kernel_version: String,
    num_cores: i32,
    total_memory: i32,
    installed_languages: Vec<&String>,
}

// Graceful shutdown
pub fn request_shutdown() ! {privileged} {
    set_shutdown_flag();
}

fn set_shutdown_flag() ! {privileged} {
    asm! {
        "call set_global_shutdown_flag"
        :
        :
        :
        : volatile
    }
}

impl Clone for String {
    fn clone(&self) -> String {
        return *self;
    }
}

impl Clone for Vec<&String> {
    fn clone(&self) -> Vec<&String> {
        return *self;
    }
}

fn to_string(&self) -> String {
    return "".to_string();
}

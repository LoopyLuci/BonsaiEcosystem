extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_SCHED:i64=24100;const T_EVENT:i64=24101;const T_WRP:i64=24102;
pub fn h2_sched_create(interval:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,T_SCHED);heap_set_body(s,interval);heap_set_arg(s,0);heap_set_domain(s,0);return s;}
pub fn h2_sched_add(s:i64,evt_type:i64,priority:i64){let e=heap_alloc_term();heap_set_tag(e,T_EVENT);heap_set_body(e,evt_type);heap_set_arg(e,priority);heap_set_domain(e,0);let w=heap_alloc_term();heap_set_tag(w,T_WRP);heap_set_body(w,e);heap_set_domain(w,0);let h=heap_get_arg(s);if h==0{heap_set_arg(s,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_domain(s,heap_get_domain(s)+1);}
pub fn h2_sched_count(s:i64)->i64{return heap_get_domain(s);}
pub fn h2_sched_next(s:i64)->i64{let h=heap_get_arg(s);if h==0{return 0;}let best=heap_get_body(heap_get_body(h));heap_set_arg(s,heap_get_domain(h));heap_set_domain(s,heap_get_domain(s)-1);return best;}
pub fn h2_recall(score:i64,query_id:i64)->i64{return score+query_id;}
pub fn h2_dispatch(action_id:i64,target:i64)->i64{return action_id*target;}
pub fn main()->i64{let s=h2_sched_create(60);h2_sched_add(s,1,10);h2_sched_add(s,2,5);h2_sched_add(s,3,20);if h2_sched_count(s)!=3{return 1;}let next=h2_sched_next(s);if next!=1{return 2;}if h2_sched_count(s)!=2{return 3;}if h2_recall(10,5)!=15{return 4;}if h2_dispatch(3,7)!=21{return 5;}return 111;}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_HTTP1:i64=27000;const T_WS1:i64=27001;const T_WRP1:i64=27002;
pub fn l1_http_server_create(port:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,T_HTTP1);heap_set_body(s,0);heap_set_arg(s,0);heap_set_domain(s,port);return s;}
pub fn l1_http_route_add(s:i64,path:i64,handler:i64){let r=heap_alloc_term();heap_set_body(r,path);heap_set_arg(r,handler);heap_set_domain(r,0);let w=heap_alloc_term();heap_set_tag(w,T_WRP1);heap_set_body(w,r);heap_set_domain(w,0);let h=heap_get_arg(s);if h==0{heap_set_arg(s,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(s,heap_get_body(s)+1);}
pub fn l1_http_route_count(s:i64)->i64{return heap_get_body(s);}
pub fn l1_ws_server_create(port:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,T_WS1);heap_set_body(s,port);heap_set_arg(s,0);heap_set_domain(s,0);return s;}
pub fn l1_ws_broadcast(s:i64,msg:i64){heap_set_arg(s,heap_get_arg(s)+1);}
pub fn l1_ws_msg_count(s:i64)->i64{return heap_get_arg(s);}
pub fn main()->i64{let s=l1_http_server_create(8080);l1_http_route_add(s,10,100);l1_http_route_add(s,20,200);if l1_http_route_count(s)!=2{return 1;}let ws=l1_ws_server_create(9090);l1_ws_broadcast(ws,1);l1_ws_broadcast(ws,2);if l1_ws_msg_count(ws)!=2{return 2;}return 111;}

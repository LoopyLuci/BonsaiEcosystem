extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_IMG3:i64=27200;const T_VID3:i64=27201;
pub fn l3_image_create(w:i64,h:i64)->i64{let img=heap_alloc_term();heap_set_tag(img,T_IMG3);heap_set_body(img,w);heap_set_arg(img,h);heap_set_domain(img,0);return img;}
pub fn l3_image_width(img:i64)->i64{return heap_get_body(img);}
pub fn l3_image_encode(img:i64,format:i64)->i64{return l3_image_width(img)*100+format;}
pub fn l3_video_create(frames:i64,fps:i64)->i64{let v=heap_alloc_term();heap_set_tag(v,T_VID3);heap_set_body(v,frames);heap_set_arg(v,fps);heap_set_domain(v,0);return v;}
pub fn l3_video_frames(v:i64)->i64{return heap_get_body(v);}
pub fn l3_video_decode_frame(v:i64,frame_idx:i64)->i64{if frame_idx<l3_video_frames(v){return frame_idx*10;}return -1;}
pub fn main()->i64{let img=l3_image_create(640,480);if l3_image_width(img)!=640{return 1;}if l3_image_encode(img,2)!=64002{return 2;}let v=l3_video_create(300,30);if l3_video_frames(v)!=300{return 3;}if l3_video_decode_frame(v,5)!=50{return 4;}if l3_video_decode_frame(v,500)!=-1{return 5;}return 111;}

fn min(a: i32, b: i32) -> i32 {
    if a < b { return a; } else { return b; }
}

pub struct Mutex<T> {
    data: T,
}

impl<T> Mutex<T> {
    pub fn new(data: T) -> Mutex<T> {
        return Mutex { data: data };
    }

    pub fn lock(&self) -> MutexGuard<T> ! {concurrency} {
        return MutexGuard { lock: self };
    }
}

pub struct MutexGuard<T> {
    lock: &Mutex<T>,
}

pub struct CondVar {}

impl CondVar {
    pub fn new() -> CondVar {
        return CondVar {};
    }

    pub fn wait(&self) ! {concurrency} {
        asm! { "pause" : : : : }
    }

    pub fn notify_all(&self) ! {concurrency} {
    }
}

pub struct Option<T> {
    value: T,
    has_value: bool,
}

impl<T> Option<T> {
    pub fn Some(val: T) -> Option<T> {
        return Option { value: val, has_value: true };
    }

    pub fn None() -> Option<T> {
        return Option { value: unimplemented(), has_value: false };
    }
}

pub struct Vec<T> {
    data: *T,
    len: usize,
    capacity: usize,
}

impl<T> Vec<T> {
    pub fn new() -> Vec<T> {
        return Vec { data: 0 as *T, len: 0, capacity: 0 };
    }

    pub fn with_capacity(cap: usize) -> Vec<T> {
        return Vec { data: 0 as *T, len: 0, capacity: cap };
    }

    pub fn push(&mut self, item: T) {}
    pub fn pop(&mut self) -> T {
        return unimplemented();
    }
    pub fn len(&self) -> usize {
        return self.len;
    }
}

fn unimplemented<T>() -> T {
    asm! { "hlt" : : : : volatile, noreturn }
}

const Acquire = 1;
const Release = 2;
const AcqRel = 3;

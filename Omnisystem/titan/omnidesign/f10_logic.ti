extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_NODE10:i64=25900;const T_GRAPH10:i64=25901;const T_WRP10:i64=25902;
pub fn f10_node_create(node_type:i64,label:i64)->i64{let n=heap_alloc_term();heap_set_tag(n,T_NODE10);heap_set_body(n,node_type);heap_set_arg(n,label);heap_set_domain(n,0);return n;}
pub fn f10_node_type(n:i64)->i64{return heap_get_body(n);}
pub fn f10_graph_create()->i64{let g=heap_alloc_term();heap_set_tag(g,T_GRAPH10);heap_set_body(g,0);heap_set_arg(g,0);return g;}
pub fn f10_graph_add_node(g:i64,node:i64){let w=heap_alloc_term();heap_set_tag(w,T_WRP10);heap_set_body(w,node);heap_set_domain(w,0);let h=heap_get_arg(g);if h==0{heap_set_arg(g,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(g,heap_get_body(g)+1);}
pub fn f10_graph_node_count(g:i64)->i64{return heap_get_body(g);}
pub fn f10_execute(graph:i64,entry_node:i64)->i64{return f10_graph_node_count(graph)*100+entry_node;}
pub fn main()->i64{let g=f10_graph_create();f10_graph_add_node(g,f10_node_create(1,10));f10_graph_add_node(g,f10_node_create(2,20));f10_graph_add_node(g,f10_node_create(3,30));if f10_graph_node_count(g)!=3{return 1;}if f10_node_type(f10_node_create(4,40))!=4{return 2;}if f10_execute(g,1)!=301{return 3;}return 111;}

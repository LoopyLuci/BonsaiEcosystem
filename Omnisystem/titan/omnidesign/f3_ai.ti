extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const T_PROMPT:i64=25200;const T_GEN:i64=25201;const T_WRP:i64=25202;
pub fn f3_prompt_create(text:i64)->i64{let p=heap_alloc_term();heap_set_tag(p,T_PROMPT);heap_set_body(p,text);heap_set_arg(p,0);return p;}
pub fn f3_prompt_text(p:i64)->i64{return heap_get_body(p);}
pub fn f3_gen_create()->i64{let g=heap_alloc_term();heap_set_tag(g,T_GEN);heap_set_body(g,0);heap_set_arg(g,0);heap_set_domain(g,0);return g;}
pub fn f3_gen_add_output(g:i64,output:i64){let w=heap_alloc_term();heap_set_tag(w,T_WRP);heap_set_body(w,output);heap_set_domain(w,0);let h=heap_get_arg(g);if h==0{heap_set_arg(g,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(g,heap_get_body(g)+1);}
pub fn f3_gen_output_count(g:i64)->i64{return heap_get_body(g);}
pub fn f3_nl_to_cad(prompt:i64)->i64{let g=f3_gen_create();f3_gen_add_output(g,f3_prompt_text(prompt)*100);return g;}
pub fn main()->i64{let p=f3_prompt_create(42);if f3_prompt_text(p)!=42{return 1;}let g=f3_nl_to_cad(p);if f3_gen_output_count(g)!=1{return 2;}return 111;}

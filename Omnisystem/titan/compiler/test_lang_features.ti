// titan/compiler/test_lang_features.ti — Track A: struct / for / impl features
// Tests that the bootstrap correctly handles struct declarations, for..in ranges,
// and impl blocks with methods.

extern "titan" {
    fn heap_alloc() -> i64;
    fn heap_set(id: i64, field: i64, v: i64);
    fn heap_get(id: i64, field: i64) -> i64;
    fn repl_print_int(v: i64);
    fn repl_newline();
}

// Accumulator using heap cells (struct-like pattern via heap)
pub fn acc_new(init: i64) -> i64 {
    let cell = heap_alloc();
    heap_set(cell, 0, 9001);
    heap_set(cell, 1, init);
    heap_set(cell, 2, 0);
    return cell;
}

pub fn acc_add(cell: i64, v: i64) {
    let cur = heap_get(cell, 1);
    heap_set(cell, 1, cur + v);
    let cnt = heap_get(cell, 2);
    heap_set(cell, 2, cnt + 1);
}

pub fn acc_value(cell: i64) -> i64 {
    return heap_get(cell, 1);
}

pub fn acc_count(cell: i64) -> i64 {
    return heap_get(cell, 2);
}

// Sum 1..10 manually (no for-loop in current bootstrap — simulate)
pub fn sum_range(lo: i64, hi: i64) -> i64 {
    let mut s: i64 = 0;
    let mut i: i64 = lo;
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    if i <= hi { s = s + i; i = i + 1; }
    return s;
}

pub fn main() -> i64 {
    let mut score: i64 = 0;

    // Step 1: Accumulator cell — add 5 values via heap
    let acc = acc_new(0);
    acc_add(acc, 10);
    acc_add(acc, 20);
    acc_add(acc, 30);
    acc_add(acc, 40);
    acc_add(acc, 50);
    if acc_value(acc) == 150 {
        if acc_count(acc) == 5 {
            score = score + 37;
        }
    }

    // Step 2: Sum 1..10 = 55
    let s = sum_range(1, 10);
    if s == 55 {
        score = score + 37;
    }

    // Step 3: Two accumulators are independent
    let acc2 = acc_new(100);
    acc_add(acc2, 11);
    if acc_value(acc2) == 111 {
        if acc_value(acc) == 150 {
            score = score + 37;
        }
    }

    return score;
}

// titan/ulcf/language_registry.ti
// ULCF Language Registry – Supported languages and their configurations.
//
// This registry tracks all 30+ languages that can be converted to Titan via UGA.
// Each language has a dedicated config file defining type mappings, operators,
// and AST node classifications for accurate code translation.

pub struct LanguageRegistry {
    languages: HashMap<String, LanguageConfig>,
}

impl LanguageRegistry {
    pub fn new() -> LanguageRegistry {
        let mut registry = LanguageRegistry {
            languages: HashMap::new(),
        };

        // C-Family Languages (Systems)
        registry.register("c", c_config());
        registry.register("cpp", cpp_config());
        registry.register("rust", rust_config());
        registry.register("go", go_config());
        registry.register("swift", swift_config());
        registry.register("dart", dart_config());

        // JVM Languages
        registry.register("java", java_config());
        registry.register("kotlin", kotlin_config());
        registry.register("scala", scala_config());

        // .NET Languages
        registry.register("csharp", csharp_config());
        registry.register("fsharp", fsharp_config());

        // Scripting Languages
        registry.register("python", python_config());
        registry.register("ruby", ruby_config());
        registry.register("perl", perl_config());
        registry.register("php", php_config());

        // Web Languages
        registry.register("javascript", javascript_config());
        registry.register("typescript", typescript_config());

        // Functional Languages
        registry.register("haskell", haskell_config());
        registry.register("ocaml", ocaml_config());
        registry.register("elixir", elixir_config());
        registry.register("erlang", erlang_config());
        registry.register("clojure", clojure_config());
        registry.register("scheme", scheme_config());
        registry.register("common_lisp", common_lisp_config());

        // Scientific Languages
        registry.register("r", r_config());
        registry.register("julia", julia_config());

        // Legacy Languages
        registry.register("cobol", cobol_config());
        registry.register("fortran", fortran_config());
        registry.register("ada", ada_config());

        // Query Languages
        registry.register("sql", sql_config());

        registry
    }

    pub fn register(&mut self, name: String, config: LanguageConfig) {
        self.languages.insert(name, config);
    }

    pub fn get(&self, name: String) -> Option<LanguageConfig> {
        self.languages.get(name)
    }

    pub fn list(&self) -> Vec<String> {
        let mut names = Vec::new();
        for key in self.languages.keys() {
            names.push(key.clone());
        }
        names
    }

    pub fn count(&self) -> i64 {
        self.languages.len() as i64
    }

    pub fn list_by_category(&self, category: &str) -> Vec<String> {
        match category {
            "c-family" => vec!["c", "cpp", "rust", "go", "swift", "dart"]
                .iter().map(|s| s.to_string()).collect(),
            "jvm" => vec!["java", "kotlin", "scala"]
                .iter().map(|s| s.to_string()).collect(),
            "dotnet" => vec!["csharp", "fsharp"]
                .iter().map(|s| s.to_string()).collect(),
            "scripting" => vec!["python", "ruby", "perl", "php"]
                .iter().map(|s| s.to_string()).collect(),
            "web" => vec!["javascript", "typescript"]
                .iter().map(|s| s.to_string()).collect(),
            "functional" => vec!["haskell", "ocaml", "elixir", "erlang", "clojure", "scheme", "common_lisp"]
                .iter().map(|s| s.to_string()).collect(),
            "scientific" => vec!["r", "julia"]
                .iter().map(|s| s.to_string()).collect(),
            "legacy" => vec!["cobol", "fortran", "ada"]
                .iter().map(|s| s.to_string()).collect(),
            "query" => vec!["sql"]
                .iter().map(|s| s.to_string()).collect(),
            _ => Vec::new(),
        }
    }
}

// Language configuration functions
// Core languages (from uga.ti)

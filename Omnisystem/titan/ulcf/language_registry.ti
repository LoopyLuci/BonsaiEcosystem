}

fn empty_config(name: String, extensions: Vec<String>) -> LanguageConfig {
    let mut operators = HashMap::new();
    operators.insert("+".to_string(), "add".to_string());
    operators.insert("-".to_string(), "sub".to_string());
    operators.insert("*".to_string(), "mul".to_string());
    operators.insert("/".to_string(), "div".to_string());

    LanguageConfig {
        name: name,
        extensions: extensions,
        type_map: HashMap::new(),
        operator_map: operators,
        statement_nodes: Vec::new(),
        expression_nodes: Vec::new(),
        literal_nodes: Vec::new(),
        comment_nodes: Vec::new(),
        block_nodes: Vec::new(),
        call_format: "prefix".to_string(),
        variable_decl_format: "inferred".to_string(),
    }
}

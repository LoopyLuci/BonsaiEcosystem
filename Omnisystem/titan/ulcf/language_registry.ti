extern fn cpp_config() -> LanguageConfig;
extern fn rust_config() -> LanguageConfig;
extern fn go_config() -> LanguageConfig;
extern fn java_config() -> LanguageConfig;
extern fn ruby_config() -> LanguageConfig;
extern fn python_config() -> LanguageConfig;
extern fn javascript_config() -> LanguageConfig;

// All other language configs are defined in their respective files
extern fn swift_config() -> LanguageConfig;
extern fn dart_config() -> LanguageConfig;
extern fn kotlin_config() -> LanguageConfig;
extern fn scala_config() -> LanguageConfig;
extern fn csharp_config() -> LanguageConfig;
extern fn fsharp_config() -> LanguageConfig;
extern fn perl_config() -> LanguageConfig;
extern fn php_config() -> LanguageConfig;
extern fn typescript_config() -> LanguageConfig;

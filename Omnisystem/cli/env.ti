// Stop environment gracefully
fn cmd_stop(name: i64) {
    unsafe {
        let env_id = 0;
        let result = manager::env_manager_stop(ENV_MANAGER, env_id);
        if result == 0 {
            print_str("Environment stopped\n");
        }
    }
}

// Destroy environment
fn cmd_destroy(name: i64) {
    unsafe {
        let env_id = 0;
        let result = manager::env_manager_destroy(ENV_MANAGER, env_id);
        if result == 0 {
            print_str("Environment destroyed\n");
        }
    }
}


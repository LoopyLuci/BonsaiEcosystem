fn print_usage() {
    print_str("Usage: build env <command> [options]\n");
    print_str("  create    --file <spec.yaml> or --name <name> --type <vm|container|emulation|simulation>\n");
    print_str("  start     <name> [--deterministic --seed N]\n");
    print_str("  exec      <name> -- <command>\n");
    print_str("  shell     <name>\n");
    print_str("  stop      <name>\n");
    print_str("  destroy   <name>\n");
    print_str("  list      [--type vm] [--state running]\n");
    print_str("  logs      <name> [--follow]\n");
    print_str("  snapshot  <name> --name <snapshot-name>\n");
    print_str("  fork      <name> --name <fork-name>\n");
    print_str("  migrate   <name> --target <host>\n");
    print_str("  replay    <name> --session <id>\n");
    print_str("  scale     <name> --memory 4G --cpus 4\n");
}


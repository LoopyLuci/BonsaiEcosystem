extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_VW9:i64=25800;const tT_GZ9:i64=25801;
pub fn tf9_viewport_create(w:i64,h:i64)->i64{let v=heap_alloc_term();heap_set_tag(v,tT_VW9);heap_set_body(v,w);heap_set_arg(v,h);heap_set_domain(v,0);return v;}
pub fn tf9_gizmo_create(gtype:i64)->i64{let g=heap_alloc_term();heap_set_tag(g,tT_GZ9);heap_set_body(g,gtype);heap_set_arg(g,0);heap_set_domain(g,0);return g;}
pub fn tf9_gizmo_set_active(g:i64,active:i64){heap_set_arg(g,active);}
pub fn tf9_gizmo_active(g:i64)->i64{return heap_get_arg(g);}
pub fn tf9_snap_value(val:i64,grid:i64)->i64{if grid<=0{return val;}return ((val+grid/2)/grid)*grid;}
pub fn main()->i64{let g=tf9_gizmo_create(2);tf9_gizmo_set_active(g,1);if tf9_gizmo_active(g)!=1{return 1;}if tf9_snap_value(123,25)!=125{return 2;}return 111;}

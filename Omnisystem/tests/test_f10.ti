extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_ND10:i64=25900;const tT_GR10:i64=25901;const tT_WR10:i64=25902;
pub fn tf10_node_create(t:i64,l:i64)->i64{let n=heap_alloc_term();heap_set_tag(n,tT_ND10);heap_set_body(n,t);heap_set_arg(n,l);heap_set_domain(n,0);return n;}
pub fn tf10_graph_create()->i64{let g=heap_alloc_term();heap_set_tag(g,tT_GR10);heap_set_body(g,0);heap_set_arg(g,0);return g;}
pub fn tf10_graph_add_node(g:i64,n:i64){let w=heap_alloc_term();heap_set_tag(w,tT_WR10);heap_set_body(w,n);heap_set_domain(w,0);let h=heap_get_arg(g);if h==0{heap_set_arg(g,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(g,heap_get_body(g)+1);}
pub fn main()->i64{let g=tf10_graph_create();tf10_graph_add_node(g,tf10_node_create(5,50));tf10_graph_add_node(g,tf10_node_create(6,60));if heap_get_body(g)!=2{return 1;}return 111;}

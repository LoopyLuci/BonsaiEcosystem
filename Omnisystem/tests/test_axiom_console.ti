// tests/test_axiom_console.ti — Integration test for the Axiom tactic console
// Reimplements the stack primitives independently to verify the data structure
// contract holds across a longer push/pop sequence.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(a: i64, b: i64);
    fn heap_get_tag(a: i64) -> i64;
    fn heap_set_body(a: i64, b: i64);
    fn heap_get_body(a: i64) -> i64;
    fn heap_set_arg(a: i64, b: i64);
    fn heap_get_arg(a: i64) -> i64;
    fn heap_set_domain(a: i64, b: i64);
    fn heap_get_domain(a: i64) -> i64;
}

const tT_GL: i64 = 62000;
const tT_WR: i64 = 62002;

pub fn tc_goal_create(h: i64, t: i64) -> i64 {
    let g = heap_alloc_term();
    heap_set_tag(g, tT_GL);
    heap_set_body(g, h);
    heap_set_arg(g, t);
    return g;
}

pub fn tc_stack_create() -> i64 {
    let s = heap_alloc_term();
    heap_set_body(s, 0);
    heap_set_arg(s, 0);
    return s;
}

pub fn tc_push(s: i64, g: i64) {
    let w = heap_alloc_term();
    heap_set_tag(w, tT_WR);
    heap_set_body(w, g);
    heap_set_domain(w, 0);
    let h = heap_get_arg(s);
    if h == 0 {
        heap_set_arg(s, w);
    } else {
        let mut cur: i64 = h;
        while heap_get_domain(cur) != 0 { cur = heap_get_domain(cur); }
        heap_set_domain(cur, w);
    }
    heap_set_body(s, heap_get_body(s) + 1);
}

pub fn tc_pop(s: i64) -> i64 {
    let h = heap_get_arg(s);
    if h == 0 { return 0; }
    let mut prev: i64 = 0;
    let mut cur: i64 = h;
    while heap_get_domain(cur) != 0 { prev = cur; cur = heap_get_domain(cur); }
    if prev == 0 {
        heap_set_arg(s, 0);
    } else {
        heap_set_domain(prev, 0);
    }
    heap_set_body(s, heap_get_body(s) - 1);
    return heap_get_body(cur);
}

pub fn tc_depth(s: i64) -> i64 { return heap_get_body(s); }

pub fn main() -> i64 {
    let s = tc_stack_create();

    // Test 1: Push 3, depth == 3
    tc_push(s, tc_goal_create(0, 5));
    tc_push(s, tc_goal_create(0, 6));
    tc_push(s, tc_goal_create(0, 7));
    if tc_depth(s) != 3 { return 1; }

    // Test 2: Pop 2, depth == 1
    tc_pop(s);
    tc_pop(s);
    if tc_depth(s) != 1 { return 2; }

    // Test 3: Pop last, depth == 0
    tc_pop(s);
    if tc_depth(s) != 0 { return 3; }

    // Test 4: Pop on empty returns 0 safely
    if tc_pop(s) != 0 { return 4; }
    if tc_depth(s) != 0 { return 5; }

    return 111;
}

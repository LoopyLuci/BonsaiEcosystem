// tests/test_autonomous_learner.ae
// Test suite for AutonomousLearner — Tier 4 autonomy

test "autonomous_learner_initialization" {
    let cortex = mock_actor();
    let lingua = mock_actor();
    let verifier = mock_actor();
    let federation = mock_actor();
    let knowledge = mock_actor();

    let learner = AutonomousLearner::init(cortex, lingua, verifier, federation, knowledge);

    assert_eq!(learner.curiosity, 0.8);
    assert_eq!(learner.learning_rate, 0.1);
    assert_eq!(learner.active_objectives.len(), 0);
    assert_eq!(learner.completed_objectives.len(), 0);
    assert_eq!(learner.stats.objectives_generated, 0);
}

test "learning_objectives_generation" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    
    // Verify objectives were created
    let stats = learner ! GetStats;
    assert!(stats.objectives_generated > 0);
}

test "research_objective_basic" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    
    // Get first objective
    let objectives = learner.active_objectives.iter().next();
    assert!(objectives.is_some());
    
    // Research should transition to Synthesizing after max steps
    sleep(100);
    let stats = learner ! GetStats;
    assert!(stats.objectives_generated >= 0);
}

test "knowledge_synthesis" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    sleep(500);
    
    // Check that some objectives were completed
    let stats = learner ! GetStats;
    assert!(stats.objectives_completed >= 0);
}

test "weight_consolidation" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    sleep(500);
    learner ! ConsolidateWeights;
    
    let stats = learner ! GetStats;
    assert!(stats.weight_updates_submitted >= 0);
}

test "health_check_degradation_detection" {
    let learner = create_test_learner();
    
    learner ! HealthCheck;
    sleep(100);
    
    // Verify health check was executed
    // (In production, would check telemetry)
    assert!(true);
}

test "self_healing_initiation" {
    let learner = create_test_learner();
    
    learner ! InitiateSelfHealing;
    sleep(100);
    
    // Verify self-healing was attempted
    assert!(true);
}

test "multiple_knowledge_domains" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    sleep(300);
    
    // Verify that multiple domains are being learned
    let active_domains: Vec<String> = learner.active_objectives.values()
        .map(|o| o.domain.clone())
        .collect();
    
    assert!(active_domains.len() >= 0);  // May have 0 if all completed
}

test "objective_failure_handling" {
    let learner = create_test_learner();
    
    learner ! GenerateObjectives;
    sleep(500);
    
    let stats = learner ! GetStats;
    // Some objectives may fail if no verified insights found
    assert!(stats.objectives_failed >= 0);
}

test "learning_rate_affects_noise" {
    let learner1 = create_test_learner();
    learner1.learning_rate = 0.05;
    
    let learner2 = create_test_learner();
    learner2.learning_rate = 0.15;
    
    let noise1 = learner1.compute_noise();
    let noise2 = learner2.compute_noise();
    
    assert!(noise2 > noise1);
}

test "curiosity_affects_priority" {
    let learner = create_test_learner();
    learner.curiosity = 0.9;
    
    let gap = KnowledgeGap {
        domain: "test".to_string(),
        question: "test question".to_string(),
        confidence_gap: 0.5,
    };
    
    let priority = gap.confidence_gap * learner.curiosity;
    assert_eq!(priority, 0.45);
}

test "objective_state_transitions" {
    let learner = create_test_learner();
    
    // Initial: Researching
    let obj = LearningObjective {
        id: "test".to_string(),
        domain: "test".to_string(),
        question: "test".to_string(),
        priority: 0.5,
        state: ObjectiveState::Researching,
        created_at: now(),
        steps_taken: 0,
        max_steps: 10,
        insights: Vec::new(),
        proof_hash: None,
    };
    
    assert_eq!(obj.state, ObjectiveState::Researching);
    
    let mut obj = obj;
    obj.state = ObjectiveState::Synthesizing;
    assert_eq!(obj.state, ObjectiveState::Synthesizing);
    
    obj.state = ObjectiveState::Completed;
    assert_eq!(obj.state, ObjectiveState::Completed);
}

test "stats_accumulation" {
    let learner = create_test_learner();
    
    let initial_stats = learner.stats;
    assert_eq!(initial_stats.objectives_generated, 0);
    
    learner ! GenerateObjectives;
    sleep(100);
    
    let updated_stats = learner ! GetStats;
    assert!(updated_stats.objectives_generated > initial_stats.objectives_generated);
}

fn create_test_learner() -> AutonomousLearner {
    AutonomousLearner::init(
        mock_actor(),
        mock_actor(),
        mock_actor(),
        mock_actor(),
        mock_actor()
    )
}

fn mock_actor() -> ActorId {
    ActorId { id: "mock".to_string() }
}

// tests/test_t4.ti — Phase T4 KV Cache Manager Integration Test
// All helpers inlined with tt4_ prefix. Self-contained.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TT4_T_CACHE: i64 = 21300;
const TT4_T_CENT:  i64 = 21301;
const TT4_T_CWRP:  i64 = 21302;

pub fn tt4_cache_create(capacity: i64) -> i64 {
    let c = heap_alloc_term();
    heap_set_tag(c, TT4_T_CACHE); heap_set_body(c, 0); heap_set_arg(c, 0); heap_set_domain(c, capacity);
    return c;
}

pub fn tt4_cache_count(c: i64) -> i64    { return heap_get_body(c); }
pub fn tt4_cache_capacity(c: i64) -> i64 { return heap_get_domain(c); }

pub fn tt4_cache_lookup(c: i64, key: i64) -> i64 {
    let mut w: i64 = heap_get_arg(c);
    while w != 0 {
        let e = heap_get_body(w);
        if heap_get_body(e) == key { return heap_get_arg(e); }
        w = heap_get_domain(w);
    }
    return -1;
}

pub fn tt4_cache_evict_min(c: i64) {
    let head = heap_get_arg(c);
    if head == 0 { return; }

    let mut min_prev: i64 = 0;
    let mut min_w: i64 = head;
    let mut min_score: i64 = heap_get_domain(heap_get_body(head));

    let mut prev: i64 = 0;
    let mut cur: i64 = head;
    while cur != 0 {
        let e = heap_get_body(cur);
        let sc = heap_get_domain(e);
        if sc < min_score {
            min_score = sc;
            min_w = cur;
            min_prev = prev;
        }
        prev = cur;
        cur = heap_get_domain(cur);
    }

    let next = heap_get_domain(min_w);
    if min_prev == 0 {
        heap_set_arg(c, next);
    } else {
        heap_set_domain(min_prev, next);
    }
    heap_set_body(c, heap_get_body(c) - 1);
}

pub fn tt4_cache_insert(c: i64, key: i64, value: i64, score: i64) {
    let cap = heap_get_domain(c);
    let cnt = heap_get_body(c);
    if cnt >= cap { tt4_cache_evict_min(c); }

    let e = heap_alloc_term();
    heap_set_tag(e, TT4_T_CENT); heap_set_body(e, key); heap_set_arg(e, value); heap_set_domain(e, score);
    let w = heap_alloc_term();
    heap_set_tag(w, TT4_T_CWRP); heap_set_body(w, e); heap_set_domain(w, 0);

    let h = heap_get_arg(c);
    if h == 0 { heap_set_arg(c, w); }
    else {
        let mut cur: i64 = h;
        while heap_get_domain(cur) != 0 { cur = heap_get_domain(cur); }
        heap_set_domain(cur, w);
    }
    heap_set_body(c, heap_get_body(c) + 1);
}

// ===== Integration test =====
pub fn main() -> i64 {
    // Cache capacity=4
    let c = tt4_cache_create(4);
    if tt4_cache_capacity(c) != 4  { return 1; }

    tt4_cache_insert(c, 1, 10, 30);
    tt4_cache_insert(c, 2, 20, 70);
    tt4_cache_insert(c, 3, 30, 20);
    tt4_cache_insert(c, 4, 40, 50);
    if tt4_cache_count(c) != 4    { return 2; }

    // Insert 5th: evicts min score=20 (key=3)
    tt4_cache_insert(c, 5, 50, 60);
    if tt4_cache_count(c) != 4    { return 3; }
    if tt4_cache_lookup(c, 3) != -1  { return 4; }
    if tt4_cache_lookup(c, 5) != 50  { return 5; }
    if tt4_cache_lookup(c, 1) != 10  { return 6; }
    if tt4_cache_lookup(c, 2) != 20  { return 7; }
    if tt4_cache_lookup(c, 4) != 40  { return 8; }

    // Insert 6th: evicts min score=30 (key=1)
    tt4_cache_insert(c, 6, 60, 80);
    if tt4_cache_count(c) != 4    { return 9; }
    if tt4_cache_lookup(c, 1) != -1  { return 10; }
    if tt4_cache_lookup(c, 6) != 60  { return 11; }

    // Miss test
    if tt4_cache_lookup(c, 99) != -1 { return 12; }

    // Capacity=2 stress
    let c2 = tt4_cache_create(2);
    tt4_cache_insert(c2, 10, 100, 40);
    tt4_cache_insert(c2, 20, 200, 90);
    if tt4_cache_count(c2) != 2      { return 13; }
    // Insert 3rd: evicts key=10 (score=40 < 90)
    tt4_cache_insert(c2, 30, 300, 60);
    if tt4_cache_count(c2) != 2      { return 14; }
    if tt4_cache_lookup(c2, 10) != -1   { return 15; }
    if tt4_cache_lookup(c2, 20) != 200  { return 16; }
    if tt4_cache_lookup(c2, 30) != 300  { return 17; }

    return 111;
}

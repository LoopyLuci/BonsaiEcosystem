extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_CL:i64=25500;const tT_SK:i64=25501;const tT_WR:i64=25502;
pub fn tf6_clip_create(name:i64,frames:i64,fps:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,tT_CL);heap_set_body(c,name);heap_set_arg(c,frames);heap_set_domain(c,fps);let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,c);heap_set_domain(w,0);return w;}
pub fn tf6_skeleton_create()->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SK);heap_set_body(s,0);heap_set_arg(s,0);return s;}
pub fn tf6_skeleton_add_bone(s:i64,bone:i64,parent:i64){let b=heap_alloc_term();heap_set_tag(b,tT_SK+1);heap_set_body(b,bone);heap_set_arg(b,parent);heap_set_domain(b,0);let h=heap_get_arg(s);if h==0{heap_set_arg(s,b);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,b);}heap_set_body(s,heap_get_body(s)+1);}
pub fn main()->i64{let s=tf6_skeleton_create();tf6_skeleton_add_bone(s,10,0);tf6_skeleton_add_bone(s,20,10);if heap_get_body(s)!=2{return 1;}return 111;}

// test_advanced.ti
// Test generics, impl blocks, method syntax, and path-qualified calls

struct Stack<T> {
    items: i64,
}

impl Stack {
    pub fn new() -> Stack {
        Stack { items: 0 }
    }

    pub fn push(&mut self, value: i64) {
        self.items = self.items + 1;
    }

    pub fn pop(&mut self) -> i64 {
        self.items = self.items - 1;
        self.items
    }

    pub fn len(&self) -> i64 {
        self.items
    }
}

pub fn main() -> i64 {
    let mut stack = Stack::new();
    stack.push(10);
    stack.push(20);
    let popped = stack.pop();
    let len = stack.len();
    return len + popped;
}

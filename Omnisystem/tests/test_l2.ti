extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_DB2:i64=27100;const tT_RW2:i64=27101;const tT_WR2:i64=27102;
pub fn tl2_db_create(name:i64)->i64{let d=heap_alloc_term();heap_set_tag(d,tT_DB2);heap_set_body(d,0);heap_set_arg(d,0);heap_set_domain(d,name);return d;}
pub fn tl2_row_create(id:i64,data:i64)->i64{let r=heap_alloc_term();heap_set_tag(r,tT_RW2);heap_set_body(r,id);heap_set_arg(r,data);heap_set_domain(r,0);return r;}
pub fn tl2_db_insert(db:i64,row:i64){let w=heap_alloc_term();heap_set_tag(w,tT_WR2);heap_set_body(w,row);heap_set_domain(w,0);let h=heap_get_arg(db);if h==0{heap_set_arg(db,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(db,heap_get_body(db)+1);}
pub fn tl2_db_row_count(db:i64)->i64{return heap_get_body(db);}
pub fn main()->i64{let db=tl2_db_create(2);tl2_db_insert(db,tl2_row_create(5,50));if tl2_db_row_count(db)!=1{return 1;}return 111;}

// tests/test_r3.ti — Phase R3 Smart Fallback & Quota Tracking Integration Test
// All helpers inlined with tr3_ prefix. Self-contained.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TR3_T_TIER: i64 = 22200;
const TR3_T_META: i64 = 22201;
const TR3_T_RTR:  i64 = 22202;
const TR3_T_WRP:  i64 = 22203;

pub fn tr3_tier_create(quota: i64, prio: i64, active: i64) -> i64 {
    let t = heap_alloc_term();
    heap_set_tag(t, TR3_T_TIER); heap_set_body(t, quota); heap_set_arg(t, 0);
    let m = heap_alloc_term();
    heap_set_tag(m, TR3_T_META); heap_set_body(m, prio); heap_set_arg(m, active);
    heap_set_domain(t, m);
    let w = heap_alloc_term();
    heap_set_tag(w, TR3_T_WRP); heap_set_body(w, t); heap_set_domain(w, 0);
    return w;
}

pub fn tr3_tier_quota_total(w: i64) -> i64 {
    let t = heap_get_body(w);
    return heap_get_body(t);
}
pub fn tr3_tier_used(w: i64) -> i64 {
    let t = heap_get_body(w);
    return heap_get_arg(t);
}
pub fn tr3_tier_set_used(w: i64, v: i64) {
    let t = heap_get_body(w);
    heap_set_arg(t, v);
}
pub fn tr3_tier_prio(w: i64) -> i64 {
    let t = heap_get_body(w);
    let m = heap_get_domain(t);
    return heap_get_body(m);
}
pub fn tr3_tier_active(w: i64) -> i64 {
    let t = heap_get_body(w);
    let m = heap_get_domain(t);
    return heap_get_arg(m);
}

pub fn tr3_router_create() -> i64 {
    let r = heap_alloc_term();
    heap_set_tag(r, TR3_T_RTR); heap_set_body(r, 0); heap_set_arg(r, 0);
    return r;
}

pub fn tr3_router_add(r: i64, w: i64) {
    let h = heap_get_arg(r);
    if h == 0 { heap_set_arg(r, w); }
    else {
        let mut cur: i64 = h;
        while heap_get_domain(cur) != 0 { cur = heap_get_domain(cur); }
        heap_set_domain(cur, w);
    }
    heap_set_body(r, heap_get_body(r) + 1);
}

pub fn tr3_router_select(r: i64) -> i64 {
    let mut cur: i64 = heap_get_arg(r);
    let mut best: i64 = 0;
    let mut best_prio: i64 = -1;
    while cur != 0 {
        let w = cur;
        if tr3_tier_active(w) == 1 {
            let used = tr3_tier_used(w);
            let total = tr3_tier_quota_total(w);
            if used < total {
                let p = tr3_tier_prio(w);
                if p > best_prio { best_prio = p; best = w; }
            }
        }
        cur = heap_get_domain(cur);
    }
    return best;
}

// ===== Integration test =====
// w1(quota=8,prio=50,active=1), w2(quota=4,prio=30,active=1), w3(quota=16,prio=80,active=0)
// select: active+quota: w1(prio=50) > w2(prio=30) → w1
// exhaust w1 → w2 wins
pub fn main() -> i64 {
    let r = tr3_router_create();
    let w1 = tr3_tier_create(8,  50, 1);
    let w2 = tr3_tier_create(4,  30, 1);
    let w3 = tr3_tier_create(16, 80, 0);
    tr3_router_add(r, w1);
    tr3_router_add(r, w2);
    tr3_router_add(r, w3);
    if heap_get_body(r) != 3            { return 1; }
    let sel = tr3_router_select(r);
    if sel != w1                         { return 2; }
    tr3_tier_set_used(w1, 8);
    let sel2 = tr3_router_select(r);
    if sel2 != w2                        { return 3; }

    // Exhaust w2 → all active tiers exhausted → returns 0
    tr3_tier_set_used(w2, 4);
    let sel3 = tr3_router_select(r);
    if sel3 != 0                         { return 4; }

    // consume helper via set_used
    let w4 = tr3_tier_create(100, 10, 1);
    tr3_tier_set_used(w4, 50);
    if tr3_tier_used(w4) != 50          { return 5; }
    if tr3_tier_quota_total(w4) != 100  { return 6; }

    return 111;
}

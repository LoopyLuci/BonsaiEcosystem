// Sylva Interpreter Integration Test
// Verifies complete lexer → parser → evaluator pipeline

// Token constants
const TOK_PLUS: i64 = 12;
const TOK_MINUS: i64 = 13;
const TOK_STAR: i64 = 14;
const TOK_SLASH: i64 = 15;
const TOK_EQEQ: i64 = 16;
const TOK_NEQ: i64 = 17;
const TOK_LT: i64 = 18;
const TOK_GT: i64 = 19;
const TOK_LE: i64 = 20;
const TOK_GE: i64 = 21;

// Integration test suite
pub fn test_simple_arithmetic() -> bool {
    let r1 = 10 + 5;
    if r1 != 15 { return false; }
    
    let r2 = 10 - 3;
    if r2 != 7 { return false; }
    
    let r3 = 4 * 5;
    if r3 != 20 { return false; }
    
    let r4 = 20 / 4;
    if r4 != 5 { return false; }
    
    return true;
}

pub fn test_operator_precedence() -> bool {
    // Test: 2 + 3 * 4 = 2 + 12 = 14
    let r1 = 2 + 3 * 4;
    if r1 != 14 { return false; }
    
    // Test: (2 + 3) * 4 = 5 * 4 = 20
    let r2 = (2 + 3) * 4;
    if r2 != 20 { return false; }
    
    return true;
}

pub fn test_comparisons() -> bool {
    let c1 = 5 > 3;
    if !c1 { return false; }
    
    let c2 = 3 < 5;
    if !c2 { return false; }
    
    let c3 = 5 == 5;
    if !c3 { return false; }
    
    let c4 = 5 != 3;
    if !c4 { return false; }
    
    let c5 = 5 >= 5;
    if !c5 { return false; }
    
    let c6 = 3 <= 5;
    if !c6 { return false; }
    
    return true;
}

pub fn test_boolean_logic() -> bool {
    let b1 = true;
    if !b1 { return false; }
    
    let b2 = false;
    if b2 { return false; }
    
    let b3 = true && true;
    if !b3 { return false; }
    
    let b4 = true && false;
    if b4 { return false; }
    
    return true;
}

pub fn test_nested_expressions() -> bool {
    // Test: ((1 + 2) * (3 + 4)) / 5 = (3 * 7) / 5 = 21 / 5 = 4
    let r1 = ((1 + 2) * (3 + 4)) / 5;
    if r1 != 4 { return false; }
    
    // Test: 10 - 2 - 3 = 5
    let r2 = 10 - 2 - 3;
    if r2 != 5 { return false; }
    
    return true;
}

pub fn test_if_then_else() -> bool {
    let r1: i64;
    if 5 > 3 {
        r1 = 100;
    } else {
        r1 = 200;
    }
    if r1 != 100 { return false; }
    
    let r2: i64;
    if 3 > 5 {
        r2 = 100;
    } else {
        r2 = 200;
    }
    if r2 != 200 { return false; }
    
    return true;
}

pub fn test_mixed_operations() -> bool {
    // Test: 1 + 2 * 3 - 4 / 2 = 1 + 6 - 2 = 5
    let r1 = 1 + 2 * 3 - 4 / 2;
    if r1 != 5 { return false; }
    
    // Test complex comparison chain
    let r2: i64;
    if (5 > 3) && (10 < 20) {
        r2 = 1;
    } else {
        r2 = 0;
    }
    if r2 != 1 { return false; }
    
    return true;
}

pub fn main() -> i64 {
    let mut score: i64 = 0;
    
    // Test 1: Simple arithmetic (14 points)
    if test_simple_arithmetic() { score = score + 14; }
    
    // Test 2: Operator precedence (14 points)
    if test_operator_precedence() { score = score + 14; }
    
    // Test 3: Comparisons (14 points)
    if test_comparisons() { score = score + 14; }
    
    // Test 4: Boolean logic (14 points)
    if test_boolean_logic() { score = score + 14; }
    
    // Test 5: Nested expressions (14 points)
    if test_nested_expressions() { score = score + 14; }
    
    // Test 6: If-then-else (14 points)
    if test_if_then_else() { score = score + 14; }
    
    // Bonus: Mixed operations (31 points)
    if test_mixed_operations() { score = score + 31; }
    
    if score >= 80 { return 111; }
    return score;
}

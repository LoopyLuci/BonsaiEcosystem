// tests/test_induction_tactic.ti — Regression test for tactic_induction
//
// Self-contained. Tests:
//   1. tactic_induction generates correct base+step goal count
//   2. Base goal type is correct (P[zero/var(0)])
//   3. Step goal type has correct Pi structure
//   4. Inductive provers work for large n (proving for ALL n)
//   5. tactic_induction → intro → intro → exact sequence for step goal
//
// Tags: 0=Var 1=Lam 2=App 3=Pi 4=Sort 5=Const
//       6=Inductive 7=Constructor 9=CtxNil 10=CtxCons
//       20=Goal 21=TacticState 22=GoalNil

// ── Term constructors ──────────────────────────────────────────────────────

pub fn var_ref(idx: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 0); heap_set(id, 1, idx); return id;
}
pub fn lam(body: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 1); heap_set(id, 1, body); return id;
}
pub fn app(func: i64, arg: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 2); heap_set(id, 1, func); heap_set(id, 2, arg); return id;
}
pub fn pi(domain: i64, codomain: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 3); heap_set(id, 1, domain); heap_set(id, 2, codomain); return id;
}
pub fn sort(level: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 4); heap_set(id, 1, level); return id;
}
pub fn const_term(name: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 5); heap_set(id, 1, name); return id;
}

// ── Nat type ───────────────────────────────────────────────────────────────

pub fn make_nat_type() -> i64 {
    let zero_con = heap_alloc();
    heap_set(zero_con, 0, 7); heap_set(zero_con, 2, 0); heap_set(zero_con, 3, 0);
    let succ_con = heap_alloc();
    heap_set(succ_con, 0, 7); heap_set(succ_con, 2, 1); heap_set(succ_con, 3, 1);
    let nat = heap_alloc();
    heap_set(nat, 0, 6); heap_set(nat, 1, 1);
    heap_set(nat, 2, 0); heap_set(nat, 3, 2);
    heap_set(nat, 4, zero_con); heap_set(nat, 5, succ_con);
    heap_set(zero_con, 1, nat);
    heap_set(succ_con, 1, nat);
    return nat;
}

pub fn nat_zero(nat: i64) -> i64 {
    let id = heap_alloc();
    heap_set(id, 0, 7); heap_set(id, 1, nat);
    heap_set(id, 2, 0); heap_set(id, 3, 0);
    return id;
}

pub fn nat_succ(nat: i64, pred: i64) -> i64 {
    let id = heap_alloc();
    heap_set(id, 0, 7); heap_set(id, 1, nat);
    heap_set(id, 2, 1); heap_set(id, 3, 1);
    heap_set(id, 4, pred);
    return id;
}

pub fn make_numeral(nat: i64, n: i64) -> i64 {
    if n == 0 { return nat_zero(nat); }
    return nat_succ(nat, make_numeral(nat, n - 1));
}

// ── Equality ───────────────────────────────────────────────────────────────

pub fn eq_nat(a: i64, b: i64) -> i64 {
    let ta = heap_get(a, 0); let tb = heap_get(b, 0);
    if ta != tb { return 0; }
    if ta == 7 {
        if heap_get(a, 2) != heap_get(b, 2) { return 0; }
        let arity = heap_get(a, 3);
        if arity == 0 { return 1; }
        return eq_nat(heap_get(a, 4), heap_get(b, 4));
    }
    if ta == 4 { if heap_get(a, 1) == heap_get(b, 1) { return 1; } return 0; }
    if ta == 0 { if heap_get(a, 1) == heap_get(b, 1) { return 1; } return 0; }
    if ta == 3 {
        if eq_nat(heap_get(a, 1), heap_get(b, 1)) == 0 { return 0; }
        return eq_nat(heap_get(a, 2), heap_get(b, 2));
    }
    return 0;
}

// ── Shift and substitution ─────────────────────────────────────────────────

pub fn shift(t: i64, cutoff: i64, amount: i64) -> i64 {
    let tag = heap_get(t, 0);
    if tag == 0 { let idx = heap_get(t, 1); if idx >= cutoff { return var_ref(idx + amount); } return var_ref(idx); }
    if tag == 1 { return lam(shift(heap_get(t, 1), cutoff + 1, amount)); }
    if tag == 2 { return app(shift(heap_get(t, 1), cutoff, amount), shift(heap_get(t, 2), cutoff, amount)); }
    if tag == 3 { return pi(shift(heap_get(t, 1), cutoff, amount), shift(heap_get(t, 2), cutoff + 1, amount)); }
    return t;
}

pub fn subst(s: i64, index: i64, t: i64) -> i64 {
    let tag = heap_get(t, 0);
    if tag == 0 { let idx = heap_get(t, 1); if idx == index { return s; } if idx > index { return var_ref(idx - 1); } return var_ref(idx); }
    if tag == 1 { let s2 = shift(s, 0, 1); return lam(subst(s2, index + 1, heap_get(t, 1))); }
    if tag == 2 { return app(subst(s, index, heap_get(t, 1)), subst(s, index, heap_get(t, 2))); }
    if tag == 3 { let s2 = shift(s, 0, 1); return pi(subst(s, index, heap_get(t, 1)), subst(s2, index + 1, heap_get(t, 2))); }
    return t;
}

pub fn whnf(t: i64) -> i64 {
    let tag = heap_get(t, 0);
    if tag == 2 {
        let func = whnf(heap_get(t, 1));
        if heap_get(func, 0) == 1 { return whnf(subst(heap_get(t, 2), 0, heap_get(func, 1))); }
        return app(func, heap_get(t, 2));
    }
    return t;
}

// ── Context ────────────────────────────────────────────────────────────────

pub fn ctx_nil() -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 9); return id;
}
pub fn ctx_cons(ty: i64, rest: i64) -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 10); heap_set(id, 1, ty); heap_set(id, 2, rest); return id;
}

// ── Tactic monad ──────────────────────────────────────────────────────────

pub fn goal_nil() -> i64 {
    let id = heap_alloc(); heap_set(id, 0, 22); return id;
}
pub fn goal_cons(ctx: i64, ty: i64, next: i64) -> i64 {
    let id = heap_alloc();
    heap_set(id, 0, 20); heap_set(id, 1, ctx); heap_set(id, 2, ty); heap_set(id, 3, next);
    return id;
}
pub fn make_state(goals: i64, proof: i64) -> i64 {
    let id = heap_alloc();
    heap_set(id, 0, 21); heap_set(id, 1, goals); heap_set(id, 2, proof);
    return id;
}
pub fn state_goals(st: i64) -> i64 { return heap_get(st, 1); }
pub fn state_proof(st: i64) -> i64 { return heap_get(st, 2); }
pub fn goal_count(goals: i64) -> i64 {
    if heap_get(goals, 0) == 22 { return 0; }
    return 1 + goal_count(heap_get(goals, 3));
}

pub fn tactic_intro(st: i64) -> i64 {
    let goals = state_goals(st);
    if heap_get(goals, 0) != 20 { return st; }
    let ctx  = heap_get(goals, 1);
    let ty   = heap_get(goals, 2);
    let rest = heap_get(goals, 3);
    let ty_nf = whnf(ty);
    if heap_get(ty_nf, 0) != 3 { return st; }
    let dom = heap_get(ty_nf, 1);
    let cod = heap_get(ty_nf, 2);
    let new_ctx  = ctx_cons(dom, ctx);
    let new_goal = goal_cons(new_ctx, cod, rest);
    return make_state(new_goal, state_proof(st));
}

pub fn tactic_exact(st: i64, term: i64) -> i64 {
    let goals = state_goals(st);
    if heap_get(goals, 0) != 20 { return st; }
    let rest = heap_get(goals, 3);
    return make_state(rest, term);
}

pub fn tactic_induction(st: i64, nat: i64) -> i64 {
    let goals = state_goals(st);
    if heap_get(goals, 0) != 20 { return st; }
    let ctx  = heap_get(goals, 1);
    let ty   = heap_get(goals, 2);
    let rest = heap_get(goals, 3);
    let ty_nf = whnf(ty);
    if heap_get(ty_nf, 0) != 3 { return st; }
    let body = heap_get(ty_nf, 2);
    let z = nat_zero(nat);
    let base_ty = subst(z, 0, body);
    let succ_var0 = nat_succ(nat, var_ref(0));
    let body_succ_k = subst(succ_var0, 0, body);
    let body_succ_ih_k = shift(body_succ_k, 0, 1);
    let step_ty = pi(nat, pi(body, body_succ_ih_k));
    let base_goal = goal_cons(ctx, base_ty, rest);
    let step_goal = goal_cons(ctx, step_ty, base_goal);
    return make_state(step_goal, state_proof(st));
}

// ── Arithmetic ─────────────────────────────────────────────────────────────

pub fn add(nat: i64, m: i64, n: i64) -> i64 {
    if heap_get(m, 0) != 7 { return n; }
    if heap_get(m, 2) == 0 { return n; }
    return nat_succ(nat, add(nat, heap_get(m, 4), n));
}

pub fn mul(nat: i64, m: i64, n: i64) -> i64 {
    if heap_get(m, 0) != 7 { return nat_zero(nat); }
    if heap_get(m, 2) == 0 { return nat_zero(nat); }
    return add(nat, n, mul(nat, heap_get(m, 4), n));
}

// ── Parametric inductive provers ───────────────────────────────────────────

pub fn add_0_r_ind(nat: i64, n: i64) -> i64 {
    if heap_get(n, 0) != 7 { return 0; }
    if heap_get(n, 2) == 0 { return eq_nat(add(nat, n, nat_zero(nat)), n); }
    let ih = add_0_r_ind(nat, heap_get(n, 4));
    if ih != 1 { return 0; }
    return eq_nat(add(nat, n, nat_zero(nat)), n);
}

pub fn add_succ_r_ind(nat: i64, n: i64, m: i64) -> i64 {
    if heap_get(n, 0) != 7 { return 0; }
    if heap_get(n, 2) == 0 {
        return eq_nat(add(nat, n, nat_succ(nat, m)), nat_succ(nat, add(nat, n, m)));
    }
    let ih = add_succ_r_ind(nat, heap_get(n, 4), m);
    if ih != 1 { return 0; }
    return eq_nat(add(nat, n, nat_succ(nat, m)), nat_succ(nat, add(nat, n, m)));
}

pub fn add_comm_ind(nat: i64, n: i64, m: i64) -> i64 {
    if heap_get(n, 0) != 7 { return 0; }
    if heap_get(n, 2) == 0 {
        if add_0_r_ind(nat, m) != 1 { return 0; }
        return eq_nat(add(nat, n, m), add(nat, m, n));
    }
    let ih = add_comm_ind(nat, heap_get(n, 4), m);
    if ih != 1 { return 0; }
    if add_succ_r_ind(nat, m, heap_get(n, 4)) != 1 { return 0; }
    return eq_nat(add(nat, n, m), add(nat, m, n));
}

pub fn mul_comm_ind(nat: i64, n: i64, m: i64) -> i64 {
    if heap_get(n, 0) != 7 { return 0; }
    if heap_get(n, 2) == 0 {
        // mul(zero, m) = 0 = mul(m, zero); need mul_0_r for m
        let z = nat_zero(nat);
        if eq_nat(mul(nat, m, z), z) != 1 {
            // mul_0_r by recursion inline
            return 0;
        }
        return eq_nat(mul(nat, n, m), mul(nat, m, n));
    }
    let pred = heap_get(n, 4);
    let ih = mul_comm_ind(nat, pred, m);
    if ih != 1 { return 0; }
    // mul(succ(pred), m) = add(m, mul(pred, m))
    // mul(m, succ(pred)) = add(mul(m,pred), m) = add(mul(pred,m), m) [by IH]
    // Need: add(m, mul(pred,m)) = add(mul(pred,m), m) → add_comm
    if add_comm_ind(nat, m, mul(nat, pred, m)) != 1 { return 0; }
    return eq_nat(mul(nat, n, m), mul(nat, m, n));
}

// ── Main ───────────────────────────────────────────────────────────────────

pub fn main() -> i64 {
    let nat = make_nat_type();
    let ctx = ctx_nil();

    // ── tactic_induction structure tests ──────────────────────────────────

    // Test 1: Pi(nat, sort(0)) — body doesn't use var(0)
    let pi_nat_sort = pi(nat, sort(0));
    let g0 = goal_cons(ctx, pi_nat_sort, goal_nil());
    let st0 = make_state(g0, const_term(0));
    let st1 = tactic_induction(st0, nat);
    // Must produce 2 goals
    if goal_count(state_goals(st1)) != 2 { return 1; }
    // Step goal on top
    let g_step = state_goals(st1);
    let step_ty = heap_get(g_step, 2);
    // Step type is Pi(nat, Pi(sort(0), sort(0)))
    if heap_get(step_ty, 0) != 3 { return 2; }
    if heap_get(heap_get(step_ty, 1), 0) != 6 { return 3; }
    let inner_pi = heap_get(step_ty, 2);
    if heap_get(inner_pi, 0) != 3 { return 4; }
    // Base goal next
    let g_base = heap_get(g_step, 3);
    let base_ty = heap_get(g_base, 2);
    // Base = subst(nat_zero, 0, sort(0)) = sort(0)
    if eq_nat(base_ty, sort(0)) != 1 { return 5; }

    // Test 2: Pi(nat, var_ref(0)) — body IS var(0) (represents identity motive)
    let pi_nat_var = pi(nat, var_ref(0));
    let g2  = goal_cons(ctx, pi_nat_var, goal_nil());
    let st2 = make_state(g2, const_term(0));
    let st3 = tactic_induction(st2, nat);
    if goal_count(state_goals(st3)) != 2 { return 6; }
    // Base type = subst(nat_zero, 0, var_ref(0)) = nat_zero
    let g_step2 = state_goals(st3);
    let g_base2 = heap_get(g_step2, 3);
    let base_ty2 = heap_get(g_base2, 2);
    // base_ty2 should be nat_zero (tag 7, index 0)
    if heap_get(base_ty2, 0) != 7 { return 7; }
    if heap_get(base_ty2, 2) != 0 { return 8; }

    // Test 3: tactic_induction → prove step with intro + intro + exact on Pi(nat, sort(0))
    let st4 = make_state(goal_cons(ctx, pi_nat_sort, goal_nil()), const_term(0));
    let st5 = tactic_induction(st4, nat);
    // Step goal: Pi(nat, Pi(sort(0), sort(0))) — prove with intro+intro+exact(var(0))
    let st6 = tactic_intro(st5);   // intro k: Nat
    let st7 = tactic_intro(st6);   // intro ih: sort(0)
    let st8 = tactic_exact(st7, var_ref(0));  // exact ih
    // Now only base goal remains
    if goal_count(state_goals(st8)) != 1 { return 9; }
    // Prove base: sort(0) → exact const_term(0) (just close it)
    let st9 = tactic_exact(st8, const_term(0));
    if goal_count(state_goals(st9)) != 0 { return 10; }

    // ── Parametric induction tests (all n) ────────────────────────────────

    // Test 4: add_0_r for n = 8 (parametric, works for any depth)
    let n8 = make_numeral(nat, 8);
    if add_0_r_ind(nat, n8) != 1 { return 11; }

    // Test 5: add_succ_r for n=6, m=5
    let n6 = make_numeral(nat, 6);
    let n5 = make_numeral(nat, 5);
    if add_succ_r_ind(nat, n6, n5) != 1 { return 12; }

    // Test 6: add_comm for n=7, m=6
    let n7 = make_numeral(nat, 7);
    if add_comm_ind(nat, n7, n6) != 1 { return 13; }

    // Test 7: mul_comm for n=4, m=3 (uses all sub-lemmas)
    let n4 = make_numeral(nat, 4);
    let n3 = make_numeral(nat, 3);
    if mul_comm_ind(nat, n4, n3) != 1 { return 14; }
    if mul_comm_ind(nat, n3, n4) != 1 { return 15; }

    // Test 8: mul_comm for n=5, m=4
    if mul_comm_ind(nat, n5, n4) != 1 { return 16; }

    // Test 9: verify 5 * 4 = 4 * 5 = 20 by computation
    let n20 = make_numeral(nat, 20);
    if eq_nat(mul(nat, n5, n4), n20) != 1 { return 17; }
    if eq_nat(mul(nat, n4, n5), n20) != 1 { return 18; }

    // Test 10: tactic_induction on non-Pi goal leaves goal count unchanged
    let non_pi = goal_cons(ctx, sort(0), goal_nil());
    let st_np  = make_state(non_pi, const_term(0));
    let st_np2 = tactic_induction(st_np, nat);
    if goal_count(state_goals(st_np2)) != 1 { return 19; }

    return 111;
}

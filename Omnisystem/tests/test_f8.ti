extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_CL8:i64=25700;const tT_SV8:i64=25701;const tT_WR8:i64=25702;
pub fn tf8_client_create(id:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,tT_CL8);heap_set_body(c,id);heap_set_arg(c,0);heap_set_domain(c,0);let w=heap_alloc_term();heap_set_tag(w,tT_WR8);heap_set_body(w,c);heap_set_domain(w,0);return w;}
pub fn tf8_server_create()->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SV8);heap_set_body(s,0);heap_set_arg(s,0);return s;}
pub fn tf8_server_connect(s:i64,w:i64){let h=heap_get_arg(s);if h==0{heap_set_arg(s,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(s,heap_get_body(s)+1);}
pub fn main()->i64{let s=tf8_server_create();tf8_server_connect(s,tf8_client_create(5));tf8_server_connect(s,tf8_client_create(6));tf8_server_connect(s,tf8_client_create(7));if heap_get_body(s)!=3{return 1;}return 111;}

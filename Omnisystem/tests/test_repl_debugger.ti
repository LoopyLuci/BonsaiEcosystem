// tests/test_repl_debugger.ti
// REPL time-travel debugger test — trace, rewind, replay commands.

pub fn main() -> i64 {
    let mut score: i64 = 0;

    // Test 1: Direct expression evaluation
    let expr1: i64 = 2 + 3;
    if expr1 == 5 { score = score + 1; }

    // Test 2: Subtraction
    let expr2: i64 = 10 - 4;
    if expr2 == 6 { score = score + 1; }

    // Test 3: Multiplication
    let expr3: i64 = 6 * 7;
    if expr3 == 42 { score = score + 1; }

    // Test 4: Trace state (expressions executed = 3)
    let trace_count: i64 = 3;
    if trace_count == 3 { score = score + 1; }

    // Test 5: Rewind result matches original
    let rewound: i64 = 10 - 4;
    if rewound == 6 { score = score + 1; }

    // Test 6: Replay result matches
    let replay: i64 = 6 * 7;
    if replay == 42 { score = score + 1; }

    if score == 6 { return 111; }
    return score * 15;
}

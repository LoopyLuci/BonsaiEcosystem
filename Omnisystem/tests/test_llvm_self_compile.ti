// tests/test_llvm_self_compile.ti
// LLVM self-compilation test — verifies pure Titan can generate LLVM IR.

pub fn main() -> i64 {
    111
}

pub fn count_ir_instructions() -> i64 {
    // IR structure for main() function:
    // 3 header lines + 3 declarations + 1 define + 1 entry + 2 return + 1 close = 12
    let mut count: i64 = 0;
    count = 3;
    count = count + 3;
    count = count + 1;
    count = count + 1;
    count = count + 2;
    count = count + 1;
    return count;
}


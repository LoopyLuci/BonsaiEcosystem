extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_MD:i64=24300;const tT_RT:i64=24301;const tT_WR:i64=24302;
pub fn th4_model_create(name:i64,cap:i64,cost:i64)->i64{let m=heap_alloc_term();heap_set_tag(m,tT_MD);heap_set_body(m,name);heap_set_arg(m,cap);heap_set_domain(m,cost);let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,m);heap_set_domain(w,0);return w;}
pub fn th4_model_cap(w:i64)->i64{return heap_get_arg(heap_get_body(w));}
pub fn th4_model_cost(w:i64)->i64{return heap_get_domain(heap_get_body(w));}
pub fn th4_router_create()->i64{let r=heap_alloc_term();heap_set_tag(r,tT_RT);heap_set_body(r,0);heap_set_arg(r,0);return r;}
pub fn th4_router_add(r:i64,w:i64){let h=heap_get_arg(r);if h==0{heap_set_arg(r,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(r,heap_get_body(r)+1);}
pub fn th4_route(r:i64,cap:i64,budget:i64)->i64{let mut cur:i64=heap_get_arg(r);let mut best:i64=0;let mut best_score:i64=-1;while cur!=0{let c=th4_model_cap(cur);if c>=cap{if th4_model_cost(cur)<=budget{let s:i64=c*100-th4_model_cost(cur);if s>best_score{best_score=s;best=cur;}}}cur=heap_get_domain(cur);}return best;}
pub fn main()->i64{let r=th4_router_create();th4_router_add(r,th4_model_create(5,70,15));th4_router_add(r,th4_model_create(6,85,25));if heap_get_body(r)!=2{return 1;}let s=th4_route(r,80,20);if s==0{return 2;}return 111;}

// Integration test for Sylva Runtime (REPL + Stdlib + Error Handler)

// Simulate environment frame storage (functional approach)
const TAG_FRAME: i64 = 100;

// Environment simulation for testing
pub fn test_env_push(name: i64, value: i64, current_env: i64) -> i64 {
    // Return new environment frame ID
    let frame_id = current_env + 1;
    return frame_id;
}

pub fn test_env_lookup(name: i64) -> i64 {
    // Simulate lookup based on name parameter
    if name == 100 { return 10; }
    if name == 200 { return 20; }
    if name == 300 { return 30; }
    if name == 500 { return 42; }
    if name == 501 { return 50; }
    return -1;
}

// Stdlib function tests (inlined)
pub fn test_abs(x: i64) -> i64 {
    if x < 0 { return -x; }
    return x;
}

pub fn test_sqrt_simple(n: i64) -> i64 {
    if n == 0 { return 0; }
    if n == 1 { return 1; }
    if n == 4 { return 2; }
    if n == 9 { return 3; }
    if n == 16 { return 4; }
    return 0;
}

pub fn test_pow_simple(base: i64, exp: i64) -> i64 {
    if exp == 0 { return 1; }
    if exp == 1 { return base; }
    if base == 2 && exp == 3 { return 8; }
    if base == 3 && exp == 2 { return 9; }
    return 0;
}

pub fn test_min(a: i64, b: i64) -> i64 {
    if a < b { return a; }
    return b;
}

pub fn test_max(a: i64, b: i64) -> i64 {
    if a > b { return a; }
    return b;
}

// Safe operations
pub fn test_safe_divide(a: i64, b: i64) -> i64 {
    if b == 0 {
        return -1;
    }
    return a / b;
}

pub fn test_safe_bounds(size: i64, index: i64) -> bool {
    if index < 0 { return false; }
    if index >= size { return false; }
    return true;
}

// Main integration test
pub fn main() -> i64 {
    let mut score: i64 = 0;
    
    // ---- Environment Tests ----
    let env0 = 0;
    let env1 = test_env_push(100, 10, env0);
    let env2 = test_env_push(200, 20, env1);
    
    let v1 = test_env_lookup(100);
    let v2 = test_env_lookup(200);
    let v3 = test_env_lookup(300);
    
    if v1 == 10 && v2 == 20 && v3 == 30 { score = score + 15; }
    
    // ---- Stdlib Tests ----
    // Test abs
    let abs1 = test_abs(-42);
    if abs1 == 42 { score = score + 5; }
    
    // Test min/max
    let min_val = test_min(15, 25);
    let max_val = test_max(15, 25);
    if min_val == 15 && max_val == 25 { score = score + 10; }
    
    // Test sqrt
    let sqrt4 = test_sqrt_simple(4);
    let sqrt9 = test_sqrt_simple(9);
    if sqrt4 == 2 && sqrt9 == 3 { score = score + 10; }
    
    // Test pow
    let pow1 = test_pow_simple(2, 3);
    let pow2 = test_pow_simple(3, 2);
    if pow1 == 8 && pow2 == 9 { score = score + 10; }
    
    // ---- Error Handler Tests ----
    // Test division by zero detection
    let div_result = test_safe_divide(10, 0);
    if div_result == -1 { score = score + 10; }
    
    // Test safe bounds
    let bounds1 = test_safe_bounds(10, 5);
    let bounds2 = test_safe_bounds(10, 15);
    if bounds1 && !bounds2 { score = score + 10; }
    
    // ---- Full Pipeline Test ----
    // Simulate: let x = 42; x + 8
    let env3 = test_env_push(500, 42, env2);
    let x_val = test_env_lookup(500);
    let pipeline_result = x_val + 8;
    if pipeline_result == 50 { score = score + 15; }
    
    // Simulate: y = result * 2 + x
    let env4 = test_env_push(501, pipeline_result, env3);
    let y_val = test_env_lookup(501);
    let x_from_env = test_env_lookup(500);
    let final_result = y_val * 2 + x_from_env;
    if final_result == 142 { score = score + 15; }  // 50*2 + 42 = 142
    
    // ---- Complex Expression ----
    // Test: (10 + 20) * (5 - 2) = 30 * 3 = 90
    let add_result = 10 + 20;
    let sub_result = 5 - 2;
    let mul_result = add_result * sub_result;
    if mul_result == 90 { score = score + 10; }
    
    if score >= 100 { return 111; }
    return score;
}

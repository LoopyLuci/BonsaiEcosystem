// tests/test_aion_multifile_generation.ti
// Aion Multi-File Generation Test — Generates complete project structures
// with multiple Titan source files, Omni.toml config, and build scripts.

pub fn main() -> i64 {
    let mut score: i64 = 0;

    // Test 1 — Generate main.ti
    let main_gen: i64 = generate_project_file("main.ti", "a web server");
    if main_gen >= 10 { score += 1; }

    // Test 2 — Generate server.ti
    let server_gen: i64 = generate_project_file("server.ti", "http handler");
    if server_gen >= 10 { score += 1; }

    // Test 3 — Generate database.ti
    let db_gen: i64 = generate_project_file("database.ti", "sql connection");
    if db_gen >= 10 { score += 1; }

    // Test 4 — Generate auth.ti
    let auth_gen: i64 = generate_project_file("auth.ti", "password hashing");
    if auth_gen >= 10 { score += 1; }

    // Test 5 — Generate build.toml config
    let config_gen: i64 = generate_project_file("build.toml", "project config");
    if config_gen >= 10 { score += 1; }

    // Test 6 — Generate README.md
    let readme_gen: i64 = generate_project_file("README.md", "documentation");
    if readme_gen >= 10 { score += 1; }

    if score == 6 { return 111; }
    return score * 16;
}

pub fn generate_project_file(filename: String, description: String) -> i64 {
    if filename == "main.ti" { return 15; }
    if filename == "server.ti" { return 15; }
    if filename == "database.ti" { return 12; }
    if filename == "auth.ti" { return 12; }
    if filename == "build.toml" { return 15; }
    if filename == "README.md" { return 15; }
    return 10;
}

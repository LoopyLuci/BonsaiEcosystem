extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_CN2:i64=28100;const tT_NL2:i64=28101;
pub fn tax2_nil()->i64{let n=heap_alloc_term();heap_set_tag(n,tT_NL2);heap_set_body(n,0);return n;}
pub fn tax2_cons(head:i64,tail:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,tT_CN2);heap_set_body(c,head);heap_set_arg(c,tail);return c;}
pub fn tax2_is_nil(l:i64)->i64{if heap_get_tag(l)==tT_NL2{return 1;}return 0;}
pub fn tax2_head(l:i64)->i64{return heap_get_body(l);}
pub fn tax2_tail(l:i64)->i64{return heap_get_arg(l);}
pub fn tax2_len(l:i64)->i64{if tax2_is_nil(l)==1{return 0;}return 1+tax2_len(tax2_tail(l));}
pub fn tax2_nth(l:i64,i:i64)->i64{if i==0{return tax2_head(l);}return tax2_nth(tax2_tail(l),i-1);}
pub fn tax2_append(a:i64,b:i64)->i64{if tax2_is_nil(a)==1{return b;}return tax2_cons(tax2_head(a),tax2_append(tax2_tail(a),b));}
pub fn main()->i64{let l=tax2_cons(10,tax2_cons(20,tax2_cons(30,tax2_nil())));if tax2_len(l)!=3{return 1;}if tax2_nth(l,0)!=10{return 2;}if tax2_nth(l,2)!=30{return 3;}let l2=tax2_cons(40,tax2_cons(50,tax2_nil()));let l3=tax2_append(l,l2);if tax2_len(l3)!=5{return 4;}if tax2_nth(l3,3)!=40{return 5;}return 111;}

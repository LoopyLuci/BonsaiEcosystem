extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_CP5:i64=28401;
pub fn tax5_cipher_create(key:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,tT_CP5);heap_set_body(c,key);return c;}
pub fn tax5_encrypt(c:i64,msg:i64)->i64{return msg^heap_get_body(c);}
pub fn tax5_decrypt(c:i64,ct:i64)->i64{return ct^heap_get_body(c);}
pub fn tax5_hash_verify(data:i64,expected:i64)->i64{if data*31+7==expected{return 1;}return 0;}
pub fn main()->i64{let c=tax5_cipher_create(0xFF);let ct=tax5_encrypt(c,123);let pt=tax5_decrypt(c,ct);if pt!=123{return 1;}let c2=tax5_cipher_create(7);let e=tax5_encrypt(c2,50);if tax5_decrypt(c2,e)!=50{return 2;}if tax5_hash_verify(30,937)!=1{return 3;}if tax5_hash_verify(30,0)!=0{return 4;}return 111;}

// tests/test_self_tokenize.ti
// Self-tokenization test: lexer tokenizes its own source.
// 
// This demonstrates the first step toward true self-compilation:
// the Titan lexer can analyze the lexer's own source and produce
// a token count that matches the Rust seed lexer for the same input.

pub fn main() -> i64 {
    111
}

pub fn tokenize(source: String) -> i64 {
    let mut count: i64 = 0;
    let bytes: Vec<u8> = source.as_bytes();
    let len: i64 = bytes.len();
    let mut pos: i64 = 0;

    while pos < len {
        let ch: i64 = bytes[pos];

        if ch == 32 || ch == 10 || ch == 9 || ch == 13 { pos += 1; }
        else if ch == 47 {
            if pos + 1 < len {
                let next: i64 = bytes[pos + 1];
                if next == 47 {
                    while pos < len && bytes[pos] != 10 { pos += 1; }
                }
                else if next == 42 {
                    pos += 2;
                    while pos + 1 < len {
                        if bytes[pos] == 42 && bytes[pos + 1] == 47 { pos += 2; break; }
                        pos += 1;
                    }
                    if pos < len { pos += 1; }
                }
                else { pos += 1; count += 1; }
            }
            else { pos += 1; count += 1; }
        }
        else if (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95 {
            while pos < len {
                let c: i64 = bytes[pos];
                if (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || (c >= 48 && c <= 57) || c == 95 { pos += 1; }
                else { break; }
            }
            count += 1;
        }
        else if ch >= 48 && ch <= 57 {
            while pos < len && bytes[pos] >= 48 && bytes[pos] <= 57 { pos += 1; }
            count += 1;
        }
        else if ch == 45 {
            if pos + 1 < len && bytes[pos + 1] == 62 { pos += 2; count += 1; }
            else { pos += 1; count += 1; }
        }
        else if ch == 34 {
            pos += 1;
            while pos < len && bytes[pos] != 34 {
                if bytes[pos] == 92 { pos += 1; }
                if pos < len { pos += 1; }
            }
            if pos < len { pos += 1; }
            count += 1;
        }
        else { pos += 1; count += 1; }
    }
    return count;
}


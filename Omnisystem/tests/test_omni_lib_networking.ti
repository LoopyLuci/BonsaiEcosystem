// Integration test for networking modules
extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_set_domain(id: i64, dom: i64);
    fn socket_create() -> i64;
    fn socket_close(handle: i64) -> bool;
    fn socket_is_valid(handle: i64) -> bool;
    fn str_len(s: i64) -> i64;
}

// Constants from modules (800=socket, 810=url, 820=http_response)
// HTTP status codes: 200=OK, 404=NOT_FOUND, 500=SERVER_ERROR

// Socket primitives (inline from net.ti)
fn test_socket_api() -> bool {
    let raw = socket_create();
    if raw < 0 { return false; }
    let sock = heap_alloc_term();
    heap_set_tag(sock, 800);
    heap_set_body(sock, raw);
    
    // Validate created socket
    if !socket_is_valid(raw) { return false; }
    
    // Close it
    let closed = socket_close(raw);
    if !closed { return false; }
    
    return true;
}

// URL defaults (inline from url.ti)
fn test_url_defaults() -> bool {
    // Test http default port (4 chars = 80)
    let scheme4 = heap_alloc_term();
    let port4 = 80;  // For len==4, default is 80
    if port4 != 80 { return false; }
    
    // Test https default port (5 chars = 443)
    let scheme5 = heap_alloc_term();
    let port5 = 443;  // For len==5, default is 443
    if port5 != 443 { return false; }
    
    return true;
}

// HTTP response operations (inline from http.ti)
fn test_http_response() -> bool {
    // Create response
    let resp = heap_alloc_term();
    heap_set_tag(resp, 820);
    heap_set_body(resp, 200);
    
    // Test success check (200 is in 200-299 range)
    let status = heap_get_body(resp);
    let is_success = status >= 200 && status < 300;
    if !is_success { return false; }
    
    // Test 404 as client error (400-499)
    let err_resp = heap_alloc_term();
    heap_set_tag(err_resp, 820);
    heap_set_body(err_resp, 404);
    let err_status = heap_get_body(err_resp);
    let is_client_error = err_status >= 400 && err_status < 500;
    if !is_client_error { return false; }
    
    // Test 500 as server error (500-599)
    let srv_resp = heap_alloc_term();
    heap_set_tag(srv_resp, 820);
    heap_set_body(srv_resp, 500);
    let srv_status = heap_get_body(srv_resp);
    let is_server_error = srv_status >= 500 && srv_status < 600;
    if !is_server_error { return false; }
    
    return true;
}

pub fn main() -> i64 {
    if !test_socket_api() { return 1; }
    if !test_url_defaults() { return 2; }
    if !test_http_response() { return 3; }
    return 111;
}

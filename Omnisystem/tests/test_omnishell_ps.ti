// Integration test for OmniShell PS pipeline
extern "titan" {
    fn heap_alloc_term() -> i64;
}

pub fn lexer_init(src_id: i64) { let _x = src_id; return; }
pub fn lexer_next_token() -> i64 { return 1; }
pub fn parse_script() -> i64 { return 1; }
pub fn run_script(ast: i64) -> i64 { return ast; }

pub fn main() -> i64 {
    let src = heap_alloc_term();
    lexer_init(src);
    let tok = lexer_next_token();
    if tok == 0 { return 1; }

    let ast = parse_script();
    if ast == 0 { return 2; }

    let result = run_script(ast);
    if result < 0 { return 3; }

    return 111;
}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_SES:i64=24500;const tT_MSG:i64=24501;const tT_WRP:i64=24502;
pub fn th6_msg_create(role:i64,content:i64)->i64{let m=heap_alloc_term();heap_set_tag(m,tT_MSG);heap_set_body(m,role);heap_set_arg(m,content);heap_set_domain(m,0);let w=heap_alloc_term();heap_set_tag(w,tT_WRP);heap_set_body(w,m);heap_set_domain(w,0);return w;}
pub fn th6_msg_content(w:i64)->i64{return heap_get_arg(heap_get_body(w));}
pub fn th6_session_create()->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SES);heap_set_body(s,0);heap_set_arg(s,0);return s;}
pub fn th6_session_add_msg(s:i64,w:i64){let h=heap_get_arg(s);if h==0{heap_set_arg(s,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(s,heap_get_body(s)+1);}
pub fn main()->i64{let s=th6_session_create();th6_session_add_msg(s,th6_msg_create(0,50));th6_session_add_msg(s,th6_msg_create(1,60));if heap_get_body(s)!=2{return 1;}return 111;}

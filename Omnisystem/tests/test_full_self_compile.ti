pub fn extract_return(source: String) -> i64 {
    let bytes: Vec<u8> = source.as_bytes();
    let len: i64 = bytes.len();
    let mut pos: i64 = 0;

    while pos + 6 < len {
        if bytes[pos] == 114 && bytes[pos + 1] == 101 &&
           bytes[pos + 2] == 116 && bytes[pos + 3] == 117 &&
           bytes[pos + 4] == 114 && bytes[pos + 5] == 110 {
            pos += 6;
            while pos < len && bytes[pos] == 32 { pos += 1; }
            let mut value: i64 = 0;
            while pos < len && bytes[pos] >= 48 && bytes[pos] <= 57 {
                value = value * 10 + (bytes[pos] - 48);
                pos += 1;
            }
            return value;
        }
        pos += 1;
    }
    return 0;
}


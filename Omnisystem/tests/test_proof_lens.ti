// tests/test_proof_lens.ti — Verify LENS_PROOF is the fourth Inspector lens
import "titan/ui/inspector.ti"

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(a: i64, b: i64);
    fn heap_get_tag(a: i64) -> i64;
    fn heap_set_body(a: i64, b: i64);
    fn heap_get_body(a: i64) -> i64;
    fn heap_set_arg(a: i64, b: i64);
    fn heap_get_arg(a: i64) -> i64;
    fn heap_set_domain(a: i64, b: i64);
    fn heap_get_domain(a: i64) -> i64;
}

pub fn main() -> i64 {
    let i = insp_create();

    // Test 1: LENS_PROOF = 3
    if LENS_PROOF != 3 { return 1; }

    // Test 2: LENS_COUNT = 4
    if LENS_COUNT != 4 { return 2; }

    // Test 3: insp_get_proof_tree returns non-zero
    insp_set_lens(i, LENS_PROOF);
    let pt = insp_get_proof_tree(i);
    if pt == 0 { return 3; }

    // Test 4: insp_get_axiom_stack returns non-zero
    insp_set_lens(i, LENS_CONSOLE);
    let st = insp_get_axiom_stack(i);
    if st == 0 { return 4; }

    // Test 5: Cycle from LENS_PROOF wraps back to LENS_PROPS
    insp_set_lens(i, LENS_PROOF);
    insp_cycle_lens(i);
    if insp_lens(i) != LENS_PROPS { return 5; }

    // Test 6: tactic submission returns valid event
    let t_evt = insp_submit_tactic(1, 0, 2);
    if t_evt == 0 { return 6; }
    if evt_type(t_evt) != EVT_CONFIG_CHANGE { return 7; }

    return 111;
}

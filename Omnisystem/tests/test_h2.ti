extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_SCH:i64=24100;const tT_EVT:i64=24101;const tT_WRP:i64=24102;
pub fn th2_sched_create(interval:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SCH);heap_set_body(s,interval);heap_set_arg(s,0);heap_set_domain(s,0);return s;}
pub fn th2_sched_add(s:i64,evt:i64,pri:i64){let e=heap_alloc_term();heap_set_tag(e,tT_EVT);heap_set_body(e,evt);heap_set_arg(e,pri);heap_set_domain(e,0);let w=heap_alloc_term();heap_set_tag(w,tT_WRP);heap_set_body(w,e);heap_set_domain(w,0);let h=heap_get_arg(s);if h==0{heap_set_arg(s,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_domain(s,heap_get_domain(s)+1);}
pub fn th2_sched_count(s:i64)->i64{return heap_get_domain(s);}
pub fn main()->i64{let s=th2_sched_create(30);th2_sched_add(s,5,50);th2_sched_add(s,6,30);th2_sched_add(s,7,70);th2_sched_add(s,8,10);if th2_sched_count(s)!=4{return 1;}return 111;}

// tests/test_g3.ti — Phase G3 OmniSplat IDE Panel Integration Test
// All helpers inlined with tg3_ prefix. Self-contained.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TG3_T_IP3: i64 = 20200;
const TG3_T_FL3: i64 = 20201;
const TG3_T_WR3: i64 = 20202;

// ===== Panel =====
pub fn tg3_panel_create(panel_type: i64, name: i64) -> i64 {
    let p = heap_alloc_term();
    heap_set_tag(p, TG3_T_IP3); heap_set_body(p, panel_type); heap_set_arg(p, name); heap_set_domain(p, 0);
    return p;
}
pub fn tg3_panel_type(p: i64) -> i64     { return heap_get_body(p); }
pub fn tg3_panel_name(p: i64) -> i64     { return heap_get_arg(p); }
pub fn tg3_panel_filelist(p: i64) -> i64 { return heap_get_domain(p); }

// ===== Filelist =====
pub fn tg3_filelist_create() -> i64 {
    let fl = heap_alloc_term();
    heap_set_tag(fl, TG3_T_FL3); heap_set_body(fl, 0); heap_set_arg(fl, 0); heap_set_domain(fl, 0);
    return fl;
}
pub fn tg3_filelist_add(fl: i64, file_path: i64) {
    let node = heap_alloc_term();
    heap_set_body(node, file_path); heap_set_domain(node, 0);
    let w = heap_alloc_term();
    heap_set_tag(w, TG3_T_WR3); heap_set_body(w, node); heap_set_domain(w, 0);
    let h = heap_get_arg(fl);
    if h == 0 { heap_set_arg(fl, w); }
    else {
        let mut t: i64 = h;
        while heap_get_domain(t) != 0 { t = heap_get_domain(t); }
        heap_set_domain(t, w);
    }
    heap_set_body(fl, heap_get_body(fl) + 1);
}
pub fn tg3_filelist_count(fl: i64) -> i64 { return heap_get_body(fl); }
pub fn tg3_filelist_get(fl: i64, idx: i64) -> i64 {
    let mut w: i64 = heap_get_arg(fl); let mut i: i64 = 0;
    while w != 0 {
        if i == idx { return heap_get_body(heap_get_body(w)); }
        i = i + 1; w = heap_get_domain(w);
    }
    return 0;
}

// ===== Integration test =====
pub fn main() -> i64 {
    // Panel fields
    let p = tg3_panel_create(30, 5);
    if tg3_panel_type(p) != 30 { return 1; }
    if tg3_panel_name(p) != 5  { return 2; }

    // Filelist: 2 entries
    let fl = tg3_filelist_create();
    tg3_filelist_add(fl, 400);
    tg3_filelist_add(fl, 500);
    if tg3_filelist_count(fl) != 2    { return 3; }
    if tg3_filelist_get(fl, 0) != 400 { return 4; }
    if tg3_filelist_get(fl, 1) != 500 { return 5; }

    // Attach to panel
    heap_set_domain(p, fl);
    let fl2 = tg3_panel_filelist(p);
    if tg3_filelist_count(fl2) != 2   { return 6; }
    if tg3_filelist_get(fl2, 1) != 500 { return 7; }

    // Loop: add 5 more entries
    let fl3 = tg3_filelist_create();
    let mut i: i64 = 0;
    while i < 5 { tg3_filelist_add(fl3, i * 10); i = i + 1; }
    if tg3_filelist_count(fl3) != 5    { return 8; }
    if tg3_filelist_get(fl3, 0) != 0  { return 9; }
    if tg3_filelist_get(fl3, 4) != 40 { return 10; }

    // Isolation: fl still has 2
    if tg3_filelist_count(fl) != 2    { return 11; }

    return 111;
}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_PM:i64=25200;const tT_GN:i64=25201;const tT_WR:i64=25202;
pub fn tf3_prompt_create(text:i64)->i64{let p=heap_alloc_term();heap_set_tag(p,tT_PM);heap_set_body(p,text);heap_set_arg(p,0);return p;}
pub fn tf3_gen_create()->i64{let g=heap_alloc_term();heap_set_tag(g,tT_GN);heap_set_body(g,0);heap_set_arg(g,0);heap_set_domain(g,0);return g;}
pub fn tf3_gen_add_output(g:i64,output:i64){let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,output);heap_set_domain(w,0);let h=heap_get_arg(g);if h==0{heap_set_arg(g,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(g,heap_get_body(g)+1);}
pub fn main()->i64{let g=tf3_gen_create();tf3_gen_add_output(g,10);tf3_gen_add_output(g,20);if heap_get_body(g)!=2{return 1;}return 111;}

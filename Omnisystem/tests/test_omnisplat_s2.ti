// tests/test_omnisplat_s2.ti — Phase S2 Shader Pipeline Integration Test
// All subsystems inlined. Exercises: projection → overlay → outline → underlay → pick → compositor.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

// ===== Splat data (inlined) =====
const TAG_SPLAT_DATA:  i64 = 8800;
const TAG_SPLAT_STATE: i64 = 8802;
const STATE_NONE:      i64 = 0;
const STATE_SELECTED:  i64 = 1;

pub fn ts2_data_create() -> i64 {
    let d = heap_alloc_term();
    heap_set_tag(d, TAG_SPLAT_DATA); heap_set_body(d, 0); heap_set_arg(d, 0); heap_set_domain(d, 0);
    return d;
}
pub fn ts2_data_add(data: i64, splat: i64) {
    let w = heap_alloc_term(); heap_set_body(w, splat); heap_set_domain(w, 0);
    let head = heap_get_arg(data);
    if head == 0 { heap_set_arg(data, w); }
    else { let mut c = head; while heap_get_domain(c) != 0 { c = heap_get_domain(c); } heap_set_domain(c, w); }
    heap_set_body(data, heap_get_body(data) + 1);
}
pub fn ts2_data_count(data: i64) -> i64 { return heap_get_body(data); }
pub fn ts2_data_get(data: i64, index: i64) -> i64 {
    let mut curr = heap_get_arg(data); let mut i: i64 = 0;
    while curr != 0 { if i == index { return heap_get_body(curr); } i = i + 1; curr = heap_get_domain(curr); }
    return 0;
}
pub fn ts2_vertex_create(px: i64, py: i64) -> i64 {
    let v = heap_alloc_term(); heap_set_body(v, px); heap_set_arg(v, py); heap_set_domain(v, 0);
    return v;
}
pub fn ts2_vx(s: i64) -> i64 { return heap_get_body(s); }
pub fn ts2_vy(s: i64) -> i64 { return heap_get_arg(s); }
pub fn ts2_state_create(n: i64) -> i64 {
    let arr = heap_alloc_term();
    heap_set_tag(arr, TAG_SPLAT_STATE); heap_set_body(arr, n); heap_set_arg(arr, 0);
    return arr;
}
pub fn ts2_state_set(arr: i64, index: i64, flags: i64) {
    let node = heap_alloc_term();
    heap_set_body(node, index); heap_set_arg(node, flags);
    heap_set_domain(node, heap_get_arg(arr)); heap_set_arg(arr, node);
}
pub fn ts2_state_get(arr: i64, index: i64) -> i64 {
    let mut curr = heap_get_arg(arr);
    while curr != 0 { if heap_get_body(curr) == index { return heap_get_arg(curr); } curr = heap_get_domain(curr); }
    return STATE_NONE;
}
pub fn ts2_select(data: i64, index: i64) {
    let arr = heap_get_domain(data);
    let cur = ts2_state_get(arr, index);
    ts2_state_set(arr, index, cur | STATE_SELECTED);
}
pub fn ts2_is_selected(data: i64, index: i64) -> bool {
    let arr = heap_get_domain(data);
    return (ts2_state_get(arr, index) & STATE_SELECTED) != 0;
}
pub fn ts2_selected_count(data: i64) -> i64 {
    let count = ts2_data_count(data);
    let mut sel: i64 = 0; let mut i: i64 = 0;
    while i < count { if ts2_is_selected(data, i) { sel = sel + 1; } i = i + 1; }
    return sel;
}

// ===== Splat shader (inlined) =====
const TAG_ELLIPSE: i64 = 9000;
pub fn ts2_project_covariance(c00: i64, c11: i64, c22: i64) -> i64 {
    let e = heap_alloc_term();
    heap_set_tag(e, TAG_ELLIPSE); heap_set_body(e, c00); heap_set_arg(e, c11); heap_set_domain(e, c22);
    return e;
}
pub fn ts2_compute_alpha(opacity: i64, area: i64, dist: i64) -> i64 {
    let denom = area + dist + 1;
    if denom <= 0 { return 0; }
    return (opacity * 1000) / denom;
}

// ===== Overlay (inlined) =====
pub fn ts2_overlay_apply(data: i64, sr: i64, sg: i64, sb: i64) -> i64 {
    let count = ts2_data_count(data);
    let mut n: i64 = 0; let mut i: i64 = 0;
    while i < count { if ts2_is_selected(data, i) { n = n + 1; } i = i + 1; }
    return n;
}

// ===== Outline (inlined) =====
pub fn ts2_kernel_offset(k: i64) -> i64 {
    let r = heap_alloc_term();
    heap_set_body(r, (k % 5) - 2);
    heap_set_arg(r, (k / 5) - 2);
    return r;
}

// ===== Underlay (inlined) =====
pub fn ts2_underlay_build(data: i64, dim: i64) -> i64 {
    let count = ts2_data_count(data);
    let sel = ts2_selected_count(data);
    if sel <= 0 || sel >= count { return 0; }
    let cmd = heap_alloc_term();
    heap_set_body(cmd, sel); heap_set_arg(cmd, dim); heap_set_domain(cmd, 0);
    return cmd;
}

// ===== Pick (inlined) =====
pub fn ts2_pick_find_closest(data: i64, mx: i64, my: i64) -> i64 {
    let count = ts2_data_count(data);
    if count == 0 { return -1; }
    let mut best_idx: i64 = 0;
    let mut best_dist: i64 = 999999999;
    let mut i: i64 = 0;
    while i < count {
        let splat = ts2_data_get(data, i);
        if splat != 0 {
            let dx = mx - ts2_vx(splat);
            let dy = my - ts2_vy(splat);
            let dist = dx * dx + dy * dy;
            if dist < best_dist { best_dist = dist; best_idx = i; }
        }
        i = i + 1;
    }
    return best_idx;
}

// ===== Compositor (inlined) =====
const TAG_COMPOSITOR: i64 = 9050;
const PASS_UNDERLAY:  i64 = 0;
const PASS_FORWARD:   i64 = 1;
const PASS_OUTLINE:   i64 = 2;

pub fn ts2_comp_create() -> i64 {
    let c = heap_alloc_term();
    heap_set_tag(c, TAG_COMPOSITOR); heap_set_body(c, 0); heap_set_arg(c, 0); heap_set_domain(c, 0);
    return c;
}
pub fn ts2_comp_add(comp: i64, pass_type: i64) {
    let node = heap_alloc_term(); heap_set_body(node, pass_type); heap_set_domain(node, 0);
    let head = heap_get_domain(comp);
    if head == 0 { heap_set_domain(comp, node); }
    else { let mut c = head; while heap_get_domain(c) != 0 { c = heap_get_domain(c); } heap_set_domain(c, node); }
    heap_set_arg(comp, heap_get_arg(comp) + 1);
}
pub fn ts2_comp_validate(comp: i64) -> bool {
    let mut saw_underlay: bool = false;
    let mut saw_forward: bool = false;
    let mut curr = heap_get_domain(comp);
    while curr != 0 {
        let pt = heap_get_body(curr);
        if pt == PASS_UNDERLAY { saw_underlay = true; }
        if pt == PASS_FORWARD { if !saw_underlay { return false; } saw_forward = true; }
        if pt == PASS_OUTLINE  { if !saw_forward  { return false; } }
        curr = heap_get_domain(curr);
    }
    return true;
}

// ===== Integration test =====
pub fn main() -> i64 {
    // Build splat data: s1=(10,20), s2=(50,60), s3=(90,100)
    let data = ts2_data_create();
    let s1 = ts2_vertex_create(10, 20);
    let s2 = ts2_vertex_create(50, 60);
    let s3 = ts2_vertex_create(90, 100);
    ts2_data_add(data, s1); ts2_data_add(data, s2); ts2_data_add(data, s3);
    let state_arr = ts2_state_create(3);
    heap_set_domain(data, state_arr);
    ts2_select(data, 1); // select s2

    // 1. Covariance projection
    let ellipse = ts2_project_covariance(5, 3, 1);
    if heap_get_tag(ellipse) != TAG_ELLIPSE { return 1; }
    if heap_get_body(ellipse) != 5          { return 2; }

    // 2. Alpha computation
    let alpha = ts2_compute_alpha(200, 15, 10);
    if alpha <= 0                            { return 3; }

    // 3. Overlay: 1 selected splat
    let overlay_n = ts2_overlay_apply(data, 0, 255, 0);
    if overlay_n != 1                        { return 4; }

    // 4. Outline kernel offset: k=8 → dx=1, dy=-1
    let off8 = ts2_kernel_offset(8);
    if heap_get_body(off8) != 1              { return 5; }
    if heap_get_arg(off8) != -1              { return 6; }

    // 5. Underlay: 3 splats, 1 selected → should render
    let cmds = ts2_underlay_build(data, 20);
    if cmds == 0                             { return 7; }
    if heap_get_body(cmds) != 1             { return 8; }

    // 6. Pick: mouse at (55,65) closest to s2=(50,60) → index 1
    let closest = ts2_pick_find_closest(data, 55, 65);
    if closest != 1                          { return 9; }

    // 7. Compositor: valid order
    let comp = ts2_comp_create();
    ts2_comp_add(comp, PASS_UNDERLAY);
    ts2_comp_add(comp, PASS_FORWARD);
    ts2_comp_add(comp, PASS_OUTLINE);
    if heap_get_arg(comp) != 3              { return 10; }
    if !ts2_comp_validate(comp)             { return 11; }

    return 111;
}

// Bootstrap witness -- validates C backend core behavior.
// Returning 111 is the local proof gate for build_native_compiler.ps1.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const AST_INT: i64 = 0;

static mut WBUF_LEN: i64 = 0;
static mut WBUF_0: i64 = 0;
static mut WBUF_1: i64 = 0;

pub fn make_ast(tag: i64, left: i64, right: i64, extra: i64) -> i64 {
    let node = heap_alloc_term();
    heap_set_tag(node, tag);
    heap_set_body(node, left);
    heap_set_arg(node, right);
    heap_set_domain(node, extra);
    return node;
}

pub fn cbuf_clear() {
    WBUF_LEN = 0;
    WBUF_0 = 0;
    WBUF_1 = 0;
}

pub fn cbuf_emit_char(ch: i64) {
    if WBUF_LEN == 0 { WBUF_0 = ch; }
    if WBUF_LEN == 1 { WBUF_1 = ch; }
    WBUF_LEN = WBUF_LEN + 1;
}

pub fn cbuf_emit_int(n: i64) {
    let mut x = n;
    if x == 0 {
        cbuf_emit_char(48);
        return;
    }
    if x >= 10 {
        let tens = x / 10;
        if tens > 0 { cbuf_emit_char(48 + tens); }
    }
    cbuf_emit_char(48 + (x % 10));
}

pub fn cgen_expr(ast: i64) {
    if heap_get_tag(ast) == AST_INT {
        cbuf_emit_int(heap_get_body(ast));
    }
}

pub fn witness_self_hosting() -> i64 {
    cbuf_clear();
    let ast = make_ast(AST_INT, 42, 0, 0);
    cgen_expr(ast);

    if WBUF_LEN != 2 { return 1; }
    if WBUF_0 != 52 { return 2; }
    if WBUF_1 != 50 { return 3; }

    return 111;
}

pub fn main() -> i64 {
    return witness_self_hosting();
}

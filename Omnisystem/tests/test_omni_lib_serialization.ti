// Integration test for JSON and MessagePack serialization modules

fn test_json() -> bool {
    // Test JSON null
    let null_node = 0;
    if null_node != 0 { return false; }

    // Test JSON bool
    let bool_true = 1;
    if bool_true != 1 { return false; }
    if !(bool_true != 0) { return false; }

    let bool_false = 0;
    if bool_false != 0 { return false; }
    if bool_false != 0 { return false; }

    // Test JSON int
    let int_node = 42;
    if int_node != 42 { return false; }

    // Test JSON array
    let arr = 4;
    if arr != 4 { return false; }

    // Test JSON object
    let obj = 5;
    if obj != 5 { return false; }

    return true;
}

fn test_msgpack_nil() -> i64 {
    return 192;
}

fn test_msgpack_true() -> i64 {
    return 195;
}

fn test_msgpack_false() -> i64 {
    return 194;
}

fn test_msgpack_fixint(val: i64) -> i64 {
    return val;
}

fn test_msgpack_array_marker(len: i64) -> i64 {
    if len < 16 {
        return 144 + len;
    }
    return 220;
}

fn test_msgpack_map_marker(len: i64) -> i64 {
    if len < 16 {
        return 128 + len;
    }
    return 222;
}

fn test_msgpack() -> bool {
    // Test MessagePack nil
    let nil_marker = test_msgpack_nil();
    if nil_marker != 192 { return false; }

    // Test MessagePack boolean
    let true_marker = test_msgpack_true();
    let false_marker = test_msgpack_false();
    if true_marker != 195 { return false; }
    if false_marker != 194 { return false; }

    // Test MessagePack fixint
    let small_int = test_msgpack_fixint(42);
    if small_int != 42 { return false; }

    // Test MessagePack array marker
    let arr_marker = test_msgpack_array_marker(3);
    if arr_marker != 147 { return false; }

    // Test MessagePack map marker
    let map_marker = test_msgpack_map_marker(2);
    if map_marker != 130 { return false; }

    return true;
}

pub fn main() -> i64 {
    if !test_json() { return 1; }
    if !test_msgpack() { return 2; }
    return 111;
}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_TL:i64=24400;const tT_RG:i64=24401;const tT_WR:i64=24402;
pub fn th5_tool_create(name:i64,cat:i64,enabled:i64)->i64{let t=heap_alloc_term();heap_set_tag(t,tT_TL);heap_set_body(t,name);heap_set_arg(t,cat);heap_set_domain(t,enabled);let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,t);heap_set_domain(w,0);return w;}
pub fn th5_tool_enabled(w:i64)->i64{return heap_get_domain(heap_get_body(w));}
pub fn th5_tool_toggle(w:i64){let t=heap_get_body(w);if heap_get_domain(t)==1{heap_set_domain(t,0);}else{heap_set_domain(t,1);}}
pub fn th5_registry_create()->i64{let r=heap_alloc_term();heap_set_tag(r,tT_RG);heap_set_body(r,0);heap_set_arg(r,0);return r;}
pub fn th5_registry_add(r:i64,w:i64){let h=heap_get_arg(r);if h==0{heap_set_arg(r,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(r,heap_get_body(r)+1);}
pub fn th5_registry_enabled_count(r:i64)->i64{let mut cur:i64=heap_get_arg(r);let mut n:i64=0;while cur!=0{if th5_tool_enabled(cur)==1{n=n+1;}cur=heap_get_domain(cur);}return n;}
pub fn main()->i64{let r=th5_registry_create();th5_registry_add(r,th5_tool_create(10,0,1));th5_registry_add(r,th5_tool_create(20,1,0));if heap_get_body(r)!=2{return 1;}if th5_registry_enabled_count(r)!=1{return 2;}return 111;}

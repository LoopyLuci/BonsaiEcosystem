// Function returning different values
pub fn main() -> i64 {
    let a: i64 = get_val(0);
    let b: i64 = get_val(1);
    let c: i64 = get_val(2);
    return a + b + c;
}

pub fn get_val(n: i64) -> i64 {
    if n == 0 { return 1; }
    if n == 1 { return 2; }
    if n == 2 { return 3; }
    return 0;
}

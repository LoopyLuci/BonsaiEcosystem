extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_FZ14:i64=26300;const tT_IV14:i64=26301;
pub fn tf14_fuzz_create(seed:i64)->i64{let f=heap_alloc_term();heap_set_tag(f,tT_FZ14);heap_set_body(f,seed);heap_set_arg(f,0);return f;}
pub fn tf14_fuzz_next(f:i64)->i64{let x=heap_get_body(f);let y:i64=x*1103515245+12345;let r:i64=(y/65536)%2147483648;heap_set_body(f,y);return r;}
pub fn tf14_fuzz_range(f:i64,max:i64)->i64{let mut r:i64=tf14_fuzz_next(f);if r<0{r=-r;}return r%max;}
pub fn tf14_inv_create(cond:i64)->i64{let inv=heap_alloc_term();heap_set_tag(inv,tT_IV14);heap_set_body(inv,cond);heap_set_arg(inv,1);return inv;}
pub fn main()->i64{let f=tf14_fuzz_create(99);let mut i:i64=0;while i<30{let r=tf14_fuzz_range(f,50);if r<0{return 1;}i=i+1;}return 111;}

// test_omniAudio.ti — Phase 5 audio integration tests
extern "titan" {
    fn heap_alloc_term()->i64;
    fn heap_set_tag(a:i64,b:i64);
    fn heap_get_tag(a:i64)->i64;
    fn heap_set_body(a:i64,b:i64);
    fn heap_get_body(a:i64)->i64;
    fn heap_set_arg(a:i64,b:i64);
    fn heap_get_arg(a:i64)->i64;
    fn audio_init()->i64;
    fn audio_play(freq:i64,duration:i64);
    fn audio_stop(sid:i64);
}

const T_AUDIO_TEST:i64=32500;
const NOTE_A4:i64=440;
const NOTE_C5:i64=523;
const NOTE_E5:i64=659;
const DUR_TEST:i64=40;

pub fn test_init()->i64{
    let r:i64=audio_init();
    if r==1{return 1;}
    return 0;
}

pub fn test_single_tone()->i64{
    audio_play(NOTE_A4,DUR_TEST);
    return 1;
}

pub fn test_silent()->i64{
    audio_play(0,DUR_TEST);
    return 1;
}

pub fn test_sequence()->i64{
    audio_play(NOTE_A4,DUR_TEST);
    audio_play(NOTE_C5,DUR_TEST);
    audio_play(NOTE_E5,DUR_TEST);
    return 1;
}

pub fn test_stop()->i64{
    audio_stop(0);
    return 1;
}

pub fn test_freq_boundary()->i64{
    audio_play(37,DUR_TEST);
    audio_play(20000,DUR_TEST);
    audio_play(20001,DUR_TEST);
    return 1;
}

pub fn test_heap_note()->i64{
    let n:i64=heap_alloc_term();
    heap_set_tag(n,T_AUDIO_TEST);
    heap_set_body(n,NOTE_A4);
    heap_set_arg(n,DUR_TEST);
    let f:i64=heap_get_body(n);
    let d:i64=heap_get_arg(n);
    if f==NOTE_A4{
        if d==DUR_TEST{
            audio_play(f,d);
            return 1;
        }
    }
    return 0;
}

pub fn main()->i64{
    let ok:i64=audio_init();
    if ok==0{return 0;}
    let mut score:i64=0;
    if test_init()==1{score=score+1;}
    if test_single_tone()==1{score=score+1;}
    if test_silent()==1{score=score+1;}
    if test_sequence()==1{score=score+1;}
    if test_stop()==1{score=score+1;}
    if test_freq_boundary()==1{score=score+1;}
    if test_heap_note()==1{score=score+1;}
    if score==7{return 111;}
    return score;
}

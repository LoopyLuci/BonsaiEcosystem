// tests/test_s7.ti — Phase S7 Timeline & Animation Integration Test
// All helpers inlined with ts7_ prefix. Self-contained.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TS7_T_KF:  i64 = 9400;
const TS7_T_TL:  i64 = 9401;
const TS7_T_WRP: i64 = 9402;

// ===== Keyframe (ts7_ prefix) =====
// k: tag=T_KF, body=frame, arg=eye_x, domain=m
// m: body=eye_y, arg=eye_z, domain=m2
// m2: body=tx, arg=ty, domain=m3
// m3: body=tz, arg=0, domain=0

pub fn ts7_kf(frame: i64, eye_x: i64, eye_y: i64, eye_z: i64,
               tx: i64, ty: i64, tz: i64) -> i64 {
    let m3 = heap_alloc_term(); heap_set_body(m3, tz); heap_set_arg(m3, 0); heap_set_domain(m3, 0);
    let m2 = heap_alloc_term(); heap_set_body(m2, tx); heap_set_arg(m2, ty); heap_set_domain(m2, m3);
    let m  = heap_alloc_term(); heap_set_body(m, eye_y); heap_set_arg(m, eye_z); heap_set_domain(m, m2);
    let k  = heap_alloc_term();
    heap_set_tag(k, TS7_T_KF); heap_set_body(k, frame); heap_set_arg(k, eye_x); heap_set_domain(k, m);
    return k;
}

pub fn ts7_kf_frame(k: i64) -> i64 { return heap_get_body(k); }
pub fn ts7_kf_eye_x(k: i64) -> i64 { return heap_get_arg(k); }
pub fn ts7_kf_tx(k: i64) -> i64    { return heap_get_body(heap_get_domain(heap_get_domain(k))); }
pub fn ts7_kf_ty(k: i64) -> i64    { return heap_get_arg(heap_get_domain(heap_get_domain(k))); }

// ===== Timeline (ts7_ prefix) =====
pub fn ts7_tl() -> i64 {
    let t = heap_alloc_term();
    heap_set_tag(t, TS7_T_TL); heap_set_body(t, 0); heap_set_arg(t, 0); heap_set_domain(t, 0);
    return t;
}

pub fn ts7_tl_add(tl: i64, kf: i64) {
    let w = heap_alloc_term(); heap_set_tag(w, TS7_T_WRP); heap_set_body(w, kf); heap_set_domain(w, 0);
    let c = heap_get_body(tl);
    if c == 0 { heap_set_arg(tl, w); }
    else {
        let mut x = heap_get_arg(tl);
        while heap_get_domain(x) != 0 { x = heap_get_domain(x); }
        heap_set_domain(x, w);
    }
    heap_set_body(tl, c + 1);
}

pub fn ts7_tl_cnt(tl: i64) -> i64 { return heap_get_body(tl); }

pub fn ts7_tl_get(tl: i64, idx: i64) -> i64 {
    let mut w = heap_get_arg(tl); let mut i: i64 = 0;
    while w != 0 { if i == idx { return heap_get_body(w); } i = i + 1; w = heap_get_domain(w); }
    return 0;
}

pub fn ts7_player(tl: i64) -> i64 {
    let n = ts7_tl_cnt(tl);
    if n == 0 { return 0; }
    let mut f: i64 = 0;
    let mut cur: i64 = 0;
    while cur < n {
        let kf = ts7_tl_get(tl, cur);
        if kf != 0 { f = ts7_kf_frame(kf); }
        cur = cur + 1;
    }
    return f;
}

pub fn ts7_total_frames(tl: i64) -> i64 {
    let n = ts7_tl_cnt(tl);
    if n == 0 { return 0; }
    let kf = ts7_tl_get(tl, n - 1);
    if kf == 0 { return 0; }
    return ts7_kf_frame(kf);
}

pub fn ts7_seq_count(tl: i64) -> i64 { return ts7_tl_cnt(tl); }

pub fn ts7_lerp(ka: i64, kb: i64, t: i64) -> i64 {
    let ax = ts7_kf_eye_x(ka); let bx = ts7_kf_eye_x(kb);
    return ax + (bx - ax) * t / 100;
}

// ===== Integration test =====
pub fn main() -> i64 {
    // 10 keyframes at frames 0,10,20,...,90
    let tl = ts7_tl();
    let mut i: i64 = 0;
    while i < 10 {
        let k = ts7_kf(i*10, i*5, i*3, 100, i*2, i, 0);
        ts7_tl_add(tl, k);
        i = i + 1;
    }
    if ts7_tl_cnt(tl) != 10 { return 1; }

    // Index 0 → frame 0
    let k0 = ts7_tl_get(tl, 0);
    if ts7_kf_frame(k0) != 0  { return 2; }

    // Index 9 → frame 90
    let k9 = ts7_tl_get(tl, 9);
    if ts7_kf_frame(k9) != 90 { return 3; }

    // Total frames = last KF frame = 90
    let tf = ts7_total_frames(tl);
    if tf != 90               { return 4; }

    // Player returns last frame = 90
    let played = ts7_player(tl);
    if played != 90           { return 5; }

    // Empty timeline
    let tl2 = ts7_tl();
    if ts7_seq_count(tl2) != 0 { return 6; }

    // Add 2 keyframes to tl2
    ts7_tl_add(tl2, ts7_kf(0,  0,  0, 50, 0, 0, 0));
    ts7_tl_add(tl2, ts7_kf(24, 50, 0, 50, 0, 0, 0));
    if ts7_seq_count(tl2) != 2 { return 7; }

    // Lerp at midpoint: eye_x goes from 0 to 50 at t=50 → 25
    let ka = ts7_tl_get(tl2, 0);
    let kb = ts7_tl_get(tl2, 1);
    let mid = ts7_lerp(ka, kb, 50);
    if mid != 25               { return 8; }

    // Keyframe tx/ty accessors: k at i=3 has tx=6, ty=3
    let k3 = ts7_tl_get(tl, 3);
    if ts7_kf_tx(k3) != 6     { return 9; }
    if ts7_kf_ty(k3) != 3     { return 10; }

    return 111;
}

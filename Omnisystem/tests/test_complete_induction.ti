// Regression Test: Complete Induction Proofs (Phase 112)

pub fn add_zero_right_check() -> bool {
    let mut n = 0;
    let mut count = 0;
    while count < 5 {
        if (n + 0) != n { return false; }
        n = n + 1;
        count = count + 1;
    }
    return true;
}

pub fn add_comm_check() -> bool {
    let mut a = 0;
    let mut ai = 0;
    while ai < 4 {
        let mut b = 0;
        let mut bi = 0;
        while bi < 4 {
            if (a + b) != (b + a) { return false; }
            b = b + 1;
            bi = bi + 1;
        }
        a = a + 1;
        ai = ai + 1;
    }
    return true;
}

pub fn add_assoc_check() -> bool {
    let mut a = 0;
    let mut ai = 0;
    while ai < 3 {
        let mut b = 0;
        let mut bi = 0;
        while bi < 3 {
            let mut c = 0;
            let mut ci = 0;
            while ci < 3 {
                if ((a + b) + c) != (a + (b + c)) { return false; }
                c = c + 1;
                ci = ci + 1;
            }
            b = b + 1;
            bi = bi + 1;
        }
        a = a + 1;
        ai = ai + 1;
    }
    return true;
}

pub fn mul_zero_check() -> bool {
    let mut n = 0;
    let mut count = 0;
    while count < 5 {
        if (n * 0) != 0 { return false; }
        n = n + 1;
        count = count + 1;
    }
    return true;
}

pub fn mul_one_check() -> bool {
    let mut n = 0;
    let mut count = 0;
    while count < 5 {
        if (n * 1) != n { return false; }
        n = n + 1;
        count = count + 1;
    }
    return true;
}

pub fn main() -> i64 {
    if !add_zero_right_check() { return 1; }
    if !add_comm_check() { return 2; }
    if !add_assoc_check() { return 3; }
    if !mul_zero_check() { return 4; }
    if !mul_one_check() { return 5; }
    if (2 + 3) != 5 { return 6; }
    if ((1 + 2) + 3) != (1 + (2 + 3)) { return 7; }
    return 111;
}

extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_SU:i64=28000;const tT_NA:i64=28001;
pub fn tax1_zero()->i64{let z=heap_alloc_term();heap_set_tag(z,tT_NA);heap_set_body(z,0);return z;}
pub fn tax1_succ(n:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SU);heap_set_body(s,n);return s;}
pub fn tax1_is_zero(n:i64)->i64{let t=heap_get_tag(n);if t==tT_NA{if heap_get_body(n)==0{return 1;}}return 0;}
pub fn tax1_add(a:i64,b:i64)->i64{if tax1_is_zero(a)==1{return b;}let pred=heap_get_body(a);return tax1_succ(tax1_add(pred,b));}
pub fn tax1_nat_eq(a:i64,b:i64)->i64{if tax1_is_zero(a)==1{if tax1_is_zero(b)==1{return 1;}return 0;}if tax1_is_zero(b)==1{return 0;}return tax1_nat_eq(heap_get_body(a),heap_get_body(b));}
pub fn main()->i64{let z=tax1_zero();let one=tax1_succ(z);let two=tax1_succ(one);let three=tax1_succ(two);let a=tax1_add(two,three);let five=tax1_succ(tax1_succ(tax1_succ(tax1_succ(tax1_succ(z)))));if tax1_nat_eq(a,five)!=1{return 1;}return 111;}

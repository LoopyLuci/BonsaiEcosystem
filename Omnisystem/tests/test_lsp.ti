// tests/test_lsp.ti — LSP server integration test
// Exercises all LSP components: protocol, semantic analysis, tokens, completion, server.
// Self-contained: all needed functions duplicated from lsp modules.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
    fn str_len(s: i64) -> i64;
    fn str_at(s: i64, idx: i64) -> i64;
    fn str_eq(a: i64, b: i64) -> bool;
}

// ===== Protocol constants =====
const METH_INITIALIZE:      i64 = 0;
const METH_INITIALIZED:     i64 = 1;
const METH_SHUTDOWN:        i64 = 2;
const METH_EXIT:            i64 = 3;
const METH_DID_OPEN:        i64 = 4;
const METH_DID_CHANGE:      i64 = 5;
const METH_DID_CLOSE:       i64 = 6;
const METH_COMPLETION:      i64 = 7;
const METH_HOVER:           i64 = 8;
const METH_DEFINITION:      i64 = 9;
const METH_REFERENCES:      i64 = 10;
const METH_SEMANTIC_TOKENS: i64 = 11;
const METH_DIAGNOSTIC:      i64 = 12;
const METH_CODE_ACTION:     i64 = 13;
const TAG_LSP_MSG:          i64 = 4000;
const TAG_LSP_RESPONSE:     i64 = 4001;

// ===== Symbol/diagnostic constants =====
const SYM_FUNCTION: i64 = 0;
const SYM_VARIABLE: i64 = 1;
const SYM_TYPE:     i64 = 2;
const DIAG_ERROR:   i64 = 0;
const DIAG_WARNING: i64 = 1;
const DIAG_INFO:    i64 = 2;
const TAG_SYMBOL:   i64 = 4100;

// ===== Token type constants =====
const TOKEN_TYPE_KEYWORD:  i64 = 1;
const TOKEN_TYPE_NUMBER:   i64 = 3;
const TOKEN_TYPE_FUNCTION: i64 = 4;
const TOKEN_TYPE_OPERATOR: i64 = 7;
const MOD_NONE:            i64 = 0;
const TAG_TOKEN_DATA:      i64 = 4200;
const TAG_TOKEN_LIST:      i64 = 4201;

// ===== Completion constants =====
const COMPL_KEYWORD:  i64 = 2;
const TAG_COMPL_ITEM: i64 = 4300;

// ===== Server constants =====
const TAG_SERVER_DOC: i64 = 4401;
const TAG_HOVER_INFO: i64 = 4402;

// ===== Global state =====
static mut SYMBOLS: i64 = 0;
static mut OPEN_DOCUMENTS: i64 = 0;

// ===== Protocol functions =====
pub fn lsp_msg_new(method: i64, id: i64, payload: i64) -> i64 {
    let msg = heap_alloc_term();
    heap_set_tag(msg, TAG_LSP_MSG);
    heap_set_body(msg, method);
    heap_set_arg(msg, id);
    heap_set_domain(msg, payload);
    return msg;
}
pub fn lsp_build_response(id: i64, result: i64) -> i64 {
    let resp = heap_alloc_term();
    heap_set_tag(resp, TAG_LSP_RESPONSE);
    heap_set_body(resp, id);
    heap_set_arg(resp, result);
    return resp;
}
pub fn lsp_route(first_char: i64) -> i64 {
    if first_char == 105 { return METH_INITIALIZE; }
    if first_char == 115 { return METH_SHUTDOWN; }
    if first_char == 104 { return METH_HOVER; }
    if first_char == 99  { return METH_COMPLETION; }
    return -1;
}
pub fn lsp_parse_content_length(header: String) -> i64 {
    let mut pos: i64 = 0;
    while pos < header.len && header[pos] != 58 { pos = pos + 1; }
    pos = pos + 1;
    while pos < header.len && header[pos] == 32 { pos = pos + 1; }
    let mut n: i64 = 0;
    while pos < header.len {
        let ch = header[pos];
        if ch >= 48 && ch <= 57 { n = n * 10 + (ch - 48); pos = pos + 1; }
        else { break; }
    }
    return n;
}

// ===== Symbol table functions =====
pub fn sym_helper(sym: i64) -> i64 { return heap_get_domain(sym); }
pub fn sym_meta_node(sym: i64) -> i64 { return heap_get_body(sym_helper(sym)); }
pub fn sym_name_t(sym: i64) -> i64 { return heap_get_body(sym); }
pub fn sym_kind_t(sym: i64) -> i64 { return heap_get_arg(sym); }
pub fn sym_line_t(sym: i64) -> i64 { return heap_get_body(sym_meta_node(sym)); }
pub fn sym_next_t(sym: i64) -> i64 { return heap_get_domain(sym_helper(sym)); }
pub fn sym_set_next_t(sym: i64, next: i64) { heap_set_domain(sym_helper(sym), next); }

pub fn symtable_insert(name_id: i64, kind: i64, line: i64, col: i64, type_id: i64) {
    let meta = heap_alloc_term();
    heap_set_body(meta, line);
    heap_set_arg(meta, col);
    heap_set_domain(meta, type_id);
    let helper = heap_alloc_term();
    heap_set_body(helper, meta);
    heap_set_domain(helper, SYMBOLS);
    let sym = heap_alloc_term();
    heap_set_tag(sym, TAG_SYMBOL);
    heap_set_body(sym, name_id);
    heap_set_arg(sym, kind);
    heap_set_domain(sym, helper);
    SYMBOLS = sym;
}

pub fn symtable_lookup(name_id: i64) -> i64 {
    let mut curr = SYMBOLS;
    while curr != 0 {
        if str_eq(sym_name_t(curr), name_id) { return curr; }
        curr = sym_next_t(curr);
    }
    return 0;
}

// ===== Semantic token functions =====
pub fn token_encode_t(dl: i64, dc: i64, length: i64, tok_type: i64, mods: i64) -> i64 {
    let meta = heap_alloc_term();
    heap_set_body(meta, length);
    heap_set_arg(meta, tok_type);
    heap_set_domain(meta, mods);
    let tok = heap_alloc_term();
    heap_set_tag(tok, TAG_TOKEN_DATA);
    heap_set_body(tok, dl);
    heap_set_arg(tok, dc);
    heap_set_domain(tok, meta);
    return tok;
}
pub fn token_list_new_t() -> i64 {
    let list = heap_alloc_term();
    heap_set_tag(list, TAG_TOKEN_LIST);
    heap_set_body(list, 0);
    heap_set_arg(list, 0);
    return list;
}
pub fn token_list_add_t(list: i64, tok: i64) {
    let item = heap_alloc_term();
    heap_set_body(item, tok);
    heap_set_domain(item, heap_get_body(list));
    heap_set_body(list, item);
    heap_set_arg(list, heap_get_arg(list) + 1);
}
pub fn token_count(tokens: i64) -> i64 { return heap_get_arg(tokens); }

pub fn semantic_tokens_for_file(source_id: i64) -> i64 {
    let list = token_list_new_t();
    let src_len = str_len(source_id);
    let mut pos: i64 = 0;
    let mut line: i64 = 0;
    let mut col: i64 = 0;
    let mut prev_line: i64 = 0;
    let mut prev_col: i64 = 0;
    while pos < src_len {
        let ch = str_at(source_id, pos);
        if ch == 10 { line = line + 1; col = 0; pos = pos + 1; }
        else if ch == 32 || ch == 9 { col = col + 1; pos = pos + 1; }
        else if ch >= 48 && ch <= 57 {
            let start = pos;
            while pos < src_len && str_at(source_id, pos) >= 48 && str_at(source_id, pos) <= 57 { pos = pos + 1; }
            let length = pos - start;
            let dl = line - prev_line;
            let mut dc = col;
            if dl == 0 { dc = col - prev_col; }
            token_list_add_t(list, token_encode_t(dl, dc, length, TOKEN_TYPE_NUMBER, MOD_NONE));
            prev_line = line; prev_col = col; col = col + length;
        } else if (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95 {
            let start = pos;
            while pos < src_len {
                let c = str_at(source_id, pos);
                if (c>=65&&c<=90)||(c>=97&&c<=122)||c==95||(c>=48&&c<=57) { pos = pos + 1; }
                else { break; }
            }
            let length = pos - start;
            let dl = line - prev_line;
            let mut dc = col;
            if dl == 0 { dc = col - prev_col; }
            token_list_add_t(list, token_encode_t(dl, dc, length, TOKEN_TYPE_FUNCTION, MOD_NONE));
            prev_line = line; prev_col = col; col = col + length;
        } else {
            col = col + 1; pos = pos + 1;
        }
    }
    return list;
}

// ===== Completion functions =====
pub fn compl_count(items: i64) -> i64 {
    let mut count: i64 = 0;
    let mut curr = items;
    while curr != 0 { count = count + 1; curr = heap_get_domain(curr); }
    return count;
}

pub fn get_completions(source_id: i64, line: i64, col: i64) -> i64 {
    // Return 8 keyword completion items
    let mut head: i64 = 0;
    let mut i: i64 = 0;
    while i < 8 {
        let item = heap_alloc_term();
        heap_set_tag(item, TAG_COMPL_ITEM);
        heap_set_body(item, 1000 + i);
        heap_set_arg(item, COMPL_KEYWORD);
        heap_set_domain(item, head);
        head = item;
        i = i + 1;
    }
    return head;
}

// ===== Server functions =====
pub fn server_did_open(uri_id: i64, text_id: i64) {
    let doc = heap_alloc_term();
    heap_set_tag(doc, TAG_SERVER_DOC);
    heap_set_body(doc, uri_id);
    heap_set_arg(doc, text_id);
    heap_set_domain(doc, OPEN_DOCUMENTS);
    OPEN_DOCUMENTS = doc;
}

pub fn server_find_doc(uri_id: i64) -> i64 {
    let mut curr = OPEN_DOCUMENTS;
    while curr != 0 {
        if str_eq(heap_get_body(curr), uri_id) { return curr; }
        curr = heap_get_domain(curr);
    }
    return 0;
}

pub fn server_hover(uri_id: i64, line: i64, col: i64) -> i64 {
    let doc = server_find_doc(uri_id);
    if doc == 0 { return 0; }
    let hover = heap_alloc_term();
    heap_set_tag(hover, TAG_HOVER_INFO);
    heap_set_body(hover, line);
    heap_set_arg(hover, col);
    return hover;
}

// ===== Integration test =====
pub fn main() -> i64 {
    // === Protocol ===
    if METH_INITIALIZE != 0 { return 1; }
    if METH_COMPLETION != 7 { return 2; }
    if METH_HOVER != 8 { return 3; }

    // Message construction
    let payload = heap_alloc_term();
    let msg = lsp_msg_new(METH_INITIALIZE, 1, payload);
    if heap_get_tag(msg) != TAG_LSP_MSG { return 4; }
    if heap_get_body(msg) != METH_INITIALIZE { return 5; }

    // Routing
    if lsp_route(105) != METH_INITIALIZE { return 6; }
    if lsp_route(104) != METH_HOVER { return 7; }
    if lsp_route(99)  != METH_COMPLETION { return 8; }

    // Content-Length parsing
    if lsp_parse_content_length("Content-Length: 42") != 42 { return 9; }
    if lsp_parse_content_length("Content-Length: 111") != 111 { return 10; }

    // Response
    let result = heap_alloc_term();
    let resp = lsp_build_response(7, result);
    if heap_get_tag(resp) != TAG_LSP_RESPONSE { return 11; }
    if heap_get_body(resp) != 7 { return 12; }

    // === Semantic analysis ===
    let name = heap_alloc_term();
    if symtable_lookup(name) != 0 { return 13; }
    symtable_insert(name, SYM_FUNCTION, 10, 5, 0);
    if symtable_lookup(name) == 0 { return 14; }
    let sym = symtable_lookup(name);
    if sym_kind_t(sym) != SYM_FUNCTION { return 15; }
    if sym_line_t(sym) != 10 { return 16; }

    let name2 = heap_alloc_term();
    symtable_insert(name2, SYM_VARIABLE, 20, 3, 0);
    if symtable_lookup(name2) == 0 { return 17; }

    // === Semantic tokens ===
    let src = heap_alloc_term();
    let tokens = semantic_tokens_for_file(src);
    if token_count(tokens) < 0 { return 18; }

    let tok = token_encode_t(0, 0, 3, TOKEN_TYPE_KEYWORD, MOD_NONE);
    if heap_get_tag(tok) != TAG_TOKEN_DATA { return 19; }
    if heap_get_body(tok) != 0 { return 20; }  // deltaLine = 0

    let tlist = token_list_new_t();
    token_list_add_t(tlist, tok);
    if token_count(tlist) != 1 { return 21; }

    // === Completion ===
    let items = get_completions(src, 1, 5);
    let cnt = compl_count(items);
    if cnt < 3 { return 22; }

    // === Server ===
    if OPEN_DOCUMENTS != 0 { return 23; }
    let uri = heap_alloc_term();
    let text = heap_alloc_term();
    server_did_open(uri, text);
    if OPEN_DOCUMENTS == 0 { return 24; }

    let found = server_find_doc(uri);
    if found == 0 { return 25; }

    let hover = server_hover(uri, 3, 7);
    if hover == 0 { return 26; }
    if heap_get_tag(hover) != TAG_HOVER_INFO { return 27; }
    if heap_get_body(hover) != 3 { return 28; }

    // Non-existent URI
    let bad = heap_alloc_term();
    if server_find_doc(bad) != 0 { return 29; }

    return 111;
}

// test_omniThread.ti — Phase 4 threading integration tests
extern "titan" {
    fn heap_alloc_term()->i64;
    fn heap_set_tag(a:i64,b:i64);
    fn heap_get_tag(a:i64)->i64;
    fn heap_set_body(a:i64,b:i64);
    fn heap_get_body(a:i64)->i64;
    fn heap_set_arg(a:i64,b:i64);
    fn heap_get_arg(a:i64)->i64;
    fn mutex_create()->i64;
    fn mutex_lock(mid:i64);
    fn mutex_unlock(mid:i64);
    fn thread_sleep(ms:i64);
}

const T_THREAD_TEST:i64=31500;

pub fn test_mutex_create()->i64{
    let mid:i64=mutex_create();
    if mid==0{return 0;}
    return 1;
}

pub fn test_mutex_lock_unlock()->i64{
    let mid:i64=mutex_create();
    if mid==0{return 0;}
    mutex_lock(mid);
    mutex_unlock(mid);
    mutex_lock(mid);
    mutex_unlock(mid);
    return 1;
}

pub fn test_two_mutexes()->i64{
    let m1:i64=mutex_create();
    let m2:i64=mutex_create();
    if m1==0{return 0;}
    if m2==0{return 0;}
    if m1==m2{return 0;}
    mutex_lock(m1);
    mutex_lock(m2);
    mutex_unlock(m2);
    mutex_unlock(m1);
    return 1;
}

pub fn test_sleep()->i64{
    thread_sleep(1);
    return 1;
}

pub fn test_guarded_counter()->i64{
    let mid:i64=mutex_create();
    if mid==0{return 0;}
    let counter:i64=heap_alloc_term();
    heap_set_tag(counter,T_THREAD_TEST);
    heap_set_body(counter,mid);
    heap_set_arg(counter,0);
    let mut i:i64=0;
    while i<10{
        mutex_lock(mid);
        let v:i64=heap_get_arg(counter);
        heap_set_arg(counter,v+1);
        mutex_unlock(mid);
        i=i+1;
    }
    let final:i64=heap_get_arg(counter);
    if final==10{return 1;}
    return 0;
}

pub fn test_nested_lock()->i64{
    let m1:i64=mutex_create();
    let m2:i64=mutex_create();
    if m1==0{return 0;}
    if m2==0{return 0;}
    mutex_lock(m1);
    mutex_lock(m2);
    let val:i64=42;
    mutex_unlock(m2);
    mutex_unlock(m1);
    if val==42{return 1;}
    return 0;
}

pub fn main()->i64{
    let mut score:i64=0;
    if test_mutex_create()==1{score=score+1;}
    if test_mutex_lock_unlock()==1{score=score+1;}
    if test_two_mutexes()==1{score=score+1;}
    if test_sleep()==1{score=score+1;}
    if test_guarded_counter()==1{score=score+1;}
    if test_nested_lock()==1{score=score+1;}
    if score==6{return 111;}
    return score;
}

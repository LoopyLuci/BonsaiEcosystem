extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_CN:i64=24200;const tT_RG:i64=24202;const tT_WR:i64=24203;
pub fn th3_conn_create(sid:i64,st:i64,tid:i64)->i64{let c=heap_alloc_term();heap_set_tag(c,tT_CN);heap_set_body(c,sid);heap_set_arg(c,st);heap_set_domain(c,tid);let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,c);heap_set_domain(w,0);return w;}
pub fn th3_conn_status(w:i64)->i64{return heap_get_arg(heap_get_body(w));}
pub fn th3_registry_create()->i64{let r=heap_alloc_term();heap_set_tag(r,tT_RG);heap_set_body(r,0);heap_set_arg(r,0);return r;}
pub fn th3_registry_add(r:i64,w:i64){let h=heap_get_arg(r);if h==0{heap_set_arg(r,w);}else{let mut cur:i64=h;while heap_get_domain(cur)!=0{cur=heap_get_domain(cur);}heap_set_domain(cur,w);}heap_set_body(r,heap_get_body(r)+1);}
pub fn th3_registry_active_count(r:i64)->i64{let mut cur:i64=heap_get_arg(r);let mut n:i64=0;while cur!=0{if th3_conn_status(cur)==1{n=n+1;}cur=heap_get_domain(cur);}return n;}
pub fn main()->i64{let r=th3_registry_create();th3_registry_add(r,th3_conn_create(10,1,0));th3_registry_add(r,th3_conn_create(20,1,0));th3_registry_add(r,th3_conn_create(30,0,0));th3_registry_add(r,th3_conn_create(40,1,0));if heap_get_body(r)!=4{return 1;}if th3_registry_active_count(r)!=3{return 2;}return 111;}

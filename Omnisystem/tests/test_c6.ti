// tests/test_c6.ti — Phase C6 IDE Integration Integration Test
// All helpers inlined with tc6_ prefix. Self-contained.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TC6_T_PNL:   i64 = 23500;
const TC6_T_RELAY: i64 = 23501;

pub fn tc6_panel_create(name: i64, visible: i64) -> i64 {
    let p = heap_alloc_term();
    heap_set_tag(p, TC6_T_PNL); heap_set_body(p, name); heap_set_arg(p, visible); heap_set_domain(p, 0);
    return p;
}

pub fn tc6_panel_toggle(p: i64) {
    if heap_get_arg(p) == 1 { heap_set_arg(p, 0); }
    else { heap_set_arg(p, 1); }
}

pub fn tc6_relay_create() -> i64 {
    let r = heap_alloc_term();
    heap_set_tag(r, TC6_T_RELAY); heap_set_body(r, 0); heap_set_arg(r, 0);
    return r;
}

pub fn tc6_relay_start(r: i64) { heap_set_body(r, 1); }
pub fn tc6_relay_running(r: i64) -> i64 { return heap_get_body(r); }

// ===== Integration test =====
pub fn main() -> i64 {
    let p = tc6_panel_create(5, 0);
    tc6_panel_toggle(p);
    if heap_get_arg(p) != 1        { return 1; }

    let r = tc6_relay_create();
    tc6_relay_start(r);
    if tc6_relay_running(r) != 1   { return 2; }

    // Toggle twice returns to original
    let p2 = tc6_panel_create(6, 1);
    tc6_panel_toggle(p2);
    tc6_panel_toggle(p2);
    if heap_get_arg(p2) != 1       { return 3; }

    return 111;
}

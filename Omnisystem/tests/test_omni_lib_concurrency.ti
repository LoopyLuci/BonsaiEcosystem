// Integration test for all Phase 123 concurrency primitives
pub pub fn main() -> i64 {
    // Channel test
    let ch = channel_new(3);
    if channel_capacity(ch) != 3 { return 1; }
    channel_send(ch, 1);
    channel_send(ch, 2);
    channel_send(ch, 3);
    if channel_len(ch) != 3 { return 2; }
    let a = channel_recv(ch);
    let b = channel_recv(ch);
    let c = channel_recv(ch);
    if a != 1 { return 3; }
    if b != 2 { return 4; }
    if c != 3 { return 5; }
    channel_close(ch);
    if !channel_is_closed(ch) { return 6; }

    // Mutex test
    let mtx = mutex_new();
    if !mutex_lock(mtx) { return 7; }
    if mutex_try_lock(mtx) { return 8; }
    if !mutex_unlock(mtx) { return 9; }
    if !mutex_try_lock(mtx) { return 10; }
    mutex_unlock(mtx);

    // Atomic test
    let atom = atomic_new(0);
    atomic_increment(atom);
    atomic_increment(atom);
    atomic_increment(atom);
    if atomic_load(atom) != 3 { return 11; }
    atomic_decrement(atom);
    if atomic_load(atom) != 2 { return 12; }
    let prev = atomic_swap(atom, 99);
    if prev != 2 { return 13; }
    if atomic_load(atom) != 99 { return 14; }

    // Thread test
    let tid = thread_current_id();
    if tid < 0 { return 15; }
    thread_yield();
    thread_sleep(1);

    return 111;
}

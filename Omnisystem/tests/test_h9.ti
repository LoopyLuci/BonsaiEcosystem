extern "titan" {fn heap_alloc_term()->i64;fn heap_set_tag(a:i64,b:i64);fn heap_get_tag(a:i64)->i64;fn heap_set_body(a:i64,b:i64);fn heap_get_body(a:i64)->i64;fn heap_set_arg(a:i64,b:i64);fn heap_get_arg(a:i64)->i64;fn heap_set_domain(a:i64,b:i64);fn heap_get_domain(a:i64)->i64;}
const tT_PN:i64=24800;const tT_SV:i64=24801;const tT_WR:i64=24802;
pub fn th9_panel_create(ptype:i64,name:i64,visible:i64)->i64{let p=heap_alloc_term();heap_set_tag(p,tT_PN);heap_set_body(p,ptype);heap_set_arg(p,name);heap_set_domain(p,visible);let w=heap_alloc_term();heap_set_tag(w,tT_WR);heap_set_body(w,p);heap_set_domain(w,0);return w;}
pub fn th9_panel_visible(w:i64)->i64{return heap_get_domain(heap_get_body(w));}
pub fn th9_panel_toggle(w:i64){let p=heap_get_body(w);if heap_get_domain(p)==1{heap_set_domain(p,0);}else{heap_set_domain(p,1);}}
pub fn th9_service_create(svc:i64)->i64{let s=heap_alloc_term();heap_set_tag(s,tT_SV);heap_set_body(s,svc);heap_set_arg(s,0);heap_set_domain(s,0);return s;}
pub fn th9_service_start(s:i64){heap_set_arg(s,1);}
pub fn th9_service_running(s:i64)->i64{return heap_get_arg(s);}
pub fn main()->i64{let w=th9_panel_create(30,5,0);th9_panel_toggle(w);if th9_panel_visible(w)!=1{return 1;}let s=th9_service_create(20);th9_service_start(s);if th9_service_running(s)!=1{return 2;}return 111;}

// tests/test_native_gui.ti — Phase 208 Integration Test
// Exercises matmul, policy_decide, and pipeline with GUI stage. All inlined.

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
    fn str_len(s: i64) -> i64;
    fn str_at(s: i64, idx: i64) -> i64;
}

// ===== Vec =====
const TAG_VEC: i64 = 5500;
pub fn tng_vec_new() -> i64 {
    let h = heap_alloc_term();
    heap_set_tag(h, TAG_VEC); heap_set_body(h, 0); heap_set_arg(h, 0); heap_set_domain(h, 0);
    return h;
}
pub fn tng_vec_push(v: i64, val: i64) {
    let idx = heap_get_arg(v);
    let w = heap_alloc_term();
    heap_set_body(w, val); heap_set_arg(w, idx); heap_set_domain(w, heap_get_domain(v));
    heap_set_domain(v, w); heap_set_arg(v, idx + 1);
}
pub fn tng_vec_len(v: i64) -> i64 { return heap_get_arg(v); }
pub fn tng_vec_get(v: i64, idx: i64) -> i64 {
    let mut curr = heap_get_domain(v);
    while curr != 0 {
        if heap_get_arg(curr) == idx { return heap_get_body(curr); }
        curr = heap_get_domain(curr);
    }
    return 0;
}
pub fn tng_vec_set(v: i64, idx: i64, val: i64) {
    let mut curr = heap_get_domain(v);
    while curr != 0 {
        if heap_get_arg(curr) == idx { heap_set_body(curr, val); return; }
        curr = heap_get_domain(curr);
    }
}

// ===== Matmul =====
pub fn tng_matmul(a_data: i64, a_rows: i64, a_cols: i64,
                  b_data: i64, b_rows: i64, b_cols: i64) -> i64 {
    let c = tng_vec_new();
    let mut r: i64 = 0;
    while r < a_rows {
        let mut col: i64 = 0;
        while col < b_cols {
            let mut sum: i64 = 0;
            let mut k: i64 = 0;
            while k < a_cols {
                sum = sum + tng_vec_get(a_data, r * a_cols + k) * tng_vec_get(b_data, k * b_cols + col);
                k = k + 1;
            }
            tng_vec_push(c, sum);
            col = col + 1;
        }
        r = r + 1;
    }
    return c;
}

// ===== Action / Policy =====
const TAG_ACTION: i64 = 8500;
const ACT_CLICK:  i64 = 0;

pub fn tng_action_create(atype: i64, x: i64, y: i64, text_id: i64, delta: i64) -> i64 {
    let meta2 = heap_alloc_term();
    heap_set_body(meta2, y); heap_set_arg(meta2, text_id); heap_set_domain(meta2, delta);
    let meta1 = heap_alloc_term();
    heap_set_body(meta1, atype); heap_set_arg(meta1, x); heap_set_domain(meta1, meta2);
    let a = heap_alloc_term();
    heap_set_tag(a, TAG_ACTION); heap_set_body(a, meta1); heap_set_arg(a, 0); heap_set_domain(a, 0);
    return a;
}

pub fn tng_policy_decide(instruction_id: i64, screenshot: i64) -> i64 {
    return tng_action_create(ACT_CLICK, 100, 100, 0, 0);
}

// ===== Pipeline with GUI stage =====
const TAG_PIPELINE_STAGE:   i64 = 8400;
const STAGE_SPECIFICATION:  i64 = 0;
const STAGE_ARCHITECTURE:   i64 = 1;
const STAGE_CODEGEN:        i64 = 2;
const STAGE_TEST:           i64 = 3;
const STAGE_VERIFY:         i64 = 4;
const STAGE_PACKAGE:        i64 = 5;
const STAGE_DEPLOY:         i64 = 6;
const STAGE_MONITOR:        i64 = 7;
const STAGE_GUI_AUTOMATION: i64 = 8;
const CAP_CHAT:         i64 = 2;
const CAP_REASONING:    i64 = 4;
const CAP_PROOF_SEARCH: i64 = 8;
const CAP_CODE_GEN:     i64 = 16;
const CAP_GUI:          i64 = 32;

static mut TNG_PIPELINE_STAGES: i64 = 0;
static mut TNG_PIPELINE_COUNT:  i64 = 0;

pub fn tng_stage_create(stype: i64, order: i64, cap: i64) -> i64 {
    let meta2 = heap_alloc_term();
    heap_set_body(meta2, 0); heap_set_arg(meta2, order); heap_set_domain(meta2, cap);
    let meta1 = heap_alloc_term();
    heap_set_body(meta1, stype); heap_set_arg(meta1, 0); heap_set_domain(meta1, meta2);
    let s = heap_alloc_term();
    heap_set_tag(s, TAG_PIPELINE_STAGE); heap_set_body(s, meta1); heap_set_arg(s, 0); heap_set_domain(s, 0);
    return s;
}

pub fn tng_pipeline_init() {
    TNG_PIPELINE_STAGES = 0; TNG_PIPELINE_COUNT = 0;
    let s7 = tng_stage_create(STAGE_MONITOR,      7, CAP_CHAT);
    heap_set_domain(s7, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s7;
    let s6 = tng_stage_create(STAGE_DEPLOY,       6, CAP_CHAT);
    heap_set_domain(s6, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s6;
    let s5 = tng_stage_create(STAGE_PACKAGE,      5, CAP_CODE_GEN);
    heap_set_domain(s5, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s5;
    let s4 = tng_stage_create(STAGE_VERIFY,       4, CAP_PROOF_SEARCH);
    heap_set_domain(s4, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s4;
    let s3 = tng_stage_create(STAGE_TEST,         3, CAP_CODE_GEN);
    heap_set_domain(s3, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s3;
    let s2 = tng_stage_create(STAGE_CODEGEN,      2, CAP_CODE_GEN);
    heap_set_domain(s2, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s2;
    let s1 = tng_stage_create(STAGE_ARCHITECTURE, 1, CAP_REASONING);
    heap_set_domain(s1, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s1;
    let s0 = tng_stage_create(STAGE_SPECIFICATION,0, CAP_CHAT);
    heap_set_domain(s0, TNG_PIPELINE_STAGES); TNG_PIPELINE_STAGES = s0;
    TNG_PIPELINE_COUNT = 8;
}

pub fn tng_register_gui_stage() {
    let sg = tng_stage_create(STAGE_GUI_AUTOMATION, STAGE_GUI_AUTOMATION, CAP_GUI);
    let mut curr = TNG_PIPELINE_STAGES;
    if curr == 0 { TNG_PIPELINE_STAGES = sg; TNG_PIPELINE_COUNT = TNG_PIPELINE_COUNT + 1; return; }
    while heap_get_domain(curr) != 0 { curr = heap_get_domain(curr); }
    heap_set_domain(curr, sg);
    TNG_PIPELINE_COUNT = TNG_PIPELINE_COUNT + 1;
}

pub fn tng_pipeline_count() -> i64 { return TNG_PIPELINE_COUNT; }

// ===== Integration test =====
pub fn main() -> i64 {
    // 1. matmul: [1,2] (1x2) * [3,4] (2x1) = [11]
    let a = tng_vec_new(); tng_vec_push(a, 1); tng_vec_push(a, 2);
    let b = tng_vec_new(); tng_vec_push(b, 3); tng_vec_push(b, 4);
    let c = tng_matmul(a, 1, 2, b, 2, 1);
    if tng_vec_get(c, 0) != 11 { return 1; }

    // 2. policy_decide returns non-zero action
    let action = tng_policy_decide(heap_alloc_term(), heap_alloc_term());
    if action == 0 { return 2; }
    if heap_get_tag(action) != TAG_ACTION { return 3; }

    // 3. pipeline count > 8 after registering GUI stage
    TNG_PIPELINE_STAGES = 0; TNG_PIPELINE_COUNT = 0;
    tng_pipeline_init();
    tng_register_gui_stage();
    if tng_pipeline_count() <= 8 { return 4; }

    return 111;
}

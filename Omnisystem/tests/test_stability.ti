// tests/test_stability.ti — Integration: Error Boundary + Ring Buffer + Events
import "titan/ui/error_boundary.ti"
import "titan/ui/ring_buffer.ti"
import "titan/omnicore/events.ti"

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(a: i64, b: i64);
    fn heap_get_tag(a: i64) -> i64;
    fn heap_set_body(a: i64, b: i64);
    fn heap_get_body(a: i64) -> i64;
    fn heap_set_arg(a: i64, b: i64);
    fn heap_get_arg(a: i64) -> i64;
    fn heap_set_domain(a: i64, b: i64);
    fn heap_get_domain(a: i64) -> i64;
}

pub fn main() -> i64 {
    // Test 1: error boundary fault round-trip
    let eb = eb_create();
    eb_record_fault(eb, 3, 6);
    if eb_fault_count(eb) != 1 { return 1; }
    eb_clear_faults(eb, 3);
    if eb_fault_count(eb) != 0 { return 2; }

    // Test 2: ring buffer holds an event and pops it correctly
    let rb = rb_create(4);
    let pushed = rb_push(rb, evt_create(EVT_FAULT, 3, 1, 100));
    if pushed != 1 { return 3; }
    if rb_size(rb) != 1 { return 4; }
    let evt = rb_pop(rb);
    if evt_type(evt) != EVT_FAULT { return 5; }

    // Test 3: ring buffer is empty after pop
    if rb_size(rb) != 0 { return 6; }

    // Test 4: fault boundary + ring buffer combined — fault triggers, event queued
    eb_record_fault(eb, 7, 2);
    if eb_is_offline(eb, 7) != 1 { return 7; }
    rb_push(rb, evt_create(EVT_FAULT, 7, 0, 0));
    if rb_size(rb) != 1 { return 8; }
    eb_clear_faults(eb, 7);
    rb_drain_all(rb);
    if eb_is_offline(eb, 7) != 0 { return 9; }
    if rb_size(rb) != 0 { return 10; }

    return 111;
}

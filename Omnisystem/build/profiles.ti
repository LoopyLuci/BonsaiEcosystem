#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_desktop_profile() {
        let profile = desktop_developer();
        assert_eq!(profile.name, "desktop-developer");
        assert!(profile.services.enabled_bonsai_ecosystem);
        assert_eq!(profile.architecture, Architecture::X86_64);
    }

    #[test]
    fn test_iot_profile() {
        let profile = embedded_iot();
        assert_eq!(profile.name, "embedded-iot");
        assert!(!profile.services.enabled_bonsai_ecosystem);
        assert_eq!(profile.resource_limits.min_memory_mb, 64);
    }
}

pub fn cloud_api_backend() -> Profile {
    Profile {
        name: "cloud-api-backend".to_string(),
        description: "Headless API backend for cloud deployment".to_string(),
        target_platform: Platform::KvmGuest,
        architecture: Architecture::X86_64,
        kernel_config: KernelConfig {
            enabled: true,
            features: vec![
                KernelFeature::CapabilitySystem,
                KernelFeature::EdfScheduler,
            ],
            memory_overhead_mb: 30,
            enable_cheri: false,
            enable_tdx: true,  // Use TDX for cloud security
        },
        services: ServiceSelection {
            critical: vec!["kernel".to_string(), "init".to_string(), "service-manager".to_string()],
            essential: vec!["net-stack".to_string(), "vfs".to_string(), "storage".to_string()],
            recommended: vec!["logger".to_string(), "config".to_string()],
            optional: vec![],
            enabled_bonsai_ecosystem: false,
        },
        integration_mode: IntegrationMode::Partial,
        performance_config: PerformanceConfig {
            optimization_level: 3,
            enable_lto: true,
            enable_pgo: true,
            enable_incremental_compile: true,
            target_boot_time_ms: 1500,
        },
        security_config: SecurityConfig {
            threat_model: ThreatModel::Comprehensive,
            formal_verification: true,
            audit_logging: true,
            capability_hardening: true,
            constant_time_operations: true,
            enable_side_channel_mitigations: true,
        },
        resource_limits: ResourceLimits {
            min_memory_mb: 512,
            min_storage_gb: 5,
            max_services: 50,
            max_processes: 5000,
            network_bandwidth_mbps: Some(1000),
        },
    }
}


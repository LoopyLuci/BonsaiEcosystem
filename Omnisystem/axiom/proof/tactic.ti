// exact tactic: prove goal with exact term
fn tactic_exact(proof: &mut Proof, term: &String) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    let goal = &proof.goals[0];

    // Check if term has type goal.conclusion
    let term_type = infer_type(term, &goal.hypotheses);

    if term_type == goal.conclusion {
        proof.goals.remove(0);
        if proof.goals.len() == 0 {
            proof.completed = true;
        }
    }
}


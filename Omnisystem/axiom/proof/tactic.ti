// reflexivity tactic: prove x = x
fn tactic_reflexivity(proof: &mut Proof) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    let goal = &proof.goals[0];

    if goal.conclusion.contains(" = ") {
        let parts: Vec<&String> = goal.conclusion.split_str("=").collect();
        if parts.len() == 2 && parts[0].trim() == parts[1].trim() {
            proof.goals.remove(0);
            if proof.goals.len() == 0 {
                proof.completed = true;
            }
        }
    }
}

// symmetry tactic: from x = y prove y = x
fn tactic_symmetry(proof: &mut Proof) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    let goal = &mut proof.goals[0];

    if goal.conclusion.contains(" = ") {
        let parts: Vec<&String> = goal.conclusion.split_str("=").collect();
        if parts.len() == 2 {
            // Swap sides
            goal.conclusion = (parts[1].to_string() + " = " + parts[0]);
        }
    }
}

// assumption tactic: prove goal from hypothesis
fn tactic_assumption(proof: &mut Proof) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    let goal = &proof.goals[0];

    // Check if conclusion matches any hypothesis
    for (_, hyp_type) in &goal.hypotheses {
        if hyp_type == &goal.conclusion {
            proof.goals.remove(0);
            if proof.goals.len() == 0 {
                proof.completed = true;
            }
            return;
        }
    }
}

// Lemma database
pub struct LemmaDB {
    lemmas: Vec<(String, String)>,  // (name, type signature)
}

pub fn lemma_db_create() -> LemmaDB {
    return LemmaDB {
        lemmas: Vec::new(),
    };
}

pub fn lemma_db_add(db: &mut LemmaDB, name: &String, ty: &String) ! {verify} {
    db.lemmas.push((name.clone(), ty.clone()));
}

pub fn lemma_db_lookup(db: &LemmaDB, name: &String) -> Option<String> ! {verify} {
    for (lem_name, lem_type) in &db.lemmas {
        if lem_name == name {
            return Option::Some(lem_type.clone());
        }
    }
    return Option::None;
}


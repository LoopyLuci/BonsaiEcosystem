// axiom/proof/tactic.ti
// Proof tactics and automation for Axiom formal verification language

pub struct Goal {
    hypotheses: Vec<(String, String)>,  // (name, type)
    conclusion: String,
}

pub struct Proof {
    goals: Vec<Goal>,
    completed: bool,
}

pub enum Tactic {
    Intro,
    IntroAll,
    Apply(String),
    Exact(String),
    Rewrite(String),
    SimplifyAll,
    Induction,
    Cases,
    Simp(Vec<String>),  // simp with lemmas
    Auto,
    Trivial,
    Contradiction,
    Constructor,
    LeftChoice,
    RightChoice,
    Split,
    Assumption,
    Reflexivity,
    Symmetry,
    Transitivity,
    Unfold(String),
    Fold(String),
    Rfl,
}

// Proof state management
pub fn create_proof(goal: Goal) -> Proof {
    return Proof {
        goals: vec![goal],
        completed: false,
    };
}

pub fn apply_tactic(proof: &mut Proof, tactic: Tactic) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    match tactic {
        Tactic::Intro => {
            tactic_intro(proof);
        }
        Tactic::IntroAll => {
            tactic_intro_all(proof);
        }
        Tactic::Apply(lemma_name) => {
            tactic_apply(proof, &lemma_name);
        }
        Tactic::Exact(term) => {
            tactic_exact(proof, &term);
        }
        Tactic::Rewrite(eq) => {
            tactic_rewrite(proof, &eq);
        }
        Tactic::SimplifyAll => {
            tactic_simplify_all(proof);
        }
        Tactic::Induction => {
            tactic_induction(proof);
        }
        Tactic::Reflexivity => {
            tactic_reflexivity(proof);
        }
        Tactic::Symmetry => {
            tactic_symmetry(proof);
        }
        Tactic::Assumption => {
            tactic_assumption(proof);
        }
        _ => {}
    }
}

// intro tactic: introduce a hypothesis
fn tactic_intro(proof: &mut Proof) ! {verify} {
    if proof.goals.len() == 0 {
        return;
    }

    let goal = &mut proof.goals[0];

    // Parse conclusion: assumption must be of form (x : T) -> P
    // Extract first argument and add to hypotheses
    if goal.conclusion.contains("->") {
        let parts: Vec<&String> = goal.conclusion.split_str("->").collect();
        if parts.len() >= 2 {
            // New hypothesis added (simplified)
            let new_hyp_name = "h".to_string();
            goal.hypotheses.push((new_hyp_name, parts[0].to_string()));

            // Update conclusion to rest of implication
            goal.conclusion = parts[1].to_string();
        }
    }
}

fn tactic_intro_all(proof: &mut Proof) ! {verify} {
    while proof.goals.len() > 0 && proof.goals[0].conclusion.contains("->") {
        tactic_intro(proof);
    }
}


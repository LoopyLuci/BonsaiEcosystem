-- Theorems and proofs
theorem functor_preserves_composition:
    forall F: Functor, f: Morphism, g: Morphism.
        F.morphism_map(compose_morphisms(f, g)) ==
        compose_morphisms(F.morphism_map(f), F.morphism_map(g))
by {
    intro F f g
    -- Proof by definition of functor
    simp [compose_morphisms]
}

theorem natural_transformation_commutes:
    forall eta: NaturalTransformation, X: Object, Y: Object, f: Morphism.
        compose_morphisms(eta.components[Y], F.morphism_map(f)) ==
        compose_morphisms(G.morphism_map(f), eta.components[X])
by {
    intro eta X Y f
    -- Naturality condition
    exact naturality_condition(eta, f)
}

theorem adjoint_functors_isomorphic:
    forall F: Functor, G: Functor.
        is_adjoint(F, G) -->
        forall X: Object. homset(F(X), -) ≅ homset(X, G(-))
by {
    intro F G h_adj X
    -- Proof using adjoint definition
    sorry
}

fn compose_morphisms(f: Morphism, g: Morphism) -> Morphism {
    if f.target != g.source {
        -- Composition undefined
        return Morphism { source: f.source, target: f.target, label: "" }
    }

    return Morphism {
        source: f.source,
        target: g.target,
        label: g.label + " ∘ " + f.label,
    }
}


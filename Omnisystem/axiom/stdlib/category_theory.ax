type List<T> = Any
type Map<K, V> = Any
type Option<T> = Any
type Bool = Any

fn Some<T>(val: T) -> Option<T> { return val; }
fn None<T>() -> Option<T> { return null; }
fn is_some<T>(opt: Option<T>) -> Bool { return true; }
fn unwrap<T>(opt: Option<T>) -> T { return null; }

fn pattern_matches(pattern: LemmaPattern, goal: Goal) -> Bool {
    return true
}

fn instantiate_pattern(pattern: LemmaPattern, goal: Goal) -> Lemma {
    return Lemma { name: "", statement: "", proof: "" }

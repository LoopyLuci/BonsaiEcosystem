-- Lemma and theorem suggestion
struct LemmaSuggester {
    lemma_database: List[Lemma]

    fn new() -> LemmaSuggester {
        return LemmaSuggester {
            lemma_database: List::new(),
        }
    }

    fn suggest_lemmas(goal: Goal) -> List[Lemma] {
        let mut suggestions = List::new()

        for lemma in this.lemma_database {
            if lemma_applicable(lemma, goal) {
                suggestions.push(lemma)
            }
        }

        return suggestions
    }
}

type Lemma = {
    name: String
    statement: String
    proof: String
}


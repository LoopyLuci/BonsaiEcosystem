enum GlobalConstraint {
    | Sum(List[String], Int)
    | Element(String, List[Any], String)
    | Cardinality(List[String], Int)
    | Cumulative(List[String], List[String], List[String])
}

type Goal = String
type List<T> = Any
type Map<K, V> = Any
type Result<T, E> = Any
type Any = *void

fn Ok<T, E>(val: T) -> Result<T, E> { return val; }
fn Err<T, E>(msg: String) -> Result<T, E> { return null; }

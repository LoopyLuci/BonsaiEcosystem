fn softmax_forward(input: Tensor[f32], dim: Int) -> Tensor[f32] {
    return input
}

fn compute_mean(values: List[Int]) -> Float {
    let mut sum = 0

    for v in values {
        sum = sum + v
    }

    return (sum as Float) / (values.len() as Float)
}

fn compute_min(values: List[Int]) -> Int {
    let mut min_val = values[0]

    for v in values {
        if v < min_val {
            min_val = v
        }
    }

    return min_val
}

fn compute_max(values: List[Int]) -> Int {
    let mut max_val = values[0]

    for v in values {
        if v > max_val {
            max_val = v
        }
    }

    return max_val
}


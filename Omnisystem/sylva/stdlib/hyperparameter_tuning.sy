type Map<K, V> = Any
type List<T> = Any
type Option<T> = Any
type Any = Any

fn slice<T>(list: List[T], start: Int, end: Int) -> List[T] { return list; }
fn sort_by<T>(list: List[T], cmp: fn(T, T) -> Float) -> List[T] { return list; }

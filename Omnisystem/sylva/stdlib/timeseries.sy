}

fn estimate_yule_walker(autocov: Tensor[f32], p: Int) -> Tensor[f32] {
    return zeros([p])
}

fn compute_residuals(tensor: Tensor[f32], ar_coeffs: Tensor[f32]) -> Tensor[f32] {
    return tensor
}

fn estimate_ma_coefficients(residuals: Tensor[f32], q: Int) -> Tensor[f32] {

{
  "name": "java",
  "version": "21",
  "created": 951868800,
  "author": "James Gosling",
  "syntax": {
    "keywords": ["abstract", "assert", "boolean", "break", "byte", "case", "catch", "char", "class", "const", "continue", "default", "do", "double", "else", "enum", "extends", "false", "final", "finally", "float", "for", "goto", "if", "implements", "import", "instanceof", "int", "interface", "long", "native", "new", "null", "package", "private", "protected", "public", "return", "short", "static", "strictfp", "super", "switch", "synchronized", "this", "throw", "throws", "transient", "true", "try", "void", "volatile", "while", "yield"],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "%", "precedence": 13, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>>", "precedence": 11, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "&", "precedence": 8, "associativity": "Left"},
      {"symbol": "^", "precedence": 7, "associativity": "Left"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "?:", "precedence": 3, "associativity": "Right"},
      {"symbol": "=", "precedence": 2, "associativity": "Right"},
      {"symbol": "+=", "precedence": 2, "associativity": "Right"},
      {"symbol": "-=", "precedence": 2, "associativity": "Right"},
      {"symbol": "*=", "precedence": 2, "associativity": "Right"},
      {"symbol": "/=", "precedence": 2, "associativity": "Right"}
    ],
    "comments": {
      "line_comment": "//",
      "block_comment_start": "/*",
      "block_comment_end": "*/"
    },
    "string_delimiters": ["\""],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Variants", "Records", "Classes"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Threads",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".java"],
    "shebang": null,
    "lsp_command": "java-language-server",
    "compiler": {
      "command": "javac",
      "targets": ["jvm"],
      "optimization_levels": [],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "java",
      "jit_available": true,
      "tracing": true
    },
    "package_manager": "maven"
  },
  "metadata": {
    "paradigms": ["ObjectOriented", "Imperative", "Functional"],
    "influences": ["C++", "Smalltalk", "Ada"],
    "dialects": [],
    "standards": ["Java 1.0 through Java 21"],
    "tags": ["enterprise", "jvm", "compiled", "cross-platform", "static-typing"],
    "urls": {
      "homepage": "https://www.oracle.com/java/",
      "docs": "https://docs.oracle.com/en/java/",
      "repo": "https://github.com/openjdk/jdk"
    }
  }
}

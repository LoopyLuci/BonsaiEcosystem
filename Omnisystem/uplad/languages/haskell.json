{
  "name": "haskell",
  "version": "2010",
  "created": 1200960000,
  "author": "Lennart Augustsson et al.",
  "syntax": {
    "keywords": ["case", "class", "data", "default", "deriving", "do", "else", "if", "import", "in", "infix", "infixl", "infixr", "instance", "let", "module", "newtype", "of", "then", "type", "where"],
    "operators": [
      {"symbol": "+", "precedence": 6, "associativity": "Left"},
      {"symbol": "-", "precedence": 6, "associativity": "Left"},
      {"symbol": "*", "precedence": 7, "associativity": "Left"},
      {"symbol": "/", "precedence": 7, "associativity": "Left"},
      {"symbol": "++", "precedence": 5, "associativity": "Right"},
      {"symbol": ":", "precedence": 5, "associativity": "Right"},
      {"symbol": "==", "precedence": 4, "associativity": "Left"},
      {"symbol": "/=", "precedence": 4, "associativity": "Left"},
      {"symbol": "<", "precedence": 4, "associativity": "Left"},
      {"symbol": "<=", "precedence": 4, "associativity": "Left"},
      {"symbol": ">", "precedence": 4, "associativity": "Left"},
      {"symbol": ">=", "precedence": 4, "associativity": "Left"},
      {"symbol": "&&", "precedence": 3, "associativity": "Right"},
      {"symbol": "||", "precedence": 2, "associativity": "Right"},
      {"symbol": ">>", "precedence": 1, "associativity": "Left"},
      {"symbol": ">>=", "precedence": 1, "associativity": "Left"},
      {"symbol": "<-", "precedence": 0, "associativity": "Right"}
    ],
    "comments": {
      "line_comment": "--",
      "block_comment_start": "{-",
      "block_comment_end": "-}"
    },
    "string_delimiters": ["\""],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Variants", "Records", "Tuples", "Unions", "Effects"],
    "nominal": false,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Lazy",
    "concurrency": "None",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".hs"],
    "shebang": "#!/usr/bin/env runhaskell",
    "lsp_command": "hls",
    "compiler": {
      "command": "ghc",
      "targets": ["native"],
      "optimization_levels": ["0", "1", "2"],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "ghci",
      "jit_available": true,
      "tracing": false
    },
    "package_manager": "cabal"
  },
  "metadata": {
    "paradigms": ["Functional", "Declarative"],
    "influences": ["Miranda", "ML", "Lisp"],
    "dialects": ["Haskell98", "Haskell2010"],
    "standards": ["Haskell2010"],
    "tags": ["functional", "pure", "lazy", "strongly-typed"],
    "urls": {
      "homepage": "https://www.haskell.org",
      "docs": "https://www.haskell.org/documentation",
      "repo": "https://gitlab.haskell.org/ghc/ghc"
    }
  }
}

{
  "name": "rust",
  "version": "1.77.0",
  "created": 1621382400,
  "author": "Mozilla Foundation",
  "syntax": {
    "keywords": [
      "as", "break", "const", "continue", "crate", "dyn", "else", "enum",
      "extern", "false", "fn", "for", "if", "impl", "in", "let", "loop",
      "match", "mod", "move", "mut", "pub", "ref", "return", "self",
      "Self", "static", "struct", "super", "trait", "true", "type",
      "unsafe", "use", "where", "while", "abstract", "async", "await",
      "become", "box", "do", "final", "macro", "override", "priv",
      "typeof", "unsized", "virtual", "yield"
    ],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "%", "precedence": 13, "associativity": "Left"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "!", "precedence": 14, "associativity": "Right"},
      {"symbol": "&", "precedence": 15, "associativity": "Right"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "^", "precedence": 7, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": "=", "precedence": 1, "associativity": "Right"},
      {"symbol": "+=", "precedence": 1, "associativity": "Right"},
      {"symbol": "-=", "precedence": 1, "associativity": "Right"},
      {"symbol": "*=", "precedence": 1, "associativity": "Right"},
      {"symbol": "/=", "precedence": 1, "associativity": "Right"},
      {"symbol": "%=", "precedence": 1, "associativity": "Right"},
      {"symbol": "&=", "precedence": 1, "associativity": "Right"},
      {"symbol": "|=", "precedence": 1, "associativity": "Right"},
      {"symbol": "^=", "precedence": 1, "associativity": "Right"},
      {"symbol": "<<=", "precedence": 1, "associativity": "Right"},
      {"symbol": ">>=", "precedence": 1, "associativity": "Right"},
      {"symbol": "=>", "precedence": 2, "associativity": "Right"},
      {"symbol": "..", "precedence": 16, "associativity": "Left"},
      {"symbol": "..=", "precedence": 16, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": "//",
      "block_comment_start": "/*",
      "block_comment_end": "*/"
    },
    "string_delimiters": ["\"", "'", "r\"", "r#\""],
    "case_sensitive": true
  },
  "grammar": {
    "start_symbol": "crate",
    "productions": {},
    "ebnf": null
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Variants", "Records", "Tuples", "Unions", "Effects"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Threads",
    "memory_management": "Ownership"
  },
  "tooling": {
    "extensions": [".rs"],
    "shebang": "#!/usr/bin/env rust-script",
    "lsp_command": "rust-analyzer",
    "compiler": {
      "command": "rustc",
      "targets": ["native", "wasm"],
      "optimization_levels": ["0", "1", "2", "3", "s", "z"],
      "cross_compilation": true
    },
    "interpreter": null,
    "package_manager": "cargo"
  },
  "metadata": {
    "paradigms": ["Systems", "Functional", "Imperative"],
    "influences": ["C++", "Haskell", "OCaml"],
    "dialects": [],
    "standards": ["RFC"],
    "tags": ["systems", "memory-safe", "concurrent", "compiled"],
    "urls": {
      "homepage": "https://www.rust-lang.org",
      "docs": "https://doc.rust-lang.org",
      "repo": "https://github.com/rust-lang/rust"
    }
  }
}

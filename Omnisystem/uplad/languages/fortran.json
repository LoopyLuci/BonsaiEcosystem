{
  "name": "fortran",
  "version": "2023",
  "created": 299836800,
  "author": "John Backus",
  "syntax": {
    "keywords": ["abstract", "access", "action", "allocatable", "allocate", "asynchronous", "backspace", "bind", "block", "call", "case", "character", "class", "close", "codimension", "common", "concurrent", "contains", "contiguous", "continue", "critical", "cycle", "deallocate", "decimal", "declare", "default", "deferred", "dimension", "do", "double", "elemental", "else", "elseif", "elsewhere", "end", "endif", "entry", "enum", "enumerator", "equivalence", "error", "exit", "external", "file", "final", "flush", "forall", "form", "format", "formatted", "function", "go", "goto", "if", "implicit", "import", "in", "include", "integer", "intent", "interface", "intrinsic", "is", "kind", "len", "logical", "module", "name", "namelist", "non_overridable", "nopass", "not", "null", "only", "open", "optional", "out", "parameter", "pass", "pause", "pointer", "print", "private", "procedure", "program", "protected", "public", "pure", "read", "readwrite", "real", "recursive", "result", "return", "rewind", "save", "select", "sequence", "stat", "submodule", "subroutine", "sync", "target", "then", "to", "type", "unformatted", "unit", "use", "value", "volatile", "wait", "where", "while", "write"],
    "operators": [
      {"symbol": "+", "precedence": 3, "associativity": "Left"},
      {"symbol": "-", "precedence": 3, "associativity": "Left"},
      {"symbol": "*", "precedence": 4, "associativity": "Left"},
      {"symbol": "/", "precedence": 4, "associativity": "Left"},
      {"symbol": "**", "precedence": 5, "associativity": "Right"},
      {"symbol": "==", "precedence": 2, "associativity": "Left"},
      {"symbol": "/=", "precedence": 2, "associativity": "Left"},
      {"symbol": "<", "precedence": 2, "associativity": "Left"},
      {"symbol": ">", "precedence": 2, "associativity": "Left"},
      {"symbol": "<=", "precedence": 2, "associativity": "Left"},
      {"symbol": ">=", "precedence": 2, "associativity": "Left"},
      {"symbol": ".and.", "precedence": 1, "associativity": "Left"},
      {"symbol": ".or.", "precedence": 0, "associativity": "Left"},
      {"symbol": ".not.", "precedence": 5, "associativity": "Right"},
      {"symbol": "=", "precedence": -1, "associativity": "Right"}
    ],
    "comments": {
      "line_comment": "!",
      "block_comment_start": null,
      "block_comment_end": null
    },
    "string_delimiters": ["\"", "'"],
    "case_sensitive": false
  },
  "type_system": {
    "kind": "Static",
    "features": ["Arrays", "Derived Types", "Parametric Polymorphism"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": false,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Coarrays",
    "memory_management": "Manual"
  },
  "tooling": {
    "extensions": [".f90", ".f95", ".f03", ".f08", ".f18"],
    "shebang": null,
    "lsp_command": "fortls",
    "compiler": {
      "command": "gfortran",
      "targets": ["native"],
      "optimization_levels": ["0", "1", "2", "3"],
      "cross_compilation": true
    },
    "interpreter": null,
    "package_manager": "fpm"
  },
  "metadata": {
    "paradigms": ["Imperative", "Procedural", "Functional"],
    "influences": [],
    "dialects": ["Fortran77", "Fortran90", "Fortran95", "Fortran2003", "Fortran2008"],
    "standards": ["F77", "F90", "F95", "F2003", "F2008", "F2018", "F2023"],
    "tags": ["scientific-computing", "numerical", "legacy", "high-performance", "vectorized"],
    "urls": {
      "homepage": "https://fortran-lang.org",
      "docs": "https://fortran-lang.org/en/learn/",
      "repo": "https://github.com/fortran-lang/fpm"
    }
  }
}

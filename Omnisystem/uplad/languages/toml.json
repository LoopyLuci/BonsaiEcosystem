{
  "name": "toml",
  "version": "1.0",
  "created": 1372550400,
  "author": "Tom Preston-Werner",
  "syntax": {
    "keywords": ["true", "false"],
    "operators": [
      {"symbol": "=", "precedence": 0, "associativity": "Right"},
      {"symbol": ".", "precedence": 0, "associativity": "Left"},
      {"symbol": "[", "precedence": 0, "associativity": "Left"},
      {"symbol": "]", "precedence": 0, "associativity": "Left"},
      {"symbol": "{", "precedence": 0, "associativity": "Left"},
      {"symbol": "}", "precedence": 0, "associativity": "Left"},
      {"symbol": ",", "precedence": 0, "associativity": "Left"},
      {"symbol": "-", "precedence": 0, "associativity": "Left"},
      {"symbol": "_", "precedence": 0, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": "#",
      "block_comment_start": null,
      "block_comment_end": null
    },
    "string_delimiters": ["\"", "'"],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Tables", "Arrays", "Inline Tables"],
    "nominal": true,
    "polymorphism": "None",
    "inference": false,
    "dependent": false
  },
  "evaluation": {
    "model": "Data",
    "concurrency": "None",
    "memory_management": "Managed"
  },
  "tooling": {
    "extensions": [".toml"],
    "shebang": null,
    "lsp_command": "toml-language-server",
    "compiler": null,
    "interpreter": null,
    "package_manager": null
  },
  "metadata": {
    "paradigms": ["Data Format"],
    "influences": ["INI", "YAML", "JSON"],
    "dialects": [],
    "standards": ["TOML 1.0.0"],
    "tags": ["configuration", "data-interchange", "human-readable", "minimal", "typed"],
    "urls": {
      "homepage": "https://toml.io",
      "docs": "https://toml.io/en/v1.0.0",
      "repo": "https://github.com/toml-lang/toml"
    }
  }
}

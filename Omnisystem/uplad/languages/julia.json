{
  "name": "julia",
  "version": "1.10",
  "created": 1378598400,
  "author": "Jeff Bezanson, Stefan Karpinski, Viral B. Shah, Alan Edelman",
  "syntax": {
    "keywords": ["abstract", "and", "as", "begin", "break", "catch", "const", "continue", "do", "elseif", "else", "end", "export", "finally", "for", "function", "global", "if", "import", "in", "inner", "let", "local", "macro", "module", "not", "or", "outer", "primitive", "quote", "return", "struct", "using", "where", "while"],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "\\", "precedence": 13, "associativity": "Left"},
      {"symbol": "//", "precedence": 13, "associativity": "Left"},
      {"symbol": "^", "precedence": 14, "associativity": "Right"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "!", "precedence": 15, "associativity": "Right"},
      {"symbol": "&", "precedence": 8, "associativity": "Left"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "xor", "precedence": 7, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": "=", "precedence": 1, "associativity": "Right"},
      {"symbol": ".=", "precedence": 1, "associativity": "Right"},
      {"symbol": "?:", "precedence": 3, "associativity": "Right"}
    ],
    "comments": {
      "line_comment": "#",
      "block_comment_start": "#=",
      "block_comment_end": "=#"
    },
    "string_delimiters": ["\""],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Multiple Dispatch", "Records"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Threads",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".jl"],
    "shebang": "#!/usr/bin/env julia",
    "lsp_command": "julia-lsp",
    "compiler": {
      "command": "julia",
      "targets": ["native"],
      "optimization_levels": ["-O0", "-O1", "-O2", "-O3"],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "julia",
      "jit_available": true,
      "tracing": true
    },
    "package_manager": "Pkg"
  },
  "metadata": {
    "paradigms": ["Functional", "Imperative", "ObjectOriented"],
    "influences": ["Lisp", "Matlab", "Python", "Ruby"],
    "dialects": [],
    "standards": [],
    "tags": ["scientific-computing", "numerical", "multiple-dispatch", "jit-compiled"],
    "urls": {
      "homepage": "https://julialang.org",
      "docs": "https://docs.julialang.org",
      "repo": "https://github.com/JuliaLang/julia"
    }
  }
}

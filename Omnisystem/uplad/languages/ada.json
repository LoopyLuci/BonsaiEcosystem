{
  "name": "ada",
  "version": "2022",
  "created": 578006400,
  "author": "Jean Ichbiah",
  "syntax": {
    "keywords": ["abort", "abs", "abstract", "accept", "access", "all", "and", "array", "at", "begin", "body", "case", "constant", "declare", "delay", "delta", "digits", "do", "else", "elsif", "end", "entry", "exception", "exit", "for", "function", "generic", "goto", "if", "in", "interface", "is", "limited", "loop", "mod", "new", "not", "null", "of", "or", "others", "out", "overriding", "package", "pragma", "private", "procedure", "protected", "raise", "range", "record", "rem", "renames", "requeue", "reverse", "select", "separate", "some", "subtype", "synchronized", "tagged", "task", "terminate", "then", "type", "until", "use", "when", "while", "with", "xor"],
    "operators": [
      {"symbol": "+", "precedence": 100, "associativity": "Left"},
      {"symbol": "-", "precedence": 100, "associativity": "Left"},
      {"symbol": "*", "precedence": 200, "associativity": "Left"},
      {"symbol": "/", "precedence": 200, "associativity": "Left"},
      {"symbol": "mod", "precedence": 200, "associativity": "Left"},
      {"symbol": "rem", "precedence": 200, "associativity": "Left"},
      {"symbol": "**", "precedence": 300, "associativity": "Right"},
      {"symbol": "=", "precedence": 50, "associativity": "Left"},
      {"symbol": "/=", "precedence": 50, "associativity": "Left"},
      {"symbol": "<", "precedence": 60, "associativity": "Left"},
      {"symbol": ">", "precedence": 60, "associativity": "Left"},
      {"symbol": "<=", "precedence": 60, "associativity": "Left"},
      {"symbol": ">=", "precedence": 60, "associativity": "Left"},
      {"symbol": "and", "precedence": 20, "associativity": "Left"},
      {"symbol": "or", "precedence": 10, "associativity": "Left"},
      {"symbol": "xor", "precedence": 10, "associativity": "Left"},
      {"symbol": "not", "precedence": 500, "associativity": "Right"},
      {"symbol": "&", "precedence": 40, "associativity": "Left"},
      {"symbol": "|", "precedence": 30, "associativity": "Left"},
      {"symbol": "^", "precedence": 25, "associativity": "Left"},
      {"symbol": "<<", "precedence": 70, "associativity": "Left"},
      {"symbol": ">>", "precedence": 70, "associativity": "Left"},
      {"symbol": ":=", "precedence": 5, "associativity": "Right"},
      {"symbol": "=>", "precedence": 5, "associativity": "Right"},
      {"symbol": "..", "precedence": 2, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": "--",
      "block_comment_start": null,
      "block_comment_end": null
    },
    "string_delimiters": ["\""],
    "case_sensitive": false
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Records", "Variants", "Tuples", "Tagged Types", "Access Types"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": false,
    "dependent": true
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Tasks",
    "memory_management": "Manual"
  },
  "tooling": {
    "extensions": [".ads", ".adb"],
    "shebang": null,
    "lsp_command": "ada-language-server",
    "compiler": {
      "command": "gnatmake",
      "targets": ["native"],
      "optimization_levels": ["0", "1", "2", "3"],
      "cross_compilation": true
    },
    "interpreter": null,
    "package_manager": "alire"
  },
  "metadata": {
    "paradigms": ["Imperative", "ObjectOriented", "Concurrent"],
    "influences": ["Pascal", "Modula"],
    "dialects": [],
    "standards": ["Ada83", "Ada95", "Ada2005", "Ada2012", "Ada2022"],
    "tags": ["safety-critical", "real-time", "compiled", "formal-verification", "contract-based"],
    "urls": {
      "homepage": "https://www.adaic.org",
      "docs": "https://www.adaic.org/learn/",
      "repo": "https://github.com/AdaCore/gcc"
    }
  }
}

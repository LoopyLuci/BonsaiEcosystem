{
  "name": "scala",
  "version": "3.3",
  "created": 1175731200,
  "author": "Martin Odersky",
  "syntax": {
    "keywords": ["abstract", "as", "case", "catch", "class", "def", "derive", "do", "else", "end", "enum", "export", "extends", "extension", "false", "final", "finally", "for", "forSome", "given", "goto", "if", "implicit", "import", "inline", "inout", "is", "lazy", "match", "new", "null", "object", "of", "opaque", "open", "override", "package", "private", "protected", "pure", "public", "requires", "return", "sealed", "self", "super", "then", "this", "throw", "trait", "transparent", "true", "try", "type", "using", "val", "var", "while", "with", "yield"],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "%", "precedence": 13, "associativity": "Left"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "!", "precedence": 15, "associativity": "Right"},
      {"symbol": "&", "precedence": 8, "associativity": "Left"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "^", "precedence": 7, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": "=", "precedence": 2, "associativity": "Right"},
      {"symbol": "=>", "precedence": 2, "associativity": "Right"},
      {"symbol": "?:", "precedence": 3, "associativity": "Right"},
      {"symbol": "@", "precedence": 14, "associativity": "Right"},
      {"symbol": "#", "precedence": 16, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": "//",
      "block_comment_start": "/*",
      "block_comment_end": "*/"
    },
    "string_delimiters": ["\""],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Variants", "Records", "Classes", "Structural"],
    "nominal": true,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Threads",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".scala", ".sc"],
    "shebang": "#!/usr/bin/env scala-cli",
    "lsp_command": "metals",
    "compiler": {
      "command": "scalac",
      "targets": ["jvm"],
      "optimization_levels": [],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "scala",
      "jit_available": true,
      "tracing": true
    },
    "package_manager": "sbt"
  },
  "metadata": {
    "paradigms": ["ObjectOriented", "Functional", "Imperative"],
    "influences": ["Java", "Haskell", "SML", "Lisp"],
    "dialects": [],
    "standards": [],
    "tags": ["jvm", "functional", "static-typing", "compiled", "language-integrated-query"],
    "urls": {
      "homepage": "https://www.scala-lang.org",
      "docs": "https://www.scala-lang.org/documentation",
      "repo": "https://github.com/scala/scala"
    }
  }
}

{
  "name": "lisp",
  "version": "ANSI CL",
  "created": 631152000,
  "author": "John McCarthy",
  "syntax": {
    "keywords": ["and", "block", "catch", "cond", "defclass", "defconstant", "defgeneric", "defmacro", "defmethod", "defpackage", "defparameter", "defstruct", "defun", "defvar", "do", "do*", "dolist", "dotimes", "ecase", "eval-when", "flet", "force", "ftype", "go", "handler-case", "if", "ignore-errors", "in-package", "incf", "labels", "lambda", "let", "let*", "locally", "loop", "macrolet", "multiple-value-bind", "nil", "not", "or", "package", "progn", "progv", "quote", "restart-case", "return", "setf", "setq", "symbol-macrolet", "t", "tagbody", "the", "throw", "trace", "unless", "unwind-protect", "when", "with-accessors", "with-open-file", "with-slots"],
    "operators": [
      {"symbol": "+", "precedence": 0, "associativity": "Left"},
      {"symbol": "-", "precedence": 0, "associativity": "Left"},
      {"symbol": "*", "precedence": 0, "associativity": "Left"},
      {"symbol": "/", "precedence": 0, "associativity": "Left"},
      {"symbol": "=", "precedence": 0, "associativity": "Left"},
      {"symbol": "eq", "precedence": 0, "associativity": "Left"},
      {"symbol": "equal", "precedence": 0, "associativity": "Left"},
      {"symbol": "<", "precedence": 0, "associativity": "Left"},
      {"symbol": ">", "precedence": 0, "associativity": "Left"},
      {"symbol": "<=", "precedence": 0, "associativity": "Left"},
      {"symbol": ">=", "precedence": 0, "associativity": "Left"},
      {"symbol": "cons", "precedence": 0, "associativity": "Left"},
      {"symbol": "car", "precedence": 0, "associativity": "Left"},
      {"symbol": "cdr", "precedence": 0, "associativity": "Left"},
      {"symbol": "list", "precedence": 0, "associativity": "Left"},
      {"symbol": "append", "precedence": 0, "associativity": "Left"},
      {"symbol": "mapcar", "precedence": 0, "associativity": "Left"},
      {"symbol": "funcall", "precedence": 0, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": ";",
      "block_comment_start": "#|",
      "block_comment_end": "|#"
    },
    "string_delimiters": ["\""],
    "case_sensitive": false
  },
  "type_system": {
    "kind": "Dynamic",
    "features": [],
    "nominal": false,
    "polymorphism": "None",
    "inference": false,
    "dependent": false
  },
  "evaluation": {
    "model": "Lazy",
    "concurrency": "None",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".lisp", ".cl", ".el"],
    "shebang": "#!/usr/bin/env sbcl",
    "lsp_command": "cl-lsp",
    "compiler": {
      "command": "sbcl",
      "targets": ["native"],
      "optimization_levels": [],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "sbcl",
      "jit_available": true,
      "tracing": true
    },
    "package_manager": "quicklisp"
  },
  "metadata": {
    "paradigms": ["Functional", "Metaprogramming", "Declarative"],
    "influences": ["Lambda calculus"],
    "dialects": ["Scheme", "Clojure", "Dylan"],
    "standards": ["Common Lisp (ANSI CL)"],
    "tags": ["functional", "meta-language", "interpreter", "homoiconicity", "symbolic-computation"],
    "urls": {
      "homepage": "https://common-lisp.net",
      "docs": "http://www.lispworks.com/documentation/HyperSpec/Front/",
      "repo": null
    }
  }

{
  "name": "objectivec",
  "version": "2.0",
  "created": 1120176000,
  "author": "Brad Cox, Tom Love",
  "syntax": {
    "keywords": ["auto", "break", "case", "char", "const", "continue", "default", "do", "double", "else", "enum", "extern", "float", "for", "goto", "if", "inline", "int", "long", "register", "restrict", "return", "short", "signed", "sizeof", "static", "struct", "switch", "typedef", "union", "unsigned", "void", "volatile", "while", "interface", "implementation", "end", "property", "synthesize", "dynamic", "protocol", "class", "public", "private", "protected", "package", "import", "selector", "encode", "defs", "compatibility_alias"],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "%", "precedence": 13, "associativity": "Left"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "!", "precedence": 15, "associativity": "Right"},
      {"symbol": "&", "precedence": 8, "associativity": "Left"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "^", "precedence": 7, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": "=", "precedence": 2, "associativity": "Right"}
    ],
    "comments": {
      "line_comment": "//",
      "block_comment_start": "/*",
      "block_comment_end": "*/"
    },
    "string_delimiters": ["\""],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Objects", "Protocols", "Categories"],
    "nominal": true,
    "polymorphism": "None",
    "inference": false,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Threads",
    "memory_management": "ReferenceCountingAuto"
  },
  "tooling": {
    "extensions": [".m", ".h"],
    "shebang": null,
    "lsp_command": "objc-language-server",
    "compiler": {
      "command": "clang",
      "targets": ["native"],
      "optimization_levels": ["0", "1", "2", "3", "s"],
      "cross_compilation": true
    },
    "interpreter": null,
    "package_manager": "CocoaPods"
  },
  "metadata": {
    "paradigms": ["ObjectOriented", "Imperative"],
    "influences": ["C", "Smalltalk"],
    "dialects": [],
    "standards": [],
    "tags": ["apple-ecosystem", "macos", "ios", "compiled", "messaging-based"],
    "urls": {
      "homepage": "https://en.wikipedia.org/wiki/Objective-C",
      "docs": "https://developer.apple.com/documentation/objectivec",
      "repo": null
    }
  }
}

{
  "name": "typescript",
  "version": "5.4",
  "created": 1289520000,
  "author": "Anders Hejlsberg",
  "syntax": {
    "keywords": ["abstract", "any", "as", "async", "await", "boolean", "break", "case", "catch", "class", "const", "constructor", "continue", "declare", "default", "delete", "do", "else", "enum", "export", "extends", "false", "finally", "for", "from", "function", "get", "global", "goto", "if", "implements", "import", "in", "instanceof", "interface", "is", "keyof", "let", "module", "namespace", "never", "new", "null", "number", "of", "package", "private", "protected", "public", "readonly", "require", "return", "set", "static", "string", "super", "switch", "symbol", "this", "throw", "true", "try", "type", "typeof", "unique", "var", "void", "while", "with", "yield"],
    "operators": [
      {"symbol": "+", "precedence": 12, "associativity": "Left"},
      {"symbol": "-", "precedence": 12, "associativity": "Left"},
      {"symbol": "*", "precedence": 13, "associativity": "Left"},
      {"symbol": "/", "precedence": 13, "associativity": "Left"},
      {"symbol": "%", "precedence": 13, "associativity": "Left"},
      {"symbol": "**", "precedence": 14, "associativity": "Right"},
      {"symbol": "==", "precedence": 9, "associativity": "Left"},
      {"symbol": "===", "precedence": 9, "associativity": "Left"},
      {"symbol": "!=", "precedence": 9, "associativity": "Left"},
      {"symbol": "!==", "precedence": 9, "associativity": "Left"},
      {"symbol": "<", "precedence": 10, "associativity": "Left"},
      {"symbol": ">", "precedence": 10, "associativity": "Left"},
      {"symbol": "<=", "precedence": 10, "associativity": "Left"},
      {"symbol": ">=", "precedence": 10, "associativity": "Left"},
      {"symbol": "&&", "precedence": 5, "associativity": "Left"},
      {"symbol": "||", "precedence": 4, "associativity": "Left"},
      {"symbol": "??", "precedence": 4, "associativity": "Left"},
      {"symbol": "!", "precedence": 15, "associativity": "Right"},
      {"symbol": "&", "precedence": 8, "associativity": "Left"},
      {"symbol": "|", "precedence": 6, "associativity": "Left"},
      {"symbol": "^", "precedence": 7, "associativity": "Left"},
      {"symbol": "<<", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>", "precedence": 11, "associativity": "Left"},
      {"symbol": ">>>", "precedence": 11, "associativity": "Left"},
      {"symbol": "=", "precedence": 2, "associativity": "Right"},
      {"symbol": "=>", "precedence": 2, "associativity": "Right"},
      {"symbol": "?:", "precedence": 3, "associativity": "Right"},
      {"symbol": "?.", "precedence": 16, "associativity": "Left"},
      {"symbol": "as", "precedence": 11, "associativity": "Left"}
    ],
    "comments": {
      "line_comment": "//",
      "block_comment_start": "/*",
      "block_comment_end": "*/"
    },
    "string_delimiters": ["\"", "'", "`"],
    "case_sensitive": true
  },
  "type_system": {
    "kind": "Static",
    "features": ["Generics", "Variants", "Records", "Tuples", "Structural"],
    "nominal": false,
    "polymorphism": "Parametric",
    "inference": true,
    "dependent": false
  },
  "evaluation": {
    "model": "Eager",
    "concurrency": "Async",
    "memory_management": "GarbageCollection"
  },
  "tooling": {
    "extensions": [".ts", ".tsx"],
    "shebang": "#!/usr/bin/env node",
    "lsp_command": "typescript-language-server",
    "compiler": {
      "command": "tsc",
      "targets": ["javascript"],
      "optimization_levels": [],
      "cross_compilation": false
    },
    "interpreter": {
      "command": "node",
      "jit_available": true,
      "tracing": true
    },
    "package_manager": "npm"
  },
  "metadata": {
    "paradigms": ["Imperative", "Functional", "ObjectOriented"],
    "influences": ["JavaScript", "Java", "C#"],
    "dialects": ["JavaScript", "Flow"],
    "standards": ["ECMAScript"],
    "tags": ["scripting", "static-typing", "web", "transpiled", "superset"],
    "urls": {
      "homepage": "https://www.typescriptlang.org",
      "docs": "https://www.typescriptlang.org/docs",
      "repo": "https://github.com/microsoft/TypeScript"
    }
  }
}

// ────────────────────────────────────────────────────────────────────────
// BATCH VERIFICATION
// ────────────────────────────────────────────────────────────────────────

/// Verify multiple language properties at once
pub fn verify_language_complete(spec: &LanguageSpec) -> Result<LanguageVerification, String> {
    let grammar = verify_grammar_unambiguous(spec)?;
    let type_system = verify_type_system_sound(spec)?;

    let overall_valid = match (&grammar.is_unambiguous, &type_system.is_sound) {
        (VerificationResult::Valid, VerificationResult::Valid) => true,
        (VerificationResult::Valid, VerificationResult::Unproven) => true, // Still OK if grammar valid
        _ => false,
    };

    Ok(LanguageVerification {
        language: spec.name.clone(),
        grammar,
        type_system,
        overall_valid,
    })
}

/// Complete language verification report
#[derive(Clone, Debug)]
pub struct LanguageVerification {
    pub language: String,
    pub grammar: GrammarVerification,
    pub type_system: TypeSystemVerification,
    pub overall_valid: bool,
}


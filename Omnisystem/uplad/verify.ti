// uplad/verify.ti – Formal verification of language properties with Axiom
// Proves grammar properties, type system soundness, and safety guarantees

module uplad::verify

use uplad::schema::{LanguageSpec, GrammarSpec, Production, Symbol, TypeSystemKind}
use core::vec::Vec
use core::string::String
use core::option::Option
use core::result::Result

/// Verification result for a language property
#[derive(Clone, Debug, PartialEq, Eq)]
pub enum VerificationResult {
    Valid,
    Invalid,
    Unproven,
    Unknown,
}

/// Grammar verification results
#[derive(Clone, Debug)]
pub struct GrammarVerification {
    pub language: String,
    pub is_unambiguous: VerificationResult,
    pub is_deterministic: VerificationResult,
    pub is_ll1: Option<bool>,
    pub conflict_count: u64,
}

/// Type system verification results
#[derive(Clone, Debug)]
pub struct TypeSystemVerification {
    pub language: String,
    pub is_sound: VerificationResult,
    pub has_progress: VerificationResult,
    pub has_preservation: VerificationResult,
    pub can_infer: bool,
}

// ────────────────────────────────────────────────────────────────────────
// GRAMMAR VERIFICATION
// ────────────────────────────────────────────────────────────────────────

/// Verify that a grammar is unambiguous
pub fn verify_grammar_unambiguous(spec: &LanguageSpec) -> Result<GrammarVerification, String> {
    let language = spec.name.clone();

    // Step 1: Check for immediate conflicts
    let conflicts = check_shift_reduce_conflicts(&spec.grammar);

    // Step 2: Try to build LR(1) table (would detect unreducible conflicts)
    let is_deterministic = conflicts == 0;

    // Step 3: Check if grammar is LL(1)
    let is_ll1 = check_ll1(&spec.grammar);

    Ok(GrammarVerification {
        language,
        is_unambiguous: if is_deterministic {
            VerificationResult::Valid
        } else {
            VerificationResult::Invalid
        },
        is_deterministic: if is_deterministic {
            VerificationResult::Valid
        } else {
            VerificationResult::Invalid
        },
        is_ll1,
        conflict_count: conflicts,
    })
}

/// Check for shift/reduce and reduce/reduce conflicts

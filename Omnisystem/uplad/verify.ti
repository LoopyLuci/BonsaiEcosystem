#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_left_recursion_detection() {
        // Placeholder: would create grammar and verify
        let has_lr = check_left_recursion(&GrammarSpec {
            start_symbol: "expr".to_string(),
            productions: std::collections::HashMap::new(),
            ebnf: None,
        });
        assert!(!has_lr);
    }

    #[test]
    fn test_verification_result_equality() {
        assert_eq!(VerificationResult::Valid, VerificationResult::Valid);
        assert_ne!(VerificationResult::Valid, VerificationResult::Invalid);
    }
}

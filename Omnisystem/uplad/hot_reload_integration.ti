/// Generation counter for atomic symbol table updates
pub struct GenerationCounter {
    current: u64,
}

impl GenerationCounter {
    pub fn new() -> Self {
        Self { current: 0 }
    }

    pub fn increment(&mut self) -> u64 {
        self.current += 1;
        self.current
    }

    pub fn get(&self) -> u64 {
        self.current
    }
}

/// In-flight call tracker for safe draining
pub struct InflightTracker {
    active_calls: Vec<(String, u64)>, // (function_name, gen)
}

impl InflightTracker {
    pub fn new() -> Self {
        Self {
            active_calls: Vec::new(),
        }
    }

    pub fn enter(&mut self, function: &str, gen: u64) {
        self.active_calls.push((function.to_string(), gen));
    }

    pub fn exit(&mut self, function: &str) {
        self.active_calls.retain(|(f, _)| f != function);
    }

    pub fn drain_for_generation(&self, gen: u64) -> bool {
        // Check if all remaining calls are newer than gen
        self.active_calls.iter().all(|(_, g)| g > &gen)
    }

    pub fn pending_count(&self) -> usize {
        self.active_calls.len()
    }
}

/// Atomic frontend hot-reload manager
pub struct HotReloadManager {
    registry: RegistryClient,
    gen_counter: GenerationCounter,
    inflight_tracker: InflightTracker,
}

impl HotReloadManager {
    /// Create a new hot-reload manager
    pub fn new(registry_addr: &str) -> Result<Self, String> {
        let registry = RegistryClient::new(registry_addr)?;
        Ok(Self {
            registry,
            gen_counter: GenerationCounter::new(),
            inflight_tracker: InflightTracker::new(),
        })
    }

    // ────────────────────────────────────────────────────────────────
    // ATOMIC RELOAD PROCEDURE
    // ────────────────────────────────────────────────────────────────

    /// Perform atomic hot-reload of a language frontend
    /// Returns new generation number
    pub fn reload_language(&mut self, language_name: &str) -> Result<u64, String> {
        // Step 1: Fetch language spec from registry
        let spec = self.registry.lookup(language_name)?
            .ok_or_else(|| format!("Language '{}' not found", language_name))?;

        // Step 2: Generate new frontend IR
        let parser_ir = generate_parser_ir(&spec)?;

        // Step 3: Compile IR to native code (BACE – fast)
        let compiled_code = self.compile_frontend(parser_ir)?;

        // Step 4: Begin atomic generation transition
        let new_gen = self.gen_counter.increment();

        // Step 5: Perform atomic symbol table update (kernel operation)
        self.atomic_symbol_update(language_name, compiled_code, new_gen)?;

        // Step 6: Drain in-flight calls to old code
        self.drain_inflight_calls(new_gen)?;

        // Step 7: Register frontend capability in registry
        let capability = FrontendCapability {
            language: language_name.to_string(),
            version: spec.version.clone(),
            compiled_at: current_timestamp(),
            parser_hash: hash_frontend(&compiled_code),
        };

        self.registry.update_frontend(language_name, capability)?;

        Ok(new_gen)
    }

    /// Reload multiple languages atomically
    pub fn reload_batch(&mut self, language_names: &[String]) -> Result<Vec<u64>, String> {
        let mut generations = Vec::new();

        for name in language_names {
            match self.reload_language(name) {
                Ok(gen) => generations.push(gen),
                Err(e) => return Err(format!("Failed to reload {}: {}", name, e)),
            }
        }

        Ok(generations)
    }

    // ────────────────────────────────────────────────────────────────
    // KERNEL-LEVEL OPERATIONS
    // ────────────────────────────────────────────────────────────────

    /// Atomic symbol table update (kernel-level operation)
    /// This is where the CAS (compare-and-swap) magic happens
    fn atomic_symbol_update(
        &self,
        language_name: &str,
        compiled_code: Vec<u8>,
        new_gen: u64,
    ) -> Result<(), String> {
        // In real implementation, this would:
        // 1. Allocate new memory region for compiled code
        // 2. Copy compiled code into new region
        // 3. Perform CAS on symbol table generation pointer
        // 4. Update all function pointers atomically
        //
        // The CAS ensures that from one CPU instruction onwards,
        // all new calls use the new code (no race window).

        // Placeholder: would call kernel::symbol_table::atomic_update()
        Ok(())
    }

    /// Drain in-flight calls to old code generation
    fn drain_inflight_calls(&mut self, new_gen: u64) -> Result<(), String> {
        // In real implementation, this would:
        // 1. Spin until all in-flight calls complete
        // 2. Check that pending calls are for newer generations
        // 3. Deallocate old code region when safe

        let max_wait_us = 100_000; // 100ms timeout
        let mut waited = 0u64;

        while !self.inflight_tracker.drain_for_generation(new_gen) && waited < max_wait_us {
            // Busy-wait with backoff (in real impl: event-based)
            // small_sleep(100); // 100 microseconds
            waited += 100;
        }

        if waited >= max_wait_us {
            return Err(format!("Timeout draining in-flight calls (pending: {})",
                self.inflight_tracker.pending_count()));
        }

        Ok(())
    }

    // ────────────────────────────────────────────────────────────────
    // TYPE-AWARE DATA MIGRATION
    // ────────────────────────────────────────────────────────────────

    /// Check type compatibility between old and new frontends
    /// Returns true if migration is safe (automatic or via user function)
    pub fn check_type_compatibility(
        &self,
        old_spec: &LanguageSpec,
        new_spec: &LanguageSpec,
    ) -> Result<bool, String> {
        // Compare type descriptors from grammar

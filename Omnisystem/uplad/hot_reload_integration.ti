        Ok(true)
    }

    /// Perform type-aware data migration for global state
    pub fn migrate_globals(
        &self,
        old_globals: Vec<u8>,
        migration_function: Option<Box<dyn Fn(Vec<u8>) -> Result<Vec<u8>, String>>>,
    ) -> Result<Vec<u8>, String> {
        match migration_function {
            Some(f) => f(old_globals),
            None => {
                // Automatic migration: copy bytes as-is if types are identical
                Ok(old_globals)
            }
        }
    }

    // ────────────────────────────────────────────────────────────────
    // SUBSCRIPTION AND AUTO-RELOAD
    // ────────────────────────────────────────────────────────────────

    /// Watch language registry for updates and auto-reload
    pub fn watch_and_reload(&mut self) -> Result<(), String> {

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_generation_counter() {
        let mut gen = GenerationCounter::new();
        assert_eq!(gen.get(), 0);
        assert_eq!(gen.increment(), 1);
        assert_eq!(gen.get(), 1);
    }

    #[test]
    fn test_inflight_tracker() {
        let mut tracker = InflightTracker::new();
        tracker.enter("foo", 1);
        assert_eq!(tracker.pending_count(), 1);
        assert!(tracker.drain_for_generation(0));
        tracker.exit("foo");
        assert_eq!(tracker.pending_count(), 0);
    }

    #[test]
    fn test_hot_reload_manager_new() {
        let manager = HotReloadManager::new("aether://language-registry").unwrap();
        assert_eq!(manager.current_generation(), 0);
    }
}

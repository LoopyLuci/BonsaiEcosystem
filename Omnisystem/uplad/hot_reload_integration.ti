// uplad/hot_reload_integration.ti – Integration with atomic hot-reloading system
// Bridges language registry with kernel's atomic symbol table updates
// Enables zero-downtime frontend swapping

module uplad::hot_reload_integration

use uplad::schema::LanguageSpec

    // ────────────────────────────────────────────────────────────────
    // STATISTICS AND MONITORING
    // ────────────────────────────────────────────────────────────────

    /// Get current generation number
    pub fn current_generation(&self) -> u64 {
        self.gen_counter.get()
    }

    /// Get number of in-flight calls
    pub fn pending_inflight_calls(&self) -> usize {
        self.inflight_tracker.pending_count()
    }

    /// Get reload statistics
    pub fn stats(&self) -> ReloadStats {
        ReloadStats {
            total_reloads: self.gen_counter.get(),
            pending_calls: self.inflight_tracker.pending_count(),
            registry_languages: 0, // would query registry

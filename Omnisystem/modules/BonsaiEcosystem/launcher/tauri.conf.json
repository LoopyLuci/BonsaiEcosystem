{
  "$schema": "../../../node_modules/@tauri-apps/cli/schema.json",
  "productName": "BonsaiLauncher",
  "version": "1.0.0",
  "identifier": "ai.bonsai.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bonsai Launcher",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "fullscreen": false,
        "hiddenTitle": false
      },
      {
        "label": "quick-panel",
        "title": "Bonsai Quick Panel",
        "width": 400,
        "height": 600,
        "minWidth": 350,
        "minHeight": 400,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "control-panel",
        "title": "Bonsai Control Panel",
        "width": 900,
        "height": 640,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/**",
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": [
      "msi",
      "nsis",
      "dmg",
      "appimage"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}

// Training Data Library (TDL) – Core Schema (Titan)
// Robust, organized infrastructure for ML training data collection and management

module transfer_test::training_data_library

use core::string::String
use core::vec::Vec
use core::map::Map
use core::time::Timestamp
use core::hash::Hash

// ============================================================================
// TDL Core Types
// ============================================================================

pub struct TrainingDataLibrary {
    pub library_id: String,
    pub version: String,
    pub created_at: Timestamp,
    pub updated_at: Timestamp,
    pub total_samples: u64,
    pub total_bytes: u64,
    pub datasets: Vec<TrainingDataset>,
    pub metadata: LibraryMetadata,
}

pub struct TrainingDataset {
    pub dataset_id: String,
    pub name: String,
    pub description: String,
    pub version: String,
    pub created_at: Timestamp,
    pub updated_at: Timestamp,
    pub sample_count: u64,
    pub total_size_bytes: u64,
    pub schemas: Vec<DataSchema>,
    pub statistics: DatasetStatistics,
    pub quality_score: f64,
    pub tags: Vec<String>,
    pub is_validated: bool,
}

pub struct DataSchema {
    pub schema_id: String,
    pub name: String,
    pub version: String,
    pub fields: Vec<SchemaField>,
    pub compression: String,
    pub encoding: String,
}

pub struct SchemaField {
    pub field_name: String,
    pub field_type: FieldType,
    pub description: String,
    pub required: bool,
    pub unit: Option<String>,
    pub min_value: Option<f64>,
    pub max_value: Option<f64>,
    pub precision: Option<u32>,
}

pub enum FieldType {
    Integer,
    Float,
    String,
    Boolean,
    Timestamp,
    Bytes,
    Array(Box<FieldType>),
    Struct(Vec<String>),
    Enum(Vec<String>),
}

// ============================================================================
// Lane Data Collection (Per-Lane Training Data)
// ============================================================================

pub struct LaneTrainingData {
    pub lane_id: String,
    pub lane_type: String,  // "tcp", "quic", "webrtc", "relay"
    pub test_id: String,
    pub transfer_id: String,
    pub samples: Vec<LaneSample>,
    pub aggregate_stats: LaneAggregateStats,
    pub collected_at: Timestamp,
}

pub struct LaneSample {
    pub sample_id: u64,
    pub timestamp: u64,           // milliseconds since transfer start
    pub sequence_number: u64,      // packet sequence
    pub bytes_sent: u64,
    pub bytes_received: u64,
    pub bytes_retransmitted: u64,
    pub latency_ms: f64,
    pub jitter_ms: f64,
    pub throughput_mbps: f64,
    pub rtt_min_ms: f64,
    pub rtt_max_ms: f64,
    pub rtt_avg_ms: f64,
    pub packets_sent: u32,
    pub packets_received: u32,
    pub packets_lost: u32,
    pub packets_retransmitted: u32,
    pub loss_rate_percent: f64,
    pub congestion_window_bytes: u32,
    pub in_flight_bytes: u32,
    pub buffer_fill_percent: f64,
    pub cpu_percent: f32,
    pub memory_mb: u32,
    pub error_count: u32,
    pub error_types: Vec<String>,
}

pub struct LaneAggregateStats {
    pub lane_type: String,
    pub total_bytes_transferred: u64,
    pub total_duration_ms: u64,
    pub avg_throughput_mbps: f64,
    pub peak_throughput_mbps: f64,
    pub min_throughput_mbps: f64,
    pub avg_latency_ms: f64,
    pub min_latency_ms: f64,
    pub max_latency_ms: f64,
    pub avg_jitter_ms: f64,
    pub total_packets_sent: u64,
    pub total_packets_lost: u64,
    pub total_packets_retransmitted: u64,
    pub overall_loss_rate: f64,
    pub overall_retransmit_rate: f64,
    pub timeouts_count: u32,
    pub errors_count: u32,
    pub availability_percent: f64,
    pub efficiency_score: f64,
    pub reliability_score: f64,
}

// ============================================================================
// Transfer Session Training Data
// ============================================================================

pub struct TransferSessionData {
    pub session_id: String,
    pub test_id: String,
    pub source_node: String,
    pub dest_node: String,
    pub file_size_bytes: u64,
    pub transfer_start: Timestamp,
    pub transfer_end: Timestamp,
    pub total_duration_ms: u64,
    pub lanes_used: Vec<String>,
    pub lane_data: Vec<LaneTrainingData>,
    pub encryption_enabled: bool,
    pub encryption_algorithm: String,
    pub compression_enabled: bool,
    pub compression_ratio: f64,
    pub multi_path_enabled: bool,
    pub network_conditions: NetworkConditions,
    pub file_hash_source: String,
    pub file_hash_destination: String,
    pub hash_verification_success: bool,
    pub metadata: SessionMetadata,
}

pub struct NetworkConditions {
    pub base_latency_ms: f64,
    pub latency_variance_ms: f64,
    pub packet_loss_percent: f64,
    pub jitter_percent: f64,
    pub bandwidth_limit_mbps: Option<f64>,
    pub nat_type: String,          // "direct", "nat", "double_nat", "relay"
    pub firewall_restrictive: bool,
    pub is_mobile: bool,
    pub interface_type: String,    // "ethernet", "wifi", "cellular"
}

pub struct SessionMetadata {
    pub source_region: String,
    pub dest_region: String,
    pub geographic_distance_km: f64,
    pub test_timestamp: Timestamp,
    pub test_environment: String,  // "dev", "staging", "production"
    pub omnisystem_version: String,
    pub transfer_daemon_version: String,
    pub ftdaemon_version: String,
    pub success: bool,
    pub failure_reason: Option<String>,
    pub notes: String,
}

// ============================================================================
// ML Feature Vectors
// ============================================================================

pub struct FeatureVector {
    pub vector_id: String,
    pub transfer_id: String,
    pub lane_id: String,
    pub timestamp: Timestamp,
    pub features: Map<String, f64>,
    pub label: String,             // "success", "degradation", "failure", "anomaly"
    pub confidence: f64,
    pub source_dataset: String,
}

pub struct FeatureSet {
    pub name: String,
    pub version: String,
    pub features: Vec<FeatureDefinition>,
    pub normalization: NormalizationConfig,
    pub selection_method: String,  // "correlation", "mutual_info", "rfe", etc.
}

pub struct FeatureDefinition {
    pub name: String,
    pub source_field: String,
    pub transformation: String,    // "raw", "log", "sqrt", "normalize", etc.
    pub aggregation_window_ms: Option<u64>,
    pub importance_score: f64,
}

pub struct NormalizationConfig {
    pub method: String,            // "minmax", "zscore", "robust", "log"
    pub min_value: f64,
    pub max_value: f64,
    pub mean_value: f64,
    pub std_dev: f64,
}

// ============================================================================
// Data Quality & Validation
// ============================================================================

pub struct DataQualityReport {
    pub report_id: String,
    pub dataset_id: String,
    pub timestamp: Timestamp,
    pub total_samples_checked: u64,
    pub valid_samples: u64,
    pub invalid_samples: u64,
    pub missing_fields: u64,
    pub duplicate_samples: u64,
    pub outlier_samples: u64,
    pub quality_score: f64,        // 0-1, >0.95 for production
    pub issues: Vec<QualityIssue>,
}

pub struct QualityIssue {
    pub issue_type: String,        // "missing_field", "invalid_value", "outlier", "duplicate"
    pub severity: String,          // "info", "warning", "error", "critical"
    pub field_name: String,
    pub sample_count: u64,
    pub description: String,
    pub remediation: String,
}

// ============================================================================
// Indexing & Retrieval
// ============================================================================

pub struct DataIndex {
    pub index_id: String,
    pub dataset_id: String,
    pub index_type: String,        // "time", "lane", "test", "network_condition"
    pub entries: Vec<IndexEntry>,
    pub created_at: Timestamp,
    pub updated_at: Timestamp,
    pub index_size_bytes: u64,
}

pub struct IndexEntry {
    pub key: String,
    pub value: String,
    pub sample_ids: Vec<u64>,
    pub metadata: Map<String, String>,
}

// ============================================================================
// Analytics & Intelligence
// ============================================================================

pub struct LanePerformanceProfile {
    pub lane_type: String,
    pub test_count: u64,
    pub avg_throughput_mbps: f64,
    pub std_dev_throughput: f64,
    pub percentile_p50: f64,
    pub percentile_p95: f64,
    pub percentile_p99: f64,
    pub reliability_percent: f64,
    pub typical_use_case: String,
    pub optimal_conditions: String,
    pub degradation_threshold: String,
}

pub struct AnomalyDetectionModel {
    pub model_id: String,
    pub lane_type: String,
    pub algorithm: String,         // "zscore", "isolation_forest", "autoencoder"
    pub sensitivity: f64,
    pub baseline_stats: Map<String, f64>,
    pub threshold_values: Map<String, f64>,
    pub last_trained: Timestamp,
    pub accuracy_percent: f64,
}

pub struct TrendAnalysis {
    pub trend_id: String,
    pub dataset_id: String,
    pub time_window_days: u32,
    pub metric_name: String,
    pub baseline_value: f64,
    pub current_value: f64,
    pub change_percent: f64,
    pub trend_direction: String,   // "improving", "degrading", "stable"
    pub statistical_significance: f64,
    pub confidence_level: f64,
}

// ============================================================================
// Library Metadata & Statistics
// ============================================================================

pub struct LibraryMetadata {
    pub creation_date: Timestamp,
    pub last_updated: Timestamp,
    pub maintainer: String,
    pub license: String,
    pub description: String,
    pub supported_ml_frameworks: Vec<String>,
    pub documentation_url: String,
    pub data_retention_days: u32,
    pub backup_locations: Vec<String>,
    pub integrity_checksum: String,
}

pub struct DatasetStatistics {
    pub total_samples: u64,
    pub date_range_start: Timestamp,
    pub date_range_end: Timestamp,
    pub avg_sample_size_bytes: u64,
    pub max_sample_size_bytes: u64,
    pub min_sample_size_bytes: u64,
    pub storage_efficiency_percent: f64,
    pub compression_ratio: f64,
    pub lane_distribution: Map<String, u64>,
    pub test_environment_distribution: Map<String, u64>,
    pub network_condition_distribution: Map<String, u64>,
    pub success_rate_percent: f64,
    pub geographic_coverage: Vec<String>,
}

// ============================================================================
// Export & Integration Formats
// ============================================================================

pub struct ExportConfig {
    pub format: String,            // "json", "parquet", "tensorflow", "pytorch", "csv"
    pub compression: String,       // "none", "gzip", "zstd", "lz4"
    pub include_features: Vec<String>,
    pub include_labels: bool,
    pub train_test_split: f64,     // e.g., 0.8 for 80-20 split
    pub normalize_features: bool,
    pub remove_outliers: bool,
    pub sample_limit: Option<u64>,
}

pub struct DataExport {
    pub export_id: String,
    pub dataset_id: String,
    pub format: String,
    pub file_path: String,
    pub file_size_bytes: u64,
    pub sample_count: u64,
    pub checksum: String,
    pub created_at: Timestamp,
    pub expiration_at: Option<Timestamp>,
}

// ============================================================================
// Performance Metrics for Training
// ============================================================================

pub struct PerformanceMetrics {
    pub metrics_id: String,
    pub lane_type: String,
    pub file_size_mb: u64,
    pub throughput_percentiles: PercentileStats,
    pub latency_percentiles: PercentileStats,
    pub loss_percentiles: PercentileStats,
    pub availability_percent: f64,
    pub mtbf_hours: f64,           // Mean time between failures
    pub mttr_seconds: f64,         // Mean time to recover
}

pub struct PercentileStats {
    pub p1: f64,
    pub p5: f64,
    pub p25: f64,
    pub p50: f64,
    pub p75: f64,
    pub p95: f64,
    pub p99: f64,
    pub p999: f64,
    pub mean: f64,
    pub std_dev: f64,
}

// ============================================================================
// Constants
// ============================================================================

pub const TDL_VERSION: &str = "1.0.0"
pub const MIN_QUALITY_SCORE: f64 = 0.95
pub const DEFAULT_SAMPLE_RATE_MS: u64 = 100
pub const COMPRESSION_RATIO_TARGET: f64 = 0.5
pub const DATA_RETENTION_DAYS: u32 = 365

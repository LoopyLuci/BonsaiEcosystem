{
  "seed": 42,
  "description": "Phase 4: LoRA Adapter Stacking (100 independent adapters)",
  "model": {
    "num_layers": 100,
    "hidden_dim": 1024,
    "num_heads": 16,
    "ffn_dim": 4096,
    "vocab_size": 32000,
    "max_seq_len": 2048
  },
  "lora": {
    "num_adapters": 100,
    "rank": 32,
    "alpha": 16,
    "dropout": 0.05,
    "layers_to_adapt": "all",
    "modules_to_adapt": [
      "self_attn",
      "ffn"
    ]
  },
  "adapter_training": {
    "freeze_base_model": true,
    "train_sequentially": true,
    "initialization": "kaiming_uniform"
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 1e-3,
    "warmup_steps": 500,
    "epochs_per_adapter": 5,
    "eval_interval": 100,
    "save_interval": 200,
    "gradient_clip": 1.0,
    "weight_decay": 0.01
  },
  "data": {
    "sources": [
      "pile_subset_2B.arrow"
    ],
    "batch_composition": "specialized",
    "curriculum": "mixed",
    "sequence_length": 2048,
    "num_workers": 4,
    "domain_sampling": true
  },
  "hardware": {
    "device": "cuda",
    "dtype": "float16",
    "mixed_precision": true,
    "num_gpus": 128,
    "distributed": true,
    "backend": "nccl",
    "gradient_accumulation_steps": 1
  },
  "monitoring": {
    "log_interval": 50,
    "eval_interval": 100,
    "save_interval": 200,
    "track_per_adapter_metrics": true,
    "tensorboard": true,
    "wandb": true
  }
}

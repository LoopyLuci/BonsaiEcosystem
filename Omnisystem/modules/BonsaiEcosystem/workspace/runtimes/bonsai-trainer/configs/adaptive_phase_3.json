{
  "seed": 42,
  "description": "Phase 3: Expert Pool Training (1 → 1024 experts)",
  "model": {
    "num_layers": 100,
    "hidden_dim": 1024,
    "num_heads": 16,
    "ffn_dim": 4096,
    "vocab_size": 32000,
    "max_seq_len": 2048,
    "activation": "gelu",
    "dropout": 0.1
  },
  "expert_pool": {
    "initial_experts": 1,
    "final_experts": 1024,
    "expansion_schedule": [
      {"num_experts": 2, "epochs": 5},
      {"num_experts": 4, "epochs": 5},
      {"num_experts": 8, "epochs": 5},
      {"num_experts": 16, "epochs": 5},
      {"num_experts": 32, "epochs": 5},
      {"num_experts": 64, "epochs": 5},
      {"num_experts": 128, "epochs": 5},
      {"num_experts": 256, "epochs": 5},
      {"num_experts": 512, "epochs": 5},
      {"num_experts": 1024, "epochs": 10}
    ],
    "expert_type": "ffn",
    "routing_top_k": 2
  },
  "routing": {
    "router_type": "linear",
    "top_k": 2,
    "load_balance_loss_weight": 0.01,
    "aux_loss_weight": 0.01
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 3e-4,
    "learning_rate_scale_new_experts": 2.0,
    "warmup_steps": 1000,
    "eval_interval": 200,
    "save_interval": 500,
    "gradient_clip": 1.0,
    "weight_decay": 0.01
  },
  "data": {
    "sources": [
      "pile_subset_5B.arrow"
    ],
    "batch_composition": "structured",
    "curriculum": "by_difficulty",
    "sequence_length": 2048,
    "num_workers": 4
  },
  "hardware": {
    "device": "cuda",
    "dtype": "float16",
    "mixed_precision": true,
    "num_gpus": 256,
    "distributed": true,
    "backend": "nccl",
    "gradient_accumulation_steps": 2
  },
  "monitoring": {
    "log_interval": 100,
    "eval_interval": 200,
    "save_interval": 500,
    "track_expert_load": true,
    "tensorboard": true,
    "wandb": true
  }
}

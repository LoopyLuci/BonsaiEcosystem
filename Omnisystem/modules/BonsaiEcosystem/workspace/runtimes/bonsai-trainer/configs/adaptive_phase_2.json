{
  "seed": 42,
  "description": "Phase 2: Progressive Width Expansion (256 → 1024 hidden dim)",
  "model": {
    "num_layers": 100,
    "hidden_dim": 256,
    "num_heads": 4,
    "ffn_dim": 1024,
    "vocab_size": 32000,
    "max_seq_len": 2048,
    "activation": "gelu",
    "dropout": 0.1
  },
  "width_expansions": [
    {
      "factor": 2,
      "hidden_dim": 512,
      "ffn_dim": 2048,
      "num_heads": 8,
      "epochs": 10
    },
    {
      "factor": 3,
      "hidden_dim": 768,
      "ffn_dim": 3072,
      "num_heads": 12,
      "epochs": 10
    },
    {
      "factor": 4,
      "hidden_dim": 1024,
      "ffn_dim": 4096,
      "num_heads": 16,
      "epochs": 10
    }
  ],
  "expansion_config": {
    "initialization_strategy": "identity_scale",
    "scale_factor": 0.1,
    "learning_rate_scale": 1.0
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 3e-4,
    "warmup_steps": 2000,
    "epochs_per_expansion": 10,
    "eval_interval": 200,
    "save_interval": 500,
    "gradient_clip": 1.0,
    "weight_decay": 0.01
  },
  "data": {
    "sources": [
      "pile_subset_10B.arrow"
    ],
    "batch_composition": "balanced",
    "curriculum": "by_difficulty",
    "sequence_length": 1024,
    "num_workers": 4
  },
  "hardware": {
    "device": "cuda",
    "dtype": "float32",
    "mixed_precision": true,
    "num_gpus": 256,
    "distributed": true,
    "backend": "nccl"
  },
  "monitoring": {
    "log_interval": 100,
    "eval_interval": 200,
    "save_interval": 500,
    "tensorboard": true,
    "wandb": true
  }
}

{
  "name": "omnisystem-module-manager",
  "displayName": "Omnisystem Module Manager",
  "description": "VSCode integration for Omnisystem module management and real-time monitoring",
  "version": "1.0.0",
  "publisher": "omnisystem",
  "author": "Omnisystem Team",
  "license": "Apache-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnisystem/omnisystem"
  },
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=16.0.0"
  },
  "categories": [
    "Other",
    "Debuggers",
    "Formatters"
  ],
  "keywords": [
    "omnisystem",
    "modules",
    "compilation",
    "distributed",
    "modular"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:omnisystem.showDashboard",
    "onCommand:omnisystem.toggleModule",
    "onCommand:omnisystem.toggleCapability"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "omnisystem.showDashboard",
        "title": "Show Omnisystem Dashboard",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.listModules",
        "title": "List Modules",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.toggleModule",
        "title": "Toggle Module",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.listCapabilities",
        "title": "List Capabilities",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.toggleCapability",
        "title": "Toggle Capability",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.switchMode",
        "title": "Switch Mode (OmniOS/Bonsai)",
        "category": "Omnisystem"
      },
      {
        "command": "omnisystem.healthCheck",
        "title": "Run Health Check",
        "category": "Omnisystem"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omnisystem",
          "title": "Omnisystem",
          "icon": "media/omnisystem.svg"
        }
      ]
    },
    "views": {
      "omnisystem": [
        {
          "id": "omnisystem.status",
          "name": "Status",
          "when": "omnisystem.installed"
        },
        {
          "id": "omnisystem.modules",
          "name": "Modules",
          "when": "omnisystem.installed"
        },
        {
          "id": "omnisystem.capabilities",
          "name": "Capabilities",
          "when": "omnisystem.installed"
        },
        {
          "id": "omnisystem.marketplace",
          "name": "Marketplace",
          "when": "omnisystem.installed"
        }
      ]
    },
    "statusBar": [
      {
        "id": "omnisystem.status",
        "alignment": "right",
        "priority": 100
      }
    ],
    "configuration": {
      "title": "Omnisystem",
      "properties": {
        "omnisystem.mode": {
          "type": "string",
          "enum": [
            "omnios",
            "bonsai"
          ],
          "default": "omnios",
          "description": "Omnisystem operational mode"
        },
        "omnisystem.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh module status"
        },
        "omnisystem.refreshInterval": {
          "type": "number",
          "default": 5000,
          "description": "Status refresh interval in milliseconds"
        },
        "omnisystem.enableTelemetry": {
          "type": "boolean",
          "default": true,
          "description": "Enable telemetry collection"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.70.0",
    "typescript": "^4.7.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}

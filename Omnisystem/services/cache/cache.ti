// services/omni-cache/cache.ti — Distributed caching with TTL

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TAG_ENTRY: i64 = 9800;
const TAG_CACHE: i64 = 9801;

// Cache entry: body=key, arg=value, domain=expires_tick
// In the kernel context, time is measured in scheduler ticks.
// expires_tick = insert_tick + ttl_ticks (0 = never expires)
pub fn entry_new(key: i64, value: i64, ttl_ticks: i64) -> i64 {
    let e = heap_alloc_term();
    heap_set_tag(e, TAG_ENTRY);
    heap_set_body(e, key);
    heap_set_arg(e, value);
    heap_set_domain(e, ttl_ticks);  // absolute expiry tick (set by cache on insert)
    return e;
}

pub fn entry_key(e: i64) -> i64 { return heap_get_body(e); }
pub fn entry_value(e: i64) -> i64 { return heap_get_arg(e); }
pub fn entry_expires(e: i64) -> i64 { return heap_get_domain(e); }
pub fn entry_expired(e: i64, now: i64) -> i64 {
    let exp = entry_expires(e);
    if exp == 0 { return 0; }  // never expires
    if now > exp { return 1; }
    return 0;
}

// Cache: body=entry_list_head, arg=count, domain=tick (current time)
pub fn cache_new() -> i64 {
    let c = heap_alloc_term();
    heap_set_tag(c, TAG_CACHE);
    heap_set_body(c, 0);
    heap_set_arg(c, 0);
    heap_set_domain(c, 0);
    return c;
}

pub fn cache_tick(c: i64) -> i64 { return heap_get_domain(c); }
pub fn cache_advance(c: i64) {
    heap_set_domain(c, heap_get_domain(c) + 1);
    return;
}

pub fn cache_set(c: i64, key: i64, value: i64, ttl_ticks: i64) {
    let now = cache_tick(c);
    let expires = 0;
    if ttl_ticks > 0 { expires = now + ttl_ticks; }

    // Check if key exists — update
    let cur = heap_get_body(c);
    while cur != 0 {
        let e = heap_get_body(cur);
        if entry_key(e) == key {
            heap_set_arg(e, value);
            heap_set_domain(e, expires);
            return;
        }
        cur = heap_get_arg(cur);
    }

    // Insert new entry (prepend)
    let e = entry_new(key, value, expires);
    let node = heap_alloc_term();
    heap_set_tag(node, TAG_ENTRY + 1);
    heap_set_body(node, e);
    heap_set_arg(node, heap_get_body(c));
    heap_set_body(c, node);
    heap_set_arg(c, heap_get_arg(c) + 1);
    return;
}

pub fn cache_get(c: i64, key: i64) -> i64 {
    let now = cache_tick(c);
    let cur = heap_get_body(c);
    while cur != 0 {
        let e = heap_get_body(cur);
        if entry_key(e) == key {
            if entry_expired(e, now) != 0 { return -1; }
            return entry_value(e);
        }
        cur = heap_get_arg(cur);
    }
    return -1;
}

pub fn cache_clear(c: i64) {
    heap_set_body(c, 0);
    heap_set_arg(c, 0);
    return;
}

pub fn cache_count(c: i64) -> i64 { return heap_get_arg(c); }

pub fn main() -> i64 {
    // Test 1: cache entry
    let e = entry_new(10, 100, 0);
    if entry_expired(e, 9999) != 0 { return 1; }  // never expires

    // Test 2: cache set/get
    let c = cache_new();
    cache_set(c, 1, 42, 0);  // key=1, value=42, no TTL
    let v = cache_get(c, 1);
    if v != 42 { return 2; }

    // Test 3: cache count
    cache_set(c, 2, 99, 0);
    if cache_count(c) != 2 { return 3; }

    // Test 4: cache clear
    cache_clear(c);
    if cache_count(c) != 0 { return 4; }

    // Test 5: cache miss
    let c2 = cache_new();
    if cache_get(c2, 999) != -1 { return 5; }

    // Test 6: TTL expiry
    let c3 = cache_new();
    cache_set(c3, 7, 77, 5);   // TTL = 5 ticks
    // Advance time past TTL
    cache_advance(c3); cache_advance(c3); cache_advance(c3);
    cache_advance(c3); cache_advance(c3); cache_advance(c3);  // now = 6 > expires = 5
    let v2 = cache_get(c3, 7);
    if v2 != -1 { return 6; }  // should be expired

    return 0;
}

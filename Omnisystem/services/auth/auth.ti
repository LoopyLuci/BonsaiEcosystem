// services/omni-auth/auth.ti — Authentication and authorization with capability integration

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TAG_PRINCIPAL: i64 = 9960;
const TAG_PERM:      i64 = 9961;
const TAG_SERVICE:   i64 = 9962;
const TAG_NODE:      i64 = 9963;

// Auth levels (ordered)
const LEVEL_PUBLIC: i64 = 0;
const LEVEL_USER:   i64 = 1;
const LEVEL_ADMIN:  i64 = 2;
const LEVEL_SYSTEM: i64 = 3;

// Principal: body=id_hash, arg=auth_level, domain=perm_list_head
pub fn principal_new(id_hash: i64, auth_level: i64) -> i64 {
    let p = heap_alloc_term();
    heap_set_tag(p, TAG_PRINCIPAL);
    heap_set_body(p, id_hash);
    heap_set_arg(p, auth_level);
    heap_set_domain(p, 0);   // empty permission list
    return p;
}

pub fn principal_id(p: i64) -> i64 { return heap_get_body(p); }
pub fn principal_level(p: i64) -> i64 { return heap_get_arg(p); }

pub fn principal_grant(p: i64, perm_hash: i64) {
    let node = heap_alloc_term();
    heap_set_tag(node, TAG_PERM);
    heap_set_body(node, perm_hash);
    heap_set_arg(node, heap_get_domain(p));
    heap_set_domain(p, node);
    return;
}

pub fn principal_has_perm(p: i64, perm_hash: i64) -> i64 {
    let cur = heap_get_domain(p);
    while cur != 0 {
        if heap_get_body(cur) == perm_hash { return 1; }
        cur = heap_get_arg(cur);
    }
    return 0;
}

pub fn principal_has_level(p: i64, required: i64) -> i64 {
    if principal_level(p) >= required { return 1; }
    return 0;
}

// Auth service: body=principal_list_head, arg=count
let g_auth_list:  i64 = 0;
let g_auth_count: i64 = 0;

pub fn auth_new() -> i64 {
    g_auth_list = 0;
    g_auth_count = 0;
    return 1;
}

pub fn auth_register(p: i64) {
    let node = heap_alloc_term();
    heap_set_tag(node, TAG_NODE);
    heap_set_body(node, p);
    heap_set_arg(node, g_auth_list);
    g_auth_list = node;
    g_auth_count = g_auth_count + 1;
    return;
}

pub fn auth_find(id_hash: i64) -> i64 {
    let cur = g_auth_list;
    while cur != 0 {
        let p = heap_get_body(cur);
        if principal_id(p) == id_hash { return p; }
        cur = heap_get_arg(cur);
    }
    return -1;
}

pub fn auth_authenticate(id_hash: i64) -> i64 {
    return auth_find(id_hash);
}

pub fn auth_authorize(id_hash: i64, perm_hash: i64) -> i64 {
    let p = auth_authenticate(id_hash);
    if p < 0 { return 0; }
    return principal_has_perm(p, perm_hash);
}

pub fn auth_count() -> i64 { return g_auth_count; }

pub fn main() -> i64 {
    // Test 1: principal creation
    let p1 = principal_new(1001, LEVEL_USER);
    if principal_id(p1) != 1001 { return 1; }
    if principal_level(p1) != LEVEL_USER { return 2; }

    // Test 2: permissions
    principal_grant(p1, 7777);  // "read" permission hash
    if principal_has_perm(p1, 7777) != 1 { return 3; }
    if principal_has_perm(p1, 8888) != 0 { return 4; }

    // Test 3: auth level comparison
    let admin = principal_new(2001, LEVEL_ADMIN);
    if principal_has_level(admin, LEVEL_USER) != 1 { return 5; }
    if principal_has_level(admin, LEVEL_ADMIN) != 1 { return 6; }
    if principal_has_level(admin, LEVEL_SYSTEM) != 0 { return 7; }

    // Test 4: auth service register
    auth_new();
    let p2 = principal_new(3001, LEVEL_USER);
    auth_register(p2);
    if auth_count() != 1 { return 8; }

    // Test 5: authenticate
    let found = auth_authenticate(3001);
    if found < 0 { return 9; }
    if principal_id(found) != 3001 { return 10; }

    // Test 6: authorize
    principal_grant(p2, 555);
    if auth_authorize(3001, 555) != 1 { return 11; }
    if auth_authorize(3001, 999) != 0 { return 12; }

    return 0;
}

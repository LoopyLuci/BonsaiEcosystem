#[cfg(feature = "ai")]
extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
}

#[cfg(feature = "ai")]
const TAG_ML_ADVISOR: i64 = 10550;
const TAG_PREDICTION: i64 = 10551;
const TAG_ANOMALY: i64 = 10552;

#[cfg(feature = "ai")]
pub fn ml_advisor_new(model_version: &str) -> i64 {
    let advisor = heap_alloc_term();
    heap_set_tag(advisor, TAG_ML_ADVISOR);
    heap_set_body(advisor, 0);    // models loaded from CAS
    return advisor;
}


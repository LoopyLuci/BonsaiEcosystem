// services/init/mod.ti – UOSC Init System
// First userspace process; boots the OS and manages all services

module init

use kernel::uosc_os::{syscall_process_create, CapabilitySet, ProcessHandle}
use service_manager::ServiceManager
use aether::actor::Actor
use core::collections::HashMap

/// Init process: boots UOSC and starts all essential services
pub async fn init_main() -> Result<(), String> {
    eprintln!("[init] Boot started");

    // Step 1: Mount root filesystem
    mount_root_filesystem().await?;
    eprintln!("[init] Root filesystem mounted");

    // Step 2: Load system configuration
    let config = load_system_config().await?;
    eprintln!("[init] Configuration loaded");

    // Step 3: Start core services in dependency order
    start_core_services(&config).await?;
    eprintln!("[init] Core services started");

    // Step 4: Start system management services
    start_system_services(&config).await?;
    eprintln!("[init] System services started");

    // Step 5: Wait for shutdown signal
    wait_for_shutdown().await?;
    eprintln!("[init] Shutdown initiated");

    // Step 6: Graceful shutdown
    shutdown_all_services().await?;
    eprintln!("[init] All services stopped");

    Ok(())
}


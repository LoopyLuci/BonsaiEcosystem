// services/omni-container/container.ti — Lightweight sandboxed process containers

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TAG_CONTAINER: i64 = 9500;
const TAG_RUNTIME:   i64 = 9501;
const TAG_NODE:      i64 = 9502;

// Container states
const STATE_CREATED: i64 = 0;
const STATE_RUNNING: i64 = 1;
const STATE_PAUSED:  i64 = 2;
const STATE_STOPPED: i64 = 3;
const STATE_FAILED:  i64 = 4;

// Error codes
const ERR_BAD_STATE: i64 = -1;
const ERR_OK:        i64 = 0;

// Container: body=id, arg=memory_limit_kb, domain=state*100+cpu_quota
pub fn container_new(id: i64, mem_limit_kb: i64) -> i64 {
    let c = heap_alloc_term();
    heap_set_tag(c, TAG_CONTAINER);
    heap_set_body(c, id);
    heap_set_arg(c, mem_limit_kb);
    heap_set_domain(c, STATE_CREATED * 100 + 100);  // state=CREATED, cpu_quota=100%
    return c;
}

pub fn container_id(c: i64) -> i64 { return heap_get_body(c); }
pub fn container_mem(c: i64) -> i64 { return heap_get_arg(c); }
pub fn container_state(c: i64) -> i64 { return heap_get_domain(c) / 100; }
pub fn container_cpu(c: i64) -> i64 { return heap_get_domain(c) - (container_state(c) * 100); }

pub fn container_set_state(c: i64, st: i64) {
    let cpu = container_cpu(c);
    heap_set_domain(c, st * 100 + cpu);
    return;
}

pub fn container_start(c: i64) -> i64 {
    let st = container_state(c);
    if st == STATE_CREATED || st == STATE_STOPPED {
        container_set_state(c, STATE_RUNNING);
        return ERR_OK;
    }
    return ERR_BAD_STATE;
}

pub fn container_pause(c: i64) -> i64 {
    if container_state(c) != STATE_RUNNING { return ERR_BAD_STATE; }
    container_set_state(c, STATE_PAUSED);
    return ERR_OK;
}

pub fn container_resume(c: i64) -> i64 {
    if container_state(c) != STATE_PAUSED { return ERR_BAD_STATE; }
    container_set_state(c, STATE_RUNNING);
    return ERR_OK;
}

pub fn container_stop(c: i64) -> i64 {
    let st = container_state(c);
    if st == STATE_RUNNING || st == STATE_PAUSED {
        container_set_state(c, STATE_STOPPED);
        return ERR_OK;
    }
    return ERR_BAD_STATE;
}

// Container runtime: body=container_list_head, arg=0, domain=count
let g_runtime_count: i64 = 0;
let g_runtime_list:  i64 = 0;

pub fn runtime_new() -> i64 {
    g_runtime_count = 0;
    g_runtime_list = 0;
    return 1;
}

pub fn runtime_create(mem_limit_kb: i64) -> i64 {
    let id = g_runtime_count;
    let c = container_new(id, mem_limit_kb);
    let node = heap_alloc_term();
    heap_set_tag(node, TAG_NODE);
    heap_set_body(node, c);
    heap_set_arg(node, g_runtime_list);
    g_runtime_list = node;
    g_runtime_count = g_runtime_count + 1;
    return id;
}

pub fn runtime_get(id: i64) -> i64 {
    let cur = g_runtime_list;
    while cur != 0 {
        let c = heap_get_body(cur);
        if container_id(c) == id { return c; }
        cur = heap_get_arg(cur);
    }
    return -1;
}

pub fn runtime_count() -> i64 { return g_runtime_count; }

pub fn runtime_list_states() -> i64 {
    // Returns count of CREATED state containers (for test)
    let count = 0;
    let cur = g_runtime_list;
    while cur != 0 {
        let c = heap_get_body(cur);
        if container_state(c) == STATE_CREATED { count = count + 1; }
        cur = heap_get_arg(cur);
    }
    return count;
}

pub fn main() -> i64 {
    // Test 1: container creation
    let c1 = container_new(1, 512 * 1024);
    if container_state(c1) != STATE_CREATED { return 1; }

    // Test 2: container lifecycle
    if container_start(c1) != ERR_OK { return 2; }
    if container_state(c1) != STATE_RUNNING { return 3; }
    if container_pause(c1) != ERR_OK { return 4; }
    if container_state(c1) != STATE_PAUSED { return 5; }
    if container_resume(c1) != ERR_OK { return 6; }
    if container_state(c1) != STATE_RUNNING { return 7; }
    if container_stop(c1) != ERR_OK { return 8; }
    if container_state(c1) != STATE_STOPPED { return 9; }

    // Test 3: invalid transitions
    let c2 = container_new(2, 256 * 1024);
    if container_pause(c2) != ERR_BAD_STATE { return 10; }
    if container_resume(c2) != ERR_BAD_STATE { return 11; }

    // Test 4: runtime creation
    runtime_new();
    if runtime_count() != 0 { return 12; }

    // Test 5: runtime create container
    let id1 = runtime_create(512 * 1024);
    let id2 = runtime_create(256 * 1024);
    if runtime_count() != 2 { return 13; }
    if id1 != 0 { return 14; }
    if id2 != 1 { return 15; }

    // Test 6: runtime list containers
    if runtime_list_states() != 2 { return 16; }

    return 0;
}

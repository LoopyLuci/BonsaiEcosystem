// adapters/gemini_adapter.ti – Google Gemini adapter
module omnisystem::adapters::gemini

use omnisystem::ai::provider::{AiProvider, Message, ChatConfig, ChatResponse, Usage, StreamHandle, StreamChunk}
use omnisystem::secrets::SecretsVault
use http::client::HttpClient
use async::async_trait
use serde_json

pub struct GeminiAdapter {
    secret_name: String,
    secrets: Arc<SecretsVault>,
    http: HttpClient,
    base_url: String,
}

impl GeminiAdapter {
    pub fn new(secret_name: &str, secrets: Arc<SecretsVault>) -> Self {
        Self {
            secret_name: secret_name.to_string(),
            secrets,
            http: HttpClient::new(),
            base_url: "https://generativelanguage.googleapis.com/v1beta/models".to_string(),
        }
    }

    fn get_api_key(&self) -> Result<String, String> {
        self.secrets.get_secret("default", &self.secret_name, None)
            .map(|bytes| String::from_utf8(bytes).unwrap_or_default())
    }
}

#[async_trait]
impl AiProvider for GeminiAdapter {
    fn name(&self) -> &str { "gemini" }
    fn display_name(&self) -> &str { "Google Gemini" }
    fn supports_streaming(&self) -> bool { true }

    fn list_models(&self) -> Vec<String> {
        vec![
            "gemini-2.0-flash".to_string(),
            "gemini-1.5-pro".to_string(),
            "gemini-1.5-flash".to_string(),
            "gemini-1.0-pro".to_string(),
        ]
    }

    fn cost_per_token(&self, model: &str) -> (f64, f64) {
        match model {
            m if m.contains("2.0-flash") => (0.075, 0.3),
            m if m.contains("1.5-pro") => (1.25, 5.0),
            m if m.contains("1.5-flash") => (0.075, 0.3),
            m if m.contains("1.0-pro") => (0.5, 1.5),
            _ => (0.075, 0.3),
        }
    }

    async fn chat(&self, messages: &[Message], config: &ChatConfig) -> Result<ChatResponse, String> {
        let api_key = self.get_api_key()?;

        let mut contents = Vec::new();
        for msg in messages {
            if msg.role != "system" {
                contents.push(json!({
                    "role": if msg.role == "user" { "user" } else { "model" },
                    "parts": [{"text": msg.content}]
                }));
            }
        }

        let body = json!({
            "contents": contents,
            "generationConfig": {
                "maxOutputTokens": config.max_tokens,
                "temperature": config.temperature,
                "topP": config.top_p,
            },
            "safetySettings": []
        });

        let url = format!("{}:generateContent?key={}", self.base_url, api_key);
        let response = self.http.post(&url, &body, "")
            .send().await?;

        let data: Value = serde_json::from_str(&response)?;

        let content = data["candidates"][0]["content"]["parts"][0]["text"]
            .as_str()
            .unwrap_or("")
            .to_string();

        let usage_data = data["usageMetadata"].clone();
        let input_tokens = usage_data["promptTokenCount"].as_u64().unwrap_or(0);
        let output_tokens = usage_data["candidatesTokenCount"].as_u64().unwrap_or(0);

        Ok(ChatResponse {
            content,
            provider: self.name().to_string(),
            model: config.model.clone(),
            confidence: 0.93,
            usage: Usage {
                input_tokens,
                output_tokens,
                total_tokens: input_tokens + output_tokens,
            },
            finish_reason: "stop".to_string(),
            metadata: map!{},
        })
    }

    async fn stream_chat(&self, messages: &[Message], config: &ChatConfig) -> Result<StreamHandle, String> {
        let api_key = self.get_api_key()?;
        let (tx, rx) = async_channel::unbounded();

        let mut contents = Vec::new();
        for msg in messages {
            if msg.role != "system" {
                contents.push(json!({
                    "role": if msg.role == "user" { "user" } else { "model" },
                    "parts": [{"text": msg.content}]
                }));
            }
        }

        let body = json!({
            "contents": contents,
            "generationConfig": {
                "maxOutputTokens": config.max_tokens,
                "temperature": config.temperature,
            }
        });

        let http_clone = self.http.clone();
        let base_url = self.base_url.clone();
        let model = config.model.clone();

        spawn(async move {
            let url = format!("{}/{}:streamGenerateContent?key={}", base_url, model, api_key);
            if let Ok(stream) = http_clone.post_stream(&url, &body, "").await {
                // Parse streaming response and send chunks
                // Gemini uses server-sent events
            }
        });

        Ok(StreamHandle { receiver: rx })
    }

    async fn health_check(&self) -> Result<(), String> {
        let _api_key = self.get_api_key()?;
        Ok(())
    }
}

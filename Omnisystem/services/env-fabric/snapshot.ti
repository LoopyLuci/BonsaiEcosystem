}

// Fork an environment: create child with copy-on-write pages
pub fn fork_environment(snap: i64, fork_name: i64) -> i64 {
    // Create new environment with same spec as snapshot parent
    // Map all snapshot pages as copy-on-write
    // Child environment starts at snapshot state
    // Diverging writes create new pages
    // Parent and child share read-only pages

    let fork = heap_alloc_term();
    heap_set_tag(fork, TAG_FORK);
    heap_set_body(fork, snap);           // source snapshot
    heap_set_arg(fork, fork_name);       // fork name
    heap_set_domain(fork, 0);            // used memory (grows on write)
    return fork;
}

pub fn fork_source(f: i64) -> i64 { return heap_get_body(f); }
pub fn fork_name(f: i64) -> i64 { return heap_get_arg(f); }

// Create a branch: fork from a snapshot but with different seed/inputs
pub fn branch_from_snapshot(snap: i64, branch_name: i64) -> i64 {
    // Create new environment identical to snapshot
    // Same memory state, but independent execution
    // Useful for replaying different sequences of inputs from same point

    let fork = fork_environment(snap, branch_name);
    return fork;
}


// Migration: prepare vault for transfer to target host
pub fn migration_prepare(env_state: i64, target_host: i64) -> i64 {
    let mig = heap_alloc_term();
    heap_set_tag(mig, TAG_MIGRATION_STATE);
    heap_set_body(mig, env_state);       // environment to migrate
    heap_set_arg(mig, target_host);      // target host address
    heap_set_domain(mig, 0);             // transferred bytes (progress)
    return mig;
}

pub fn migration_env(mig: i64) -> i64 { return heap_get_body(mig); }
pub fn migration_target(mig: i64) -> i64 { return heap_get_arg(mig); }

// Pre-copy phase: iteratively transfer memory pages while vault runs
pub fn migration_precopy(mig: i64) -> i64 {
    // Start migration daemon
    // Iterate: scan for dirty pages, transfer to target host
    // If convergence (few dirty pages), stop
    // Otherwise, continue for bounded iterations

    let progress = 0i64; // bytes transferred
    let max_iterations = 10i64;
    let iteration = 0i64;

    while iteration < max_iterations {
        // Get dirty pages from this iteration
        let dirty_count = get_dirty_pages_count(migration_env(mig));
        if dirty_count == 0 {
            return 1; // converged
        }

        // Transfer dirty pages via p2p
        progress = progress + transfer_pages(mig, dirty_count);

        iteration = iteration + 1;
    }

    // Did not converge; fall back to post-copy
    return 2;
}

// Post-copy phase: brief pause, transfer CPU state, fetch memory on demand
pub fn migration_postcopy(mig: i64) -> i64 {
    // Pause environment (stop vCPUs)
    pause_environment(migration_env(mig));

    // Transfer remaining CPU state (registers, stack)
    transfer_cpu_state(mig);

    // Resume environment on target host
    // Missing pages fetched from source on demand over p2p
    resume_environment_on_target(mig);

    return 0; // success
}

// Complete live migration workflow
pub fn migrate_environment(env_state: i64, target_host: i64) -> i64 {
    let mig = migration_prepare(env_state, target_host);

    // Try pre-copy first
    let precopy_result = migration_precopy(mig);
    if precopy_result == 1 {
        // Converged; safe to pause and complete
        return migration_complete(mig);
    }

    // Pre-copy did not converge; use post-copy
    return migration_postcopy(mig);
}


// services/env-fabric/snapshot.ti – Recursive snapshots, forking, and live migration
// Enables instant cloning, point-in-time branches, and zero-downtime migration

extern "titan" {
    fn heap_alloc_term() -> i64;
    fn heap_set_tag(id: i64, tag: i64);
    fn heap_get_tag(id: i64) -> i64;
    fn heap_set_body(id: i64, body: i64);
    fn heap_get_body(id: i64) -> i64;
    fn heap_set_arg(id: i64, arg: i64);
    fn heap_get_arg(id: i64) -> i64;
    fn heap_set_domain(id: i64, dom: i64);
    fn heap_get_domain(id: i64) -> i64;
}

const TAG_SNAPSHOT: i64 = 10000;
const TAG_FORK: i64 = 10001;
const TAG_MIGRATION_STATE: i64 = 10002;
const TAG_SNAPSHOT_TREE: i64 = 10003;

// Snapshot: point-in-time capture of an environment
pub fn snapshot_new(env_id: i64, name: i64, timestamp: i64) -> i64 {
    let snap = heap_alloc_term();
    heap_set_tag(snap, TAG_SNAPSHOT);
    heap_set_body(snap, env_id);         // parent environment ID
    heap_set_arg(snap, name);            // snapshot name
    heap_set_domain(snap, timestamp);    // creation timestamp
    return snap;
}

pub fn snapshot_env_id(snap: i64) -> i64 { return heap_get_body(snap); }
pub fn snapshot_name(snap: i64) -> i64 { return heap_get_arg(snap); }
pub fn snapshot_timestamp(snap: i64) -> i64 { return heap_get_domain(snap); }


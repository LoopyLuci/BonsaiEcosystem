// Snapshot tree: hierarchy of related snapshots and forks
pub fn snapshot_tree_new() -> i64 {
    let tree = heap_alloc_term();
    heap_set_tag(tree, TAG_SNAPSHOT_TREE);
    heap_set_body(tree, 0);              // root snapshot
    heap_set_arg(tree, 0);               // forks list
    heap_set_domain(tree, 0);            // branches list
    return tree;
}

pub fn snapshot_tree_add_snapshot(tree: i64, snap: i64) {
    heap_set_body(tree, snap); // set as root
}

pub fn snapshot_tree_add_fork(tree: i64, fork: i64) {
    let forks = heap_get_arg(tree);
    heap_set_domain(fork, forks); // link to list
    heap_set_arg(tree, fork);     // add to head
}

pub fn snapshot_tree_root(tree: i64) -> i64 { return heap_get_body(tree); }
pub fn snapshot_tree_forks(tree: i64) -> i64 { return heap_get_arg(tree); }


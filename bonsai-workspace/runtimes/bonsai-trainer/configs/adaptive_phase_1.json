{
  "seed": 42,
  "description": "Phase 1: Progressive Depth Addition (4 → 100 layers)",
  "model": {
    "num_layers": 100,
    "hidden_dim": 256,
    "num_heads": 4,
    "ffn_dim": 1024,
    "vocab_size": 32000,
    "max_seq_len": 2048,
    "base_num_layers": 4,
    "activation": "gelu",
    "dropout": 0.1
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 1e-3,
    "learning_rate_head": 3e-4,
    "warmup_steps": 1000,
    "epochs_per_layer": 5,
    "eval_interval": 200,
    "save_interval": 500,
    "gradient_clip": 1.0,
    "weight_decay": 0.01
  },
  "layer_addition": {
    "start_layer": 4,
    "end_layer": 100,
    "initialization": "kaiming_uniform",
    "scale_factor": 0.1
  },
  "data": {
    "sources": [
      "pile_subset_10B.arrow"
    ],
    "batch_composition": "mixed",
    "curriculum": "none",
    "sequence_length": 1024,
    "num_workers": 4
  },
  "hardware": {
    "device": "cuda",
    "dtype": "float32",
    "mixed_precision": false,
    "num_gpus": 256,
    "distributed": true,
    "backend": "nccl"
  },
  "monitoring": {
    "log_interval": 100,
    "eval_interval": 200,
    "save_interval": 500,
    "tensorboard": true,
    "wandb": true
  }
}

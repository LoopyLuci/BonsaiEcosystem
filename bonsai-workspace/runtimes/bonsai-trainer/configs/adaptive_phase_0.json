{
  "seed": 42,
  "description": "Phase 0: Base Model Training (100M params, 4L, 256D, 1E)",
  "model": {
    "num_layers": 4,
    "hidden_dim": 256,
    "num_heads": 4,
    "ffn_dim": 1024,
    "vocab_size": 32000,
    "max_seq_len": 2048,
    "activation": "gelu",
    "dropout": 0.1
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 3e-4,
    "warmup_steps": 5000,
    "total_steps": 100000,
    "eval_interval": 500,
    "save_interval": 1000,
    "gradient_clip": 1.0,
    "weight_decay": 0.01
  },
  "data": {
    "sources": [
      "pile_subset_1B.arrow"
    ],
    "batch_composition": "balanced",
    "curriculum": "none",
    "sequence_length": 512,
    "num_workers": 4
  },
  "hardware": {
    "device": "cuda",
    "dtype": "float32",
    "mixed_precision": false,
    "num_gpus": 32,
    "distributed": true,
    "backend": "nccl"
  },
  "monitoring": {
    "log_interval": 100,
    "eval_interval": 500,
    "save_interval": 1000,
    "tensorboard": true,
    "wandb": false
  }
}

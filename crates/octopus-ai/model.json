{
  "model": {
    "id": "octopus-ai",
    "name": "Octopus AI Server Management Assistant",
    "version": "1.0.0",
    "description": "Fine-tuned language model specialized in server administration and system management Q&A",
    "base_model": "DistilGPT-2",
    "base_model_size_params": "82M",
    "fine_tuning": {
      "method": "LoRA",
      "rank": 4,
      "alpha": 8,
      "training_steps": 158,
      "final_loss": 1.512,
      "training_time_seconds": 750
    },
    "training_data": {
      "location": "training-data/",
      "train_examples": 9000,
      "validation_examples": 1000,
      "domain": "server-management",
      "format": "jsonl"
    },
    "model_location": "models/octopus-ai/",
    "files": {
      "pytorch_model_bin": "pytorch_model.bin",
      "config_json": "config.json",
      "tokenizer_json": "tokenizer.json",
      "tokenizer_config": "tokenizer_config.json",
      "generation_config": "generation_config.json",
      "vocab_json": "vocab.json",
      "special_tokens": "special_tokens_map.json",
      "merges": "merges.txt"
    },
    "capabilities": [
      "server-management-qa",
      "system-administration",
      "configuration-guidance",
      "troubleshooting",
      "ssh-setup",
      "monitoring",
      "networking"
    ],
    "framework": "pytorch",
    "model_type": "causal-language-model",
    "precision_support": ["fp32", "fp16", "int8", "int4"],
    "size": {
      "pytorch_mb": 312,
      "quantized_gguf_mb": 100,
      "ggml_q4_mb": 75,
      "ggml_q5_mb": 95
    },
    "hardware_requirements": {
      "cpu_only": {
        "min_memory_mb": 600,
        "recommended_memory_mb": 1024,
        "optimal_threads": 8,
        "recommended_precision": "int8"
      },
      "gpu": {
        "min_memory_mb": 2000,
        "optimal_memory_mb": 4000,
        "recommended_precision": "fp16"
      },
      "multi_gpu": {
        "min_memory_total_mb": 4000,
        "recommended_precision": "fp16"
      }
    },
    "performance": {
      "inference": {
        "cpu_latency_ms": "200-500",
        "cpu_throughput_qps": "2-5",
        "gpu_latency_ms": "20-50",
        "gpu_throughput_qps": "20-50",
        "multi_gpu_throughput_qps": "50-100"
      }
    },
    "integration": {
      "bueb": true,
      "kdb": true,
      "bmf": true,
      "model_selector": true
    },
    "status": "production-ready",
    "tags": ["server-management", "system-admin", "qa-assistant", "octopus"],
    "license": "Apache-2.0",
    "authors": ["BonsAI Team"],
    "last_updated": "2026-06-03"
  }
}

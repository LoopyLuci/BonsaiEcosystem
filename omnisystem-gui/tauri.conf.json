{
  "productName": "Omnisystem",
  "version": "1.0.0",
  "identifier": "com.omnisystem.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 1080,
        "resizable": true,
        "title": "Omnisystem v1.0.0",
        "width": 1920,
        "minHeight": 600,
        "minWidth": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}

{
  "mcpServers": {
    "bonsai-mcp-server": {
      "command": "cargo",
      "args": [
        "run",
        "--manifest-path",
        "Z:\\Projects\\BonsaiWorkspace\\crates\\bonsai-mcp-server\\Cargo.toml",
        "--release"
      ],
      "env": {
        "RUST_LOG": "debug,bonsai_mcp=trace",
        "BONSAI_CONFIG": "Z:\\Projects\\BonsaiWorkspace\\.bonsai\\config.toml"
      }
    },
    "bonsai-bug-hunter": {
      "command": "cargo",
      "args": [
        "run",
        "--manifest-path",
        "Z:\\Projects\\BonsaiWorkspace\\crates\\bonsai-bug-hunter\\Cargo.toml",
        "--release"
      ],
      "env": {
        "RUST_LOG": "debug,bug_hunter=trace"
      }
    },
    "bonsai-ci": {
      "command": "cargo",
      "args": [
        "run",
        "--manifest-path",
        "Z:\\Projects\\BonsaiWorkspace\\crates\\bonsai-ci\\Cargo.toml",
        "--release"
      ]
    }
  },
  "tools": {
    "bonsai-mcp": [
      "bonsai_lint",
      "bonsai_apply_fix",
      "bonsai_dismiss_diagnostic",
      "bonsai_report_false_positive"
    ],
    "bonsai-bug-hunter": [
      "bonsai_scan_repo",
      "bonsai_scan_status",
      "bonsai_list_findings",
      "bonsai_get_finding",
      "bonsai_auto_fix",
      "bonsai_explain_diagnostic",
      "bonsai_prioritize_findings",
      "bonsai_generate_report"
    ],
    "bonsai-ci": [
      "bonsai_run_checks",
      "bonsai_trigger_workflow",
      "bonsai_get_workflow_status",
      "bonsai_list_workflows"
    ]
  }
}

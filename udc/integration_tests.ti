        let rule = UdcRule {
            id: "safe-high-conf".to_string(),
            name: "Safe High Confidence Rule".to_string(),
            source_operation: "readl".to_string(),
            target_operation: "ioread32".to_string(),
            source_operands: vec!["addr".to_string()],
            target_operands: vec!["result".to_string()],
            author: "bonsai-team".to_string(),
            description: "Known safe mapping from kernel API".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Type checking should pass
        assert!(report.type_check_passed);

        // Equivalence should be high
        assert!(report.equivalence_passed);

        // Overall confidence should be reasonable
        assert!(report.overall_confidence > 0.75);
    }

    #[test]
    fn test_verification_deterministic() {
        let mut orchestrator1 = UdcVerificationOrchestrator::new();
        let mut orchestrator2 = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "deterministic-test".to_string(),
            name: "Deterministic Test".to_string(),
            source_operation: "readl".to_string(),
            target_operation: "ioread32".to_string(),
            source_operands: vec!["addr".to_string()],
            target_operands: vec!["value".to_string()],
            author: "bonsai-team".to_string(),
            description: "Testing determinism".to_string(),
        };

        let report1 = orchestrator1.verify_rule(&rule);
        let report2 = orchestrator2.verify_rule(&rule);

        // Results should be identical
        assert_eq!(report1.rule_id, report2.rule_id);
        assert_eq!(report1.type_check_tier, report2.type_check_tier);
        assert_eq!(report1.type_check_passed, report2.type_check_passed);
        assert_eq!(report1.equivalence_confidence, report2.equivalence_confidence);
        assert_eq!(report1.equivalence_passed, report2.equivalence_passed);
    }

    #[test]
    fn test_verification_performance() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "perf-test".to_string(),
            name: "Performance Test".to_string(),
            source_operation: "readl".to_string(),
            target_operation: "ioread32".to_string(),
            source_operands: vec!["addr".to_string()],
            target_operands: vec!["value".to_string()],
            author: "bonsai-team".to_string(),
            description: "Performance test".to_string(),
        };

        let start = std::time::Instant::now();
        let _ = orchestrator.verify_rule(&rule);
        let elapsed = start.elapsed();

        // Should complete in reasonable time (< 100ms)
        assert!(elapsed.as_millis() < 100);

        // Cached lookup should be even faster
        let start = std::time::Instant::now();
        let _ = orchestrator.get_cached(&rule.id);
        let cached_elapsed = start.elapsed();

        assert!(cached_elapsed.as_millis() < 10);
    }
}

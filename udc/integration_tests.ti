    #[test]
    fn test_unknown_author_low_confidence() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "unknown-author-rule".to_string(),
            name: "Unknown Author Rule".to_string(),
            source_operation: "readl".to_string(),
            target_operation: "ioread32".to_string(),
            source_operands: vec!["addr".to_string()],
            target_operands: vec!["value".to_string()],
            author: "unknown_person".to_string(),
            description: "Rule from unknown author".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Should have lower overall confidence due to unknown author
        if let Some(quality) = &report.rule_quality {
            assert!(quality.author == rule_quality::AuthorReputation::Community);
        }

        // Should require review despite equivalence
        assert!(report.requires_human_review);
    }

    #[test]
    fn test_multiple_rules_batch_verification() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rules = vec![
            UdcRule {
                id: "rule-io-1".to_string(),
                name: "IO Rule 1".to_string(),
                source_operation: "readl".to_string(),
                target_operation: "ioread32".to_string(),
                source_operands: vec!["a".to_string()],
                target_operands: vec!["b".to_string()],
                author: "bonsai-team".to_string(),
                description: "IO rule 1".to_string(),
            },
            UdcRule {
                id: "rule-mem-1".to_string(),
                name: "Mem Rule 1".to_string(),
                source_operation: "mov".to_string(),
                target_operation: "move".to_string(),
                source_operands: vec!["c".to_string()],
                target_operands: vec!["d".to_string()],
                author: "bonsai-team".to_string(),
                description: "Mem rule 1".to_string(),
            },
            UdcRule {
                id: "rule-atomic-1".to_string(),
                name: "Atomic Rule 1".to_string(),
                source_operation: "atomic_read".to_string(),
                target_operation: "atomic_load".to_string(),
                source_operands: vec!["e".to_string()],
                target_operands: vec!["f".to_string()],
                author: "verified-contributor".to_string(),
                description: "Atomic rule 1".to_string(),
            },
        ];

        let batch = orchestrator.verify_rules(&rules);

        assert_eq!(batch.total_rules, 3);
        assert!(batch.safe_rules > 0);
        assert!(!batch.reports.is_empty());

        let avg_conf = batch.average_confidence();
        assert!(avg_conf >= 0.0);
        assert!(avg_conf <= 1.0);
    }

    #[test]
    fn test_verification_with_axiom_check() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "axiom-check-rule".to_string(),
            name: "Axiom Check Rule".to_string(),
            source_operation: "atomic_update".to_string(),
            target_operation: "atomic_store".to_string(),
            source_operands: vec!["var".to_string(), "value".to_string()],
            target_operands: vec!["var".to_string(), "value".to_string()],
            author: "bonsai-team".to_string(),
            description: "Rule requiring axiom verification".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Should have axiom results
        assert!(!report.axiom_results.is_empty());

        // At least some axioms should be verified
        let verified = report.axiom_results.iter().filter(|(_, v)| *v).count();
        assert!(verified > 0);
    }

    #[test]
    fn test_fuzzing_catches_invalid_operands() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        // Rule with potentially problematic operands
        let rule = UdcRule {
            id: "invalid-operand-rule".to_string(),
            name: "Invalid Operand Rule".to_string(),
            source_operation: "memory_read".to_string(),
            target_operation: "memory_read_safe".to_string(),
            source_operands: vec!["invalid_register".to_string()],
            target_operands: vec!["valid_register".to_string()],
            author: "unknown".to_string(),
            description: "Rule with invalid operands".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Fuzzing should detect invalid register
        if let Some(fuzz) = &report.fuzzing_report {
            // May or may not fail depending on handling
            let _ = fuzz.all_passed();
        }
    }

    #[test]
    fn test_recommendations_provided() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "rec-test-rule".to_string(),
            name: "Recommendation Test Rule".to_string(),
            source_operation: "test_op".to_string(),
            target_operation: "test_op_mapped".to_string(),
            source_operands: vec!["x".to_string()],
            target_operands: vec!["y".to_string()],
            author: "unknown".to_string(),
            description: "Testing recommendations".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Should always have recommendations
        assert!(!report.recommendations.is_empty());

        // At least one recommendation should be non-empty
        let non_empty = report
            .recommendations
            .iter()
            .filter(|r| !r.is_empty())
            .count();
        assert!(non_empty > 0);
    }

    #[test]
    fn test_safe_rule_high_confidence() {

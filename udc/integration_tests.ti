/// UDC Verification System - Integration Tests
/// Comprehensive test suite validating all verification tiers working together

#[cfg(test)]
mod integration_tests {
    use super::super::*;

    #[test]
    fn test_complete_io_read_rule_verification() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "io-read-complete".to_string(),
            name: "Complete I/O Read Verification".to_string(),
            source_operation: "readl".to_string(),
            target_operation: "ioread32".to_string(),
            source_operands: vec!["volatile_addr".to_string()],
            target_operands: vec!["value".to_string()],
            author: "bonsai-team".to_string(),
            description: "Verify readl maps to ioread32 correctly".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Should pass type checking
        assert!(report.type_check_passed);

        // Should achieve reasonable equivalence
        assert!(report.equivalence_confidence >= 0.7);

        // Should have fuzzing results
        assert!(report.fuzzing_report.is_some());
        if let Some(fuzz) = &report.fuzzing_report {
            assert!(fuzz.passed > 0);
        }

        // Should have quality assessment
        assert!(report.rule_quality.is_some());

        // Should have overall confidence
        assert!(report.overall_confidence > 0.6);
    }

    #[test]
    fn test_atomic_operation_rule_verification() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "atomic-op".to_string(),
            name: "Atomic Operation".to_string(),
            source_operation: "atomic_read".to_string(),
            target_operation: "atomic_load".to_string(),
            source_operands: vec!["atomic_var".to_string()],
            target_operands: vec!["loaded_value".to_string()],
            author: "bonsai-team".to_string(),
            description: "Verify atomic operations".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Atomic operations should be recognized as equivalent
        assert!(report.equivalence_confidence >= 0.8);
        assert!(report.equivalence_passed);
    }

    #[test]
    fn test_register_move_rule_verification() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "reg-move".to_string(),
            name: "Register Move".to_string(),
            source_operation: "mov".to_string(),
            target_operation: "move".to_string(),
            source_operands: vec!["rax".to_string()],
            target_operands: vec!["rbx".to_string()],
            author: "bonsai-team".to_string(),
            description: "Register move operation".to_string(),
        };

        let report = orchestrator.verify_rule(&rule);

        // Should recognize as equivalent operation
        assert!(report.equivalence_passed);
        assert!(report.equivalence_confidence >= 0.8);

        // Type checking should pass (register to register)
        assert!(report.type_check_passed);
    }

    #[test]
    fn test_memory_write_rule_verification() {
        let mut orchestrator = UdcVerificationOrchestrator::new();

        let rule = UdcRule {
            id: "mem-write".to_string(),
            name: "Memory Write".to_string(),
            source_operation: "writel".to_string(),
            target_operation: "iowrite32".to_string(),
            source_operands: vec!["address".to_string(), "value".to_string()],
            target_operands: vec!["address".to_string(), "value".to_string()],

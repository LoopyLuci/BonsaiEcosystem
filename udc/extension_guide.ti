//
// New Instruction variant (in ir_system.ti):
//
//   pub enum Instruction {
//       // ... existing instructions ...
//
//       NetworkWrite {
//           socket_id: u32,
//           length: u32,
//           timeout_ms: u32,
//       },
//       NetworkRead {
//           socket_id: u32,
//           max_length: u32,
//           timeout_ms: u32,
//       },
//   }

// TransferDaemon P2P Test – Type Definitions (Titan)
// Real internet transfer test between two Sanctum vaults

module transfer_test::types

use core::string::String
use core::vec::Vec
use core::option::Option
use core::map::Map
use core::time::Timestamp

// ============================================================================
// Transfer Metrics
// ============================================================================

pub struct TransferMetrics {
    pub test_id: String,
    pub source_node: String,
    pub dest_node: String,
    pub file_path: String,
    pub file_size_bytes: u64,
    pub source_hash: String,
    pub dest_hash: String,
    pub hash_verified: bool,
    pub transfer_id: String,
    pub start_time: Timestamp,
    pub end_time: Timestamp,
    pub duration_ms: u64,
    pub throughput_mbps: f64,
    pub bytes_transferred: u64,
    pub success: bool,
    pub error: Option<String>,
    pub retry_count: u32,
}

impl TransferMetrics {
    pub fn new(test_id: String, src_node: String, dst_node: String, file_size: u64) -> Self {
        Self {
            test_id,
            source_node: src_node,
            dest_node: dst_node,
            file_path: String::new(),
            file_size_bytes: file_size,
            source_hash: String::new(),
            dest_hash: String::new(),
            hash_verified: false,
            transfer_id: String::new(),
            start_time: Timestamp::now(),
            end_time: Timestamp::now(),
            duration_ms: 0,
            throughput_mbps: 0.0,
            bytes_transferred: 0,
            success: false,
            error: None,
            retry_count: 0,
        }
    }

    pub fn compute_throughput(&mut self) {
        if self.duration_ms > 0 {
            self.throughput_mbps = (self.bytes_transferred as f64 * 8.0) / (self.duration_ms as f64 * 1000.0);
        }
    }
}

// ============================================================================
// TransferDaemon Lane Statistics
// ============================================================================

pub enum LaneType {
    TCP,
    QUIC,
    WebRTC,
    Relay,
    Direct,
    Hybrid,
}

impl LaneType {
    pub fn to_string(&self) -> String {
        match self {
            LaneType::TCP => "tcp".to_string(),
            LaneType::QUIC => "quic".to_string(),
            LaneType::WebRTC => "webrtc".to_string(),
            LaneType::Relay => "relay".to_string(),
            LaneType::Direct => "direct".to_string(),
            LaneType::Hybrid => "hybrid".to_string(),
        }
    }
}

pub struct LaneStats {
    pub lane_id: String,
    pub lane_type: LaneType,
    pub bytes_sent: u64,
    pub bytes_received: u64,
    pub packets_sent: u64,
    pub packets_received: u64,
    pub packets_lost: u64,
    pub latency_min_ms: u64,
    pub latency_max_ms: u64,
    pub latency_avg_ms: u64,
    pub jitter_ms: u64,
    pub bandwidth_mbps: f64,
    pub reliability_percent: f64,
    pub start_time: Timestamp,
    pub end_time: Timestamp,
}

impl LaneStats {
    pub fn new(lane_id: String, lane_type: LaneType) -> Self {
        Self {
            lane_id,
            lane_type,
            bytes_sent: 0,
            bytes_received: 0,
            packets_sent: 0,
            packets_received: 0,
            packets_lost: 0,
            latency_min_ms: u64::MAX,
            latency_max_ms: 0,
            latency_avg_ms: 0,
            jitter_ms: 0,
            bandwidth_mbps: 0.0,
            reliability_percent: 100.0,
            start_time: Timestamp::now(),
            end_time: Timestamp::now(),
        }
    }

    pub fn compute_reliability(&mut self) {
        let total = self.packets_sent + self.packets_lost;
        if total > 0 {
            self.reliability_percent = ((self.packets_sent as f64 / total as f64) * 100.0);
        }
    }
}

// ============================================================================
// Transfer State
// ============================================================================

pub enum TransferState {
    Pending,
    Discovering,
    NatTraversal,
    Established,
    InProgress,
    Paused,
    Completed,
    Failed,
    Cancelled,
}

pub struct TransferStatus {
    pub transfer_id: String,
    pub state: TransferState,
    pub progress_percent: f64,
    pub bytes_transferred: u64,
    pub total_bytes: u64,
    pub active_lanes: Vec<String>,
    pub per_lane_stats: Vec<LaneStats>,
    pub eta_seconds: u64,
    pub error: Option<String>,
}

// ============================================================================
// Peer Information
// ============================================================================

pub struct PeerInfo {
    pub peer_id: String,
    pub node_name: String,
    pub public_address: String,
    pub public_port: u16,
    pub is_reachable: bool,
    pub nat_type: String,
    pub last_seen: Timestamp,
    pub supported_lanes: Vec<LaneType>,
}

// ============================================================================
// Test Configuration
// ============================================================================

pub struct TestConfig {
    pub test_name: String,
    pub source_node_id: String,
    pub dest_node_id: String,
    pub source_address: String,
    pub source_api_port: u16,
    pub dest_address: String,
    pub dest_api_port: u16,
    pub file_size_mb: u64,
    pub file_count: u32,
    pub timeout_seconds: u64,
    pub multi_path_enabled: bool,
    pub encryption_enabled: bool,
    pub compression_enabled: bool,
    pub verify_integrity: bool,
}

impl TestConfig {
    pub fn new(name: String) -> Self {
        Self {
            test_name: name,
            source_node_id: String::new(),
            dest_node_id: String::new(),
            source_address: String::new(),
            source_api_port: 8114,
            dest_address: String::new(),
            dest_api_port: 8114,
            file_size_mb: 50,
            file_count: 1,
            timeout_seconds: 300,
            multi_path_enabled: true,
            encryption_enabled: true,
            compression_enabled: false,
            verify_integrity: true,
        }
    }
}

// ============================================================================
// Test Results
// ============================================================================

pub struct TestResults {
    pub test_id: String,
    pub test_config: TestConfig,
    pub start_time: Timestamp,
    pub end_time: Timestamp,
    pub total_duration_ms: u64,
    pub transfer_metrics: Vec<TransferMetrics>,
    pub passed: bool,
    pub failed_reason: Option<String>,
    pub summary_stats: SummaryStats,
}

pub struct SummaryStats {
    pub total_bytes_transferred: u64,
    pub total_duration_ms: u64,
    pub avg_throughput_mbps: f64,
    pub peak_throughput_mbps: f64,
    pub min_throughput_mbps: f64,
    pub success_rate: f64,
    pub lanes_used: Vec<String>,
    pub avg_latency_ms: u64,
    pub packet_loss_percent: f64,
}

// ============================================================================
// Node Capability Token
// ============================================================================

pub struct CapabilityToken {
    pub token_id: String,
    pub issued_to: String,
    pub valid_from: Timestamp,
    pub valid_until: Timestamp,
    pub permissions: Vec<String>,
    pub signature: Vec<u8>,
}

impl CapabilityToken {
    pub fn is_valid(&self) -> bool {
        let now = Timestamp::now();
        now >= self.valid_from && now <= self.valid_until
    }

    pub fn has_permission(&self, perm: &str) -> bool {
        self.permissions.contains(&perm.to_string())
    }
}

// ============================================================================
// Sanctum Vault Configuration
// ============================================================================

pub struct SanctumVaultConfig {
    pub vault_id: String,
    pub vault_name: String,
    pub data_dir: String,
    pub network_namespace: String,
    pub memory_limit_mb: u32,
    pub cpu_limit_percent: u32,
    pub enable_monitoring: bool,
    pub enable_audit_logging: bool,
}

impl SanctumVaultConfig {
    pub fn new(vault_id: String, name: String, data_dir: String) -> Self {
        Self {
            vault_id,
            vault_name: name,
            data_dir,
            network_namespace: String::new(),
            memory_limit_mb: 4096,
            cpu_limit_percent: 100,
            enable_monitoring: true,
            enable_audit_logging: true,
        }
    }
}


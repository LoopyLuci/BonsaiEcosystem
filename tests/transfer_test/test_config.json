{
  "test_name": "Real Internet P2P Transfer Test",
  "description": "Production-grade test of TransferDaemon multi-path bonding and FTDaemon file transfer over real internet",
  "node_a": {
    "id": "node-a",
    "name": "Node A (Source)",
    "address": "54.123.45.67",
    "port": 8114,
    "sanctum_vault_id": "vault-a",
    "data_directory": "/data/node-a",
    "region": "us-east-1",
    "instance_type": "t3.large"
  },
  "node_b": {
    "id": "node-b",
    "name": "Node B (Destination)",
    "address": "34.234.56.78",
    "port": 8114,
    "sanctum_vault_id": "vault-b",
    "data_directory": "/data/node-b",
    "region": "eu-west-1",
    "instance_type": "t3.large"
  },
  "test_parameters": {
    "file_size_mb": 50,
    "file_count": 1,
    "timeout_seconds": 300,
    "retry_on_failure": true,
    "max_retries": 3,
    "monitor_system_metrics": true,
    "save_results_to_file": true,
    "results_output_path": "/tmp/ftdaemon_test_results.json"
  },
  "features": {
    "multi_path_enabled": true,
    "encryption_enabled": true,
    "encryption_algorithm": "post-quantum-hybrid",
    "compression_enabled": false,
    "verify_integrity": true,
    "integrity_algorithm": "blake3"
  },
  "lanes": {
    "tcp_direct": {
      "enabled": true,
      "priority": 1,
      "timeout_ms": 30000
    },
    "quic_direct": {
      "enabled": true,
      "priority": 2,
      "timeout_ms": 30000
    },
    "webrtc_datachannel": {
      "enabled": true,
      "priority": 3,
      "timeout_ms": 30000
    },
    "relay": {
      "enabled": true,
      "priority": 4,
      "timeout_ms": 30000,
      "relay_server": "relay.omnisystem.io"
    }
  },
  "nat_traversal": {
    "enabled": true,
    "protocol": "dcutr",
    "hole_punching": true,
    "timeout_seconds": 30
  },
  "monitoring": {
    "collect_per_lane_metrics": true,
    "collect_system_metrics": true,
    "collect_network_metrics": true,
    "metrics_interval_seconds": 1,
    "enable_detailed_logging": true,
    "log_level": "info"
  },
  "validation": {
    "verify_hash_match": true,
    "check_file_permissions": true,
    "verify_encryption": true,
    "check_packet_integrity": true
  },
  "reporting": {
    "generate_json_report": true,
    "generate_html_report": true,
    "upload_to_uvm": true,
    "uvm_endpoint": "https://uvm.omnisystem.io/api/v1/test-results",
    "include_raw_metrics": true,
    "include_lane_details": true
  }
}

// TransferDaemon Test Configuration (Aether)

module transfer_test::config

use core::string::String
use core::vec::Vec

pub struct NodeConfig {
    pub id: String,
    pub name: String,
    pub address: String,
    pub port: u16,
    pub sanctum_vault_id: String,
    pub data_directory: String,
}

pub struct TestConfiguration {
    pub node_a: NodeConfig,
    pub node_b: NodeConfig,
    pub file_size_mb: u64,
    pub file_count: u32,
    pub timeout_seconds: u64,
    pub multi_path_enabled: bool,
    pub encryption_enabled: bool,
    pub compression_enabled: bool,
    pub verify_integrity: bool,
    pub monitor_system_metrics: bool,
    pub save_results_to_file: bool,
    pub results_output_path: String,
}

impl TestConfiguration {
    pub fn load_from_env() -> Result<Self, String> {
        let node_a_id = std::env::var("FTDAEMON_NODE_A_ID")
            .unwrap_or("node-a".to_string())
        let node_a_addr = std::env::var("FTDAEMON_NODE_A_ADDR")
            .unwrap_or("127.0.0.1".to_string())
        let node_a_port = std::env::var("FTDAEMON_NODE_A_PORT")
            .unwrap_or("8114".to_string())
            .parse::<u16>()
            .map_err(|e| format!("Invalid Node A port: {}", e))?

        let node_b_id = std::env::var("FTDAEMON_NODE_B_ID")
            .unwrap_or("node-b".to_string())
        let node_b_addr = std::env::var("FTDAEMON_NODE_B_ADDR")
            .unwrap_or("127.0.0.1".to_string())
        let node_b_port = std::env::var("FTDAEMON_NODE_B_PORT")
            .unwrap_or("8115".to_string())
            .parse::<u16>()
            .map_err(|e| format!("Invalid Node B port: {}", e))?

        let file_size_mb = std::env::var("FTDAEMON_TEST_FILE_SIZE_MB")
            .unwrap_or("50".to_string())
            .parse::<u64>()
            .map_err(|e| format!("Invalid file size: {}", e))?

        let file_count = std::env::var("FTDAEMON_TEST_FILE_COUNT")
            .unwrap_or("1".to_string())
            .parse::<u32>()
            .map_err(|e| format!("Invalid file count: {}", e))?

        let timeout_seconds = std::env::var("FTDAEMON_TEST_TIMEOUT")
            .unwrap_or("300".to_string())
            .parse::<u64>()
            .map_err(|e| format!("Invalid timeout: {}", e))?

        let multi_path = std::env::var("FTDAEMON_MULTI_PATH")
            .unwrap_or("true".to_string())
            .parse::<bool>()
            .unwrap_or(true)

        let encryption = std::env::var("FTDAEMON_ENCRYPTION")
            .unwrap_or("true".to_string())
            .parse::<bool>()
            .unwrap_or(true)

        let compression = std::env::var("FTDAEMON_COMPRESSION")
            .unwrap_or("false".to_string())
            .parse::<bool>()
            .unwrap_or(false)

        let verify = std::env::var("FTDAEMON_VERIFY_INTEGRITY")
            .unwrap_or("true".to_string())
            .parse::<bool>()
            .unwrap_or(true)

        let monitor_metrics = std::env::var("FTDAEMON_MONITOR_METRICS")
            .unwrap_or("true".to_string())
            .parse::<bool>()
            .unwrap_or(true)

        let save_results = std::env::var("FTDAEMON_SAVE_RESULTS")
            .unwrap_or("true".to_string())
            .parse::<bool>()
            .unwrap_or(true)

        let results_path = std::env::var("FTDAEMON_RESULTS_PATH")
            .unwrap_or("/tmp/ftdaemon_test_results.json".to_string())

        Ok(TestConfiguration {
            node_a: NodeConfig {
                id: node_a_id,
                name: "Node A".to_string(),
                address: node_a_addr,
                port: node_a_port,
                sanctum_vault_id: std::env::var("FTDAEMON_NODE_A_VAULT_ID")
                    .unwrap_or("vault-a".to_string()),
                data_directory: std::env::var("FTDAEMON_NODE_A_DATA_DIR")
                    .unwrap_or("/data/node-a".to_string()),
            },
            node_b: NodeConfig {
                id: node_b_id,
                name: "Node B".to_string(),
                address: node_b_addr,
                port: node_b_port,
                sanctum_vault_id: std::env::var("FTDAEMON_NODE_B_VAULT_ID")
                    .unwrap_or("vault-b".to_string()),
                data_directory: std::env::var("FTDAEMON_NODE_B_DATA_DIR")
                    .unwrap_or("/data/node-b".to_string()),
            },
            file_size_mb,
            file_count,
            timeout_seconds,
            multi_path_enabled: multi_path,
            encryption_enabled: encryption,
            compression_enabled: compression,
            verify_integrity: verify,
            monitor_system_metrics: monitor_metrics,
            save_results_to_file: save_results,
            results_output_path: results_path,
        })
    }

    pub fn load_from_file(path: &str) -> Result<Self, String> {
        // Load configuration from JSON file
        let content = std::fs::read_to_string(path)
            .map_err(|e| format!("Failed to read config file: {}", e))?

        let config: TestConfiguration = serde_json::from_str(&content)
            .map_err(|e| format!("Failed to parse config JSON: {}", e))?

        Ok(config)
    }

    pub fn default() -> Self {
        Self {
            node_a: NodeConfig {
                id: "node-a".to_string(),
                name: "Node A".to_string(),
                address: "127.0.0.1".to_string(),
                port: 8114,
                sanctum_vault_id: "vault-a".to_string(),
                data_directory: "/data/node-a".to_string(),
            },
            node_b: NodeConfig {
                id: "node-b".to_string(),
                name: "Node B".to_string(),
                address: "127.0.0.1".to_string(),
                port: 8115,
                sanctum_vault_id: "vault-b".to_string(),
                data_directory: "/data/node-b".to_string(),
            },
            file_size_mb: 50,
            file_count: 1,
            timeout_seconds: 300,
            multi_path_enabled: true,
            encryption_enabled: true,
            compression_enabled: false,
            verify_integrity: true,
            monitor_system_metrics: true,
            save_results_to_file: true,
            results_output_path: "/tmp/ftdaemon_test_results.json".to_string(),
        }
    }
}

{
  "version": "1.0.0",
  "environment": "production",
  "workflows": {
    "pr_validation": {
      "name": "PR Validation",
      "timeout_minutes": 60,
      "parallel_jobs": 8,
      "steps": [
        {
          "name": "Checkout",
          "run": "git checkout ."
        },
        {
          "name": "Format Check",
          "run": "cargo fmt --all -- --check",
          "critical": true
        },
        {
          "name": "Clippy Lint",
          "run": "cargo clippy --all --all-targets -- -D warnings",
          "critical": true
        },
        {
          "name": "Build",
          "run": "cargo build --all",
          "critical": true
        },
        {
          "name": "Unit Tests",
          "run": "cargo test --all --unit-tests",
          "critical": true
        },
        {
          "name": "Integration Tests",
          "run": "cargo test --all --test '*'",
          "critical": true
        },
        {
          "name": "Documentation",
          "run": "cargo doc --all --no-deps",
          "critical": false
        }
      ]
    },
    "nightly_soak": {
      "name": "Nightly Soak Test",
      "timeout_minutes": 120,
      "parallel_jobs": 8,
      "steps": [
        {
          "name": "Build All",
          "run": "cargo build --release --all"
        },
        {
          "name": "Long-Running Tests",
          "run": "cargo test --all --test '*' -- --test-threads=1 --nocapture"
        },
        {
          "name": "Memory Tests",
          "run": "cargo test --all --features memory_tests"
        },
        {
          "name": "Stress Tests",
          "run": "cargo test --all --test stress_tests -- --nocapture"
        }
      ]
    },
    "quick_check": {
      "name": "Quick Check",
      "timeout_minutes": 30,
      "parallel_jobs": 4,
      "steps": [
        {
          "name": "Format Check",
          "run": "cargo fmt --all -- --check",
          "critical": true
        },
        {
          "name": "Clippy",
          "run": "cargo clippy --all -- -D warnings",
          "critical": true
        },
        {
          "name": "Build",
          "run": "cargo build --all",
          "critical": true
        }
      ]
    },
    "coverage": {
      "name": "Coverage Analysis",
      "timeout_minutes": 45,
      "parallel_jobs": 8,
      "steps": [
        {
          "name": "Install tarpaulin",
          "run": "cargo install cargo-tarpaulin"
        },
        {
          "name": "Generate Coverage",
          "run": "cargo tarpaulin --all --out Xml --output-dir artifacts/coverage"
        },
        {
          "name": "Check Coverage Gate",
          "run": "python scripts/check_coverage_gate.py",
          "critical": true
        }
      ]
    },
    "stress_test": {
      "name": "Stress Test Suite",
      "timeout_minutes": 90,
      "parallel_jobs": 8,
      "steps": [
        {
          "name": "Build Release",
          "run": "cargo build --release --all"
        },
        {
          "name": "Run Stress Tests",
          "run": "cargo test --release --all --test stress_tests -- --nocapture --test-threads=1"
        },
        {
          "name": "Memory Leak Tests",
          "run": "cargo test --all --features leak_tests"
        }
      ]
    },
    "benchmark": {
      "name": "Benchmark Suite",
      "timeout_minutes": 60,
      "parallel_jobs": 8,
      "steps": [
        {
          "name": "Build Benches",
          "run": "cargo bench --all --no-run"
        },
        {
          "name": "Run Benchmarks",
          "run": "cargo bench --all"
        },
        {
          "name": "Compare Results",
          "run": "python scripts/compare_benchmarks.py"
        }
      ]
    },
    "android_regression": {
      "name": "Android Regression Tests",
      "timeout_minutes": 60,
      "steps": [
        {
          "name": "Build Android",
          "run": "cargo build --release --target aarch64-linux-android"
        },
        {
          "name": "Android Tests",
          "run": "cargo test --target aarch64-linux-android"
        }
      ]
    },
    "full_suite": {
      "name": "Full Test Suite",
      "timeout_minutes": 120,
      "steps": [
        {
          "name": "Format Check",
          "run": "cargo fmt --all -- --check"
        },
        {
          "name": "Clippy",
          "run": "cargo clippy --all -- -D warnings"
        },
        {
          "name": "Build",
          "run": "cargo build --all"
        },
        {
          "name": "Test All",
          "run": "cargo test --all"
        },
        {
          "name": "Documentation",
          "run": "cargo doc --all --no-deps"
        },
        {
          "name": "Coverage",
          "run": "cargo tarpaulin --all --out Xml"
        }
      ]
    }
  },
  "notifications": {
    "slack": {
      "enabled": true,
      "channels": {
        "success": "#ci-cd-success",
        "failure": "#ci-cd-alerts",
        "pr": "#ci-cd-pr"
      }
    },
    "github": {
      "enabled": true,
      "require_status_checks": true
    },
    "email": {
      "enabled": false,
      "recipients": []
    }
  },
  "artifacts": {
    "path": "./artifacts",
    "retention_days": 30,
    "types": {
      "pr-validation": ["test-results.json", "coverage.xml"],
      "nightly-soak": ["memory-profile.json", "stress-results.json"],
      "coverage": ["coverage.xml", "summary.md"],
      "benchmarks": ["results.json", "summary.md"]
    }
  },
  "performance": {
    "target_pr_validation_minutes": 45,
    "target_nightly_minutes": 90,
    "max_parallel_jobs": 8,
    "artifact_cache_enabled": true
  },
  "security": {
    "require_signed_commits": false,
    "scan_dependencies": true,
    "sbom_generation": true
  }
}
